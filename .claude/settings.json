{
  "env": {
    "MCP_LOG_MAX_OUTPUT_BYTES": "2048"
  },
  "permissions": {
    "allow": [
      "mcp__msw-maker-mcp__maker_execute_script",
      "mcp__msw-maker-mcp__maker_logs",
      "mcp__msw-maker-mcp__maker_stop",
      "mcp__msw-maker-mcp__maker_refresh_workspace",
      "Bash(node -e ' *)",
      "Bash(node \"C:/Users/mh566/AppData/Local/Temp/claude/d-------/09cd0e1f-f0bb-47a3-a3f3-6ecd147da4e3/scratchpad/dex_snapshot.cjs\")",
      "Bash(node \"C:/Users/mh566/AppData/Local/Temp/claude/d-------/09cd0e1f-f0bb-47a3-a3f3-6ecd147da4e3/scratchpad/dex_query.cjs\")",
      "Bash(node \"C:/Users/mh566/AppData/Local/Temp/claude/d-------/09cd0e1f-f0bb-47a3-a3f3-6ecd147da4e3/scratchpad/dex_query2.cjs\")",
      "Bash(node \"C:/Users/mh566/AppData/Local/Temp/claude/d-------/09cd0e1f-f0bb-47a3-a3f3-6ecd147da4e3/scratchpad/dex_query3.cjs\")",
      "Bash(node \"C:/Users/mh566/AppData/Local/Temp/claude/d-------/09cd0e1f-f0bb-47a3-a3f3-6ecd147da4e3/scratchpad/dex_build.cjs\")",
      "Bash(node \"C:/Users/mh566/AppData/Local/Temp/claude/d-------/09cd0e1f-f0bb-47a3-a3f3-6ecd147da4e3/scratchpad/dex_diffcheck.cjs\")",
      "Bash(node \"C:/Users/mh566/AppData/Local/Temp/claude/d-------/09cd0e1f-f0bb-47a3-a3f3-6ecd147da4e3/scratchpad/dex_coincheck.cjs\")",
      "Bash(node \"C:/Users/mh566/AppData/Local/Temp/claude/d-------/09cd0e1f-f0bb-47a3-a3f3-6ecd147da4e3/scratchpad/dex_bgcheck.cjs\")",
      "Bash(node \"C:/Users/mh566/AppData/Local/Temp/claude/d-------/09cd0e1f-f0bb-47a3-a3f3-6ecd147da4e3/scratchpad/dex_build2.cjs\")",
      "Bash(node \"C:/Users/mh566/AppData/Local/Temp/claude/d-------/09cd0e1f-f0bb-47a3-a3f3-6ecd147da4e3/scratchpad/dex_verify.cjs\")",
      "Bash(node \"C:/Users/mh566/AppData/Local/Temp/claude/d-------/09cd0e1f-f0bb-47a3-a3f3-6ecd147da4e3/scratchpad/dex_idcheck.cjs\")"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/hooks-project/skill-read-guard.cjs\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/hooks/structured-file-guard/structured-file-guard.cjs\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/hooks-project/readonly-path-guard.cjs\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/hooks/structured-file-guard/structured-file-guard.cjs\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/hooks-project/readonly-path-guard.cjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/hooks/mlua-lsp/mlua-diagnose-post-tool-use.cjs\"",
            "timeout": 120
          }
        ]
      },
      {
        "matcher": "Read|Skill",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/hooks/skill-log/skill-log.cjs\"",
            "timeout": 5,
            "async": true
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/hooks/mcp-log/mcp-log.cjs\"",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/hooks/mlua-lsp/mlua-session-start.cjs\"",
            "timeout": 120
          }
        ]
      },
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/hooks/update-check/update-check.cjs\"",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/hooks/core-version-check/core-version-check.cjs\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/hooks-project/skill-router-lite.cjs\"",
            "timeout": 10
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/hooks/skill-log/skill-log.cjs\"",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/hooks/mlua-lsp/mlua-session-end.cjs\"",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
