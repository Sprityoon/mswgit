@Component
script PlayerController extends Component

	@Sync
	property integer LastDirectionX = -1

	@Sync
	property integer LastDirectionY = 0

	property any KeyDownHandler = nil

	property any ScreenTouchHandler = nil

	@Sync
	property integer Level = 1

	@Sync
	property integer Stamina = 100

	@Sync
	property integer MaxStamina = 100

	@Sync
	property integer XP = 0

	@Sync
	property integer MaxXP = 100

	@Sync
	property integer Attack = 15

	@Sync
	property integer Defense = 10

	@Sync
	property number GatheringSpeed = 1.0

	@Sync
	property number MovementSpeed = 100

	@Sync
	property Entity ActivePortal = nil

	property number LastMineTime = 0.0

	property number KnockbackSpeed = 16.0

	@HideFromInspector
	property number KnockTimer = 0

	@HideFromInspector
	property Vector2 KnockVel = Vector2(0, 0)

	property number MineCooldown = 0.6

	property boolean HasRequestedInitialStones = false

	@Sync
	property string UnlockedWaypointsJson = "[]"

	property string ReticleSpriteRUID = "662fd2de11094cf08be40d8b3fab11bc"

	property number ReticleScale = 0.5

	@Sync
	property number IFrameTimer = 0.0

	@Sync
	property boolean IsDead = false

	@Sync
	property boolean CanMineOnCurrentMap = true

	@Sync
	property boolean CanPlaceOnCurrentMap = true

	@Sync
	property boolean CanInteractOnCurrentMap = true

	-- T45: 신규 캐릭터는 QWER 공백. 해금 후 자동/수동 장착.
	@Sync
	property string EquippedSkillsJson = "[]"

	-- Skill Tree (S2): 보유 스킬 레벨 맵 JSON (skillId -> level). 0 또는 부재 = 미해금.
	@Sync
	property string SkillLevelsJson = "{}"

	-- Skill Tree (S2): 투자 가능한 스킬 포인트. 레벨업 시 SPPerLevelUp만큼 지급.
	@Sync
	property integer SP = 0

	-- 레벨업당 SP 지급량 (밸런스 튜닝값 — 인스펙터 프로퍼티로 관리)
	property integer SPPerLevelUp = 3

	property any CooldownMap = nil

	@Sync
	property boolean IsSleeping = false

	@Sync
	property string SleepStartTimeTicks = "0"

	@Sync
	property string FishingState = "None"

	@Sync
	property Entity ActiveFishingSpot = nil

	method void OnBeginPlay()
		-- description: Initialize key and screen touch event listeners on the client.
		self.CooldownMap = {}
		
		if self:IsClient() then
			self.KeyDownHandler = _InputService:ConnectEvent(KeyDownEvent, self.OnKeyDown)
			self.ScreenTouchHandler = _InputService:ConnectEvent(ScreenTouchEvent, self.OnScreenTouch)
		
			-- Remove ONLY the WASD movement keys from the engine PlayerControllerComponent — do NOT
			-- disable the whole component (that also killed facing/LookDirectionX, jump, and the MOVE/IDLE
			-- walk animation). Our custom arrow-key movement drives MovementComponent every frame, so the
			-- controller's own locomotion is already overridden; WASD only survived as an in-place walk
			-- animation. Dropping the WASD action keys makes WASD inert while the arrow keys keep driving
			-- facing/jump/animation natively. (W stays usable as skill slot 2 via OnKeyDown.)
			-- Delayed one tick so the controller has bound its default action keys first.
			_TimerService:SetTimerOnce(function()
				if not isvalid(self) or not isvalid(self.Entity) then return end
				local pcc = self.Entity.PlayerControllerComponent
				if isvalid(pcc) then
					pcc:RemoveActionKey(KeyboardKey.W)
					pcc:RemoveActionKey(KeyboardKey.A)
					pcc:RemoveActionKey(KeyboardKey.S)
					pcc:RemoveActionKey(KeyboardKey.D)
				end
			end, 0.2)
		
			local movement = self.Entity.MovementComponent
			if isvalid(movement) then
				movement.InputSpeed = 3.6  -- Set top-down movement speed
			end
			
			log("PlayerController initialized on client. Facing: " .. self.LastDirectionX .. ", " .. self.LastDirectionY)
		else
			log("PlayerController initialized on server for player: " .. self.Entity.Name)
			self._T.StaminaTimer = _TimerService:SetTimerRepeat(function()
				if self.IsDead then return end
				local playerComp = self.Entity.PlayerComponent
				if self.IsSleeping then
					self._T.SleepHpAccum = (self._T.SleepHpAccum or 0.0) + (playerComp.MaxHp / 600.0)
					self._T.SleepStaminaAccum = (self._T.SleepStaminaAccum or 0.0) + (self.MaxStamina / 600.0)
					
					local hpAdd = math.floor(self._T.SleepHpAccum)
					if hpAdd > 0 then
						playerComp.Hp = math.min(playerComp.MaxHp, playerComp.Hp + hpAdd)
						self._T.SleepHpAccum = self._T.SleepHpAccum - hpAdd
					end
					
					local staminaAdd = math.floor(self._T.SleepStaminaAccum)
					if staminaAdd > 0 then
						self.Stamina = math.min(self.MaxStamina, self.Stamina + staminaAdd)
						self._T.SleepStaminaAccum = self._T.SleepStaminaAccum - staminaAdd
					end
				else
					if self.Stamina < self.MaxStamina then
						local regen = math.floor(self:GetBuffedStaminaRegen() + 0.5)
						if regen < 1 then regen = 1 end
						self.Stamina = math.min(self.MaxStamina, self.Stamina + regen)
					end
				end
			end, 1.0)
		end
	end

	method void OnEndPlay()
		-- description: Clean up event listeners and local preview on client, and stamina timer on server.
		if self:IsClient() then
			if self.KeyDownHandler then
				_InputService:DisconnectEvent(KeyDownEvent, self.KeyDownHandler)
				self.KeyDownHandler = nil
			end
			if self.ScreenTouchHandler then
				_InputService:DisconnectEvent(ScreenTouchEvent, self.ScreenTouchHandler)
				self.ScreenTouchHandler = nil
			end
			local preview = self._T.PlacementPreviewEntity
			if isvalid(preview) then
				preview.Enable = false
				preview.Visible = false
				self._T.PlacementPreviewEntity = nil
			end
			log("PlayerController cleaned up on client.")
		else
			if self._T.StaminaTimer then
				_TimerService:ClearTimer(self._T.StaminaTimer)
				self._T.StaminaTimer = nil
			end
			log("PlayerController cleaned up on server.")
		end
	end

	method boolean IsWallAt(Vector2 checkPos)
		-- description: True if checkPos sits on an impassable wall — any tile on Layer 4
		-- (RectTileMap4 = the walls layer; Big Wall is IsCollidable). Tile-based, so it also blocks
		-- the knockback teleport (SetWorldPosition) path, not just normal movement.
		local map = self.Entity.CurrentMap
		if not isvalid(map) then return false end
		local mapName = map.Name
		
		-- Resolve & cache the Layer-4 wall tilemap for the current map (re-resolve while still nil,
		-- e.g. before chunk loading creates RectTileMap4). The map has many entity children from
		-- resource proximity loading, so GetChildByName every frame once cached would be costly.
		if self._T.wallLayerMapName ~= mapName or not isvalid(self._T.wallLayer) then
			self._T.wallLayerMapName = mapName
			local l4 = map:GetChildByName("RectTileMap4")
			self._T.wallLayer = (isvalid(l4) and l4.RectTileMapComponent) or nil
		end
		
		local wallLayer = self._T.wallLayer
		if isvalid(wallLayer) then
			local cell = wallLayer:ToCellPosition(Vector3(checkPos.x, checkPos.y, 0))
			if cell ~= nil and wallLayer:GetTile(cell) ~= nil then
				return true
			end
		end
		
		return false
	end

	method boolean IsObstacle(Vector2 checkPos, number radius, any currentPos)
		-- description: True if a move to checkPos should be blocked — a Layer-4 wall tile (IsWallAt),
		-- or a blocking resource/furniture whose ResourceOccupiedArea AABB the player would penetrate
		-- deeper than at currentPos. Uses the SAME AABB source as ResolveOverlaps (GetObstacleAABB) so
		-- the preventive (stop-at-surface) and corrective (push-out) layers can never disagree: the thin
		-- TriggerComponent band is only a candidate filter (kept wide via OverlapQueryRadius), never the
		-- block geometry. Blocking membership is data-driven (IsBlockingOverlapEntity) — no name branches.
		if self:IsWallAt(checkPos) then
			return true
		end
		local simulator = _CollisionService:GetSimulator(self.Entity)
		if not simulator then return false end
		-- 후보 수집은 넓은 원으로: Trigger 밴드가 얇거나(예: Big Stone 3x0.5) 아래로 오프셋돼 있어도
		-- Occupied AABB에 해당하는 후보를 놓치지 않도록 ResolveOverlaps와 동일한 질의 반경을 쓴다.
		local queryR = self.OverlapQueryRadius
		if queryR == nil or queryR < radius then queryR = 2.5 end
		local overlaps = simulator:OverlapAll(CollisionGroups.TriggerBox, CircleShape(checkPos, queryR))
		local box = { minX = 0, maxX = 0, minY = 0, maxY = 0 }
		for _, comp in ipairs(overlaps) do
			if isvalid(comp) and isvalid(comp.Entity) then
				local entity = comp.Entity
				if self:IsBlockingOverlapEntity(entity) and self:GetColliderAABB(entity, box) then
					local penNew = self:CirclePenetration(checkPos, radius, box)
					if penNew > 0 then
						-- 밀착/탈출/평행 이동은 허용하고, currentPos보다 더 깊이 파고드는 이동만 차단.
						-- (currentPos == nil인 워프 안전위치 검사에서는 겹침 자체를 장애물로 본다.)
						local penCur = 0
						if currentPos ~= nil then
							penCur = self:CirclePenetration(currentPos, radius, box)
						end
						if penNew > penCur + 0.0001 then
							return true
						end
					end
				end
			end
		end
		return false
	end

	@ExecSpace("Server")
	method void RequestInitialStones()
		-- Client request to spawn initial stones (Disabled as per user request).
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- description: Handle updates per frame.
		if self.IsSleeping then
			local movement = self.Entity.MovementComponent
			if isvalid(movement) then movement:Stop() end
			if _InputService:IsKeyPressed(KeyboardKey.LeftArrow) or
			   _InputService:IsKeyPressed(KeyboardKey.RightArrow) or
			   _InputService:IsKeyPressed(KeyboardKey.UpArrow) or
			   _InputService:IsKeyPressed(KeyboardKey.DownArrow) or
			   _InputService:IsKeyPressed(KeyboardKey.W) or
			   _InputService:IsKeyPressed(KeyboardKey.A) or
			   _InputService:IsKeyPressed(KeyboardKey.S) or
			   _InputService:IsKeyPressed(KeyboardKey.D) then
				self:ServerRequestWakeUp()
			end
			return
		end

		if self.FishingState ~= "None" then
			local movement = self.Entity.MovementComponent
			if isvalid(movement) then movement:Stop() end
			if _InputService:IsKeyPressed(KeyboardKey.LeftArrow) or
			   _InputService:IsKeyPressed(KeyboardKey.RightArrow) or
			   _InputService:IsKeyPressed(KeyboardKey.UpArrow) or
			   _InputService:IsKeyPressed(KeyboardKey.DownArrow) or
			   _InputService:IsKeyPressed(KeyboardKey.W) or
			   _InputService:IsKeyPressed(KeyboardKey.A) or
			   _InputService:IsKeyPressed(KeyboardKey.S) or
			   _InputService:IsKeyPressed(KeyboardKey.D) then
				self:ServerRequestCancelFishing()
			end
			return
		end

		-- T16: 이동속도 버프 반영
		local movementBuff = self.Entity.MovementComponent
		if isvalid(movementBuff) then
			movementBuff.InputSpeed = self:GetBuffedMoveSpeed()
		end

		-- Resolve any overlaps with resource colliders first
		self:ResolveOverlaps(delta)

		-- description: Monitor player movement inputs to track last facing direction and drive movement.
		-- Handle visual IFrame flashing (translucent blinking)
		if self.IFrameTimer > 0 then
			local avatar = self.Entity.AvatarRendererComponent
			if isvalid(avatar) then
				-- Blink visual every 0.1s
				local sec = math.floor(_UtilLogic.ElapsedSeconds * 10)
				if sec % 2 == 0 then
					avatar:SetAlpha(0.4)
				else
					avatar:SetAlpha(0.8)
				end
			end
		else
			local avatar = self.Entity.AvatarRendererComponent
			if isvalid(avatar) then
				avatar:SetAlpha(1.0)
			end
		end
		
		if self.IsDead then
			local movement = self.Entity.MovementComponent
			if isvalid(movement) then movement:Stop() end
			return
		end
		
		-- Knockback: while active, interpolate player position smoothly on client (EaseOutCubic)
		if self.KnockTimer > 0 then
			self.KnockTimer = self.KnockTimer - delta
			
			local startPos = self._T.KnockStartPos
			local targetPos = self._T.KnockTargetPos
			local duration = self._T.KnockDuration
			
			if startPos and targetPos and duration and duration > 0 then
				local progress = 1.0 - math.max(0.0, self.KnockTimer / duration)
				-- EaseOutCubic formula: f(t) = 1 - (1-t)^3
				local t = 1.0 - progress
				local ease = 1.0 - (t * t * t)
				
				local currentPos = startPos + (targetPos - startPos) * ease
				local transform = self.Entity.TransformComponent
				if isvalid(transform) then
					transform.WorldPosition = Vector3(currentPos.x, currentPos.y, transform.WorldPosition.z)
				end
			end
			
			local movement = self.Entity.MovementComponent
			if isvalid(movement) then
				movement:Stop()
			end
			return
		end
		
		local dx = 0
		local dy = 0
		
		if _InputService:IsKeyPressed(KeyboardKey.LeftArrow) then
			dx = -1
		elseif _InputService:IsKeyPressed(KeyboardKey.RightArrow) then
			dx = 1
		end
		
		if _InputService:IsKeyPressed(KeyboardKey.UpArrow) then
			dy = 1
		elseif _InputService:IsKeyPressed(KeyboardKey.DownArrow) then
			dy = -1
		end
		
		local inputDx = dx
		local inputDy = dy
		
		-- Drive movement via MovementComponent
		local movement = self.Entity.MovementComponent
		if isvalid(movement) then
			if dx ~= 0 or dy ~= 0 then
				local speed = movement.InputSpeed
				local currentPos = nil
				local body = self.Entity.KinematicbodyComponent
				if isvalid(body) then
					currentPos = body:GetWorldGroundPosition()
				else
					currentPos = self.Entity.TransformComponent.WorldPosition:ToVector2()
				end
				
				local r = 0.3
				local step = speed * delta
				
				-- Test X movement
				if dx ~= 0 then
					local testXPos = currentPos + Vector2(dx * step, 0)
					if self:IsObstacle(testXPos, r, currentPos) then
						dx = 0
					end
				end
				
				-- Test Y movement
				if dy ~= 0 then
					local testYPos = currentPos + Vector2(0, dy * step)
					if self:IsObstacle(testYPos, r, currentPos) then
						dy = 0
					end
				end
				
				if dx ~= 0 or dy ~= 0 then
					local moveDir = Vector2(dx, dy):Normalize()
					movement:MoveToDirection(moveDir, delta)
				else
					movement:Stop()
				end
			else
				movement:Stop()
			end
		end
		
		-- Aim follows the last movement input (4/8-dir target); visual facing stays horizontal via MovementComponent.
		if inputDx ~= 0 or inputDy ~= 0 then
			local newDirX = inputDx
			local newDirY = inputDy
		
			-- Send to server if direction changed
			if newDirX ~= self.LastDirectionX or newDirY ~= self.LastDirectionY then
				self.LastDirectionX = newDirX
				self.LastDirectionY = newDirY
				self:ServerSetDirection(newDirX, newDirY)
			end
		end
		
		-- Belt-and-suspenders walk animation: the engine PlayerControllerComponent normally auto-
		-- transitions MOVE/IDLE, but our custom controller drives MovementComponent directly, so its
		-- auto-transition may not always fire. Mirror MOVE/IDLE from our arrow-key input as a fallback.
		-- Guarded to only swap IDLE<->MOVE (and only when already in one of those), so it is a no-op
		-- whenever the controller already set the state and never clobbers HIT/DEAD/JUMP/ATTACK.
		if self:IsClient() then
			local stateComp = self.Entity.StateComponent
			if isvalid(stateComp) then
				local cur = stateComp.CurrentStateName
				if cur == nil or cur == "" or cur == "IDLE" or cur == "MOVE" then
					local moving = (inputDx ~= 0 or inputDy ~= 0)
					if moving and cur ~= "MOVE" then
						stateComp:ChangeState("MOVE")
					elseif not moving and cur ~= "IDLE" then
						stateComp:ChangeState("IDLE")
					end
				end
			end
		end
		
		-- Update local placement preview
		self:UpdatePlacementPreview()
	end

	@ExecSpace("Server")
	method void ServerSetDirection(integer dirX, integer dirY)
		-- description: Synchronize client facing direction to server.
		local playerComp = self.Entity.PlayerComponent
		if playerComp == nil or senderUserId ~= playerComp.UserId then
			return
		end
		
		self.LastDirectionX = dirX
		self.LastDirectionY = dirY
		log("Player facing updated on server: " .. self.LastDirectionX .. ", " .. self.LastDirectionY)
	end

	@ExecSpace("ServerOnly")
	method void ServerDie()
		if self.IsDead then return end
		self.IsDead = true
		log("Player " .. self.Entity.Name .. " has died.")
		
		-- Stop movement immediately
		local movement = self.Entity.MovementComponent
		if isvalid(movement) then movement:Stop() end
		
		-- 50% resource loss on death (only raw materials like wood, stone, copper_ore, iron_ore)
		local inv = self.Entity:GetComponent("script.PlayerInventory")
		if isvalid(inv) then
			local resources = { "wood", "stone", "copper_ore", "iron_ore" }
			for _, resName in ipairs(resources) do
				local count = inv:GetItemCount(resName)
				if count > 0 then
					local loss = math.floor(count * 0.5)
					if loss > 0 then
						inv:RemoveItem(resName, loss)
						log("Player lost " .. loss .. " " .. resName .. " on death.")
					end
				end
			end
		end
		
		-- 3s Respawn Loop
		_TimerService:SetTimerOnce(function()
			self:ServerRespawn()
		end, 3.0)
	end

	@ExecSpace("ServerOnly")
	method void ServerRespawn()
		if not self.IsDead then return end
		self.IsDead = false
		
		local playerComp = self.Entity.PlayerComponent
		if isvalid(playerComp) then
			playerComp.Hp = playerComp.MaxHp
			-- Spawn at map center (0,0)
			local defaultPos = Vector3(0, 0, 0)
			playerComp:SetWorldPosition(defaultPos)
			log("Player " .. self.Entity.Name .. " respawned at (0,0) with full HP.")
		end
	end

	@ExecSpace("Client")
	method void ClientApplyKnockback(number startX, number startY, number targetX, number targetY, number duration)
		-- Initializes the visual cubic-ease-out knockback interpolation on the client.
		self._T.KnockStartPos = Vector2(startX, startY)
		self._T.KnockTargetPos = Vector2(targetX, targetY)
		self._T.KnockDuration = duration
		self.KnockTimer = duration
		
		log("[KNOCKBACK] ClientApplyKnockback initialized: StartPos=(" .. string.format("%.2f, %.2f", startX, startY) .. "), TargetPos=(" .. string.format("%.2f, %.2f", targetX, targetY) .. "), Duration=" .. duration)
	end

	@ExecSpace("ClientOnly")
	method void TryMine()
		-- description: Attempts to trigger mining, placement, or consumable use on client-side.
		local inv = self.Entity:GetComponent("script.PlayerInventory")
		local activeItem = ""
		if isvalid(inv) then
			local slots = _HttpService:JSONDecode(inv.QuickSlotsJson) or {}
			activeItem = slots[inv.SelectedQuickSlotIndex] or ""
			-- consumable: 쿨다운/타일맵 무관 — 퀵슬롯 Ctrl로 즉시 사용
			if activeItem ~= "" then
				local baseName = inv:GetBaseItemName(activeItem)
				local ds = _DataService:GetTable("item_dataset")
				if ds ~= nil then
					local row = ds:FindRow("Name", baseName)
					if row ~= nil and row:GetItem("Category") == "consumable" then
						inv:ServerRequestUseItem(baseName)
						return
					end
				end
			end
		end

		local now = _UtilLogic.ElapsedSeconds

		local currentMap = self.Entity.CurrentMap
		if not isvalid(currentMap) then return end
		local tilemap = currentMap:GetFirstChildComponentByTypeName("RectTileMapComponent")
		if not isvalid(tilemap) then return end
		local playerCell = tilemap:ToCellPosition(self.Entity.TransformComponent.WorldPosition)
		if playerCell == nil then return end
		local targetCell = Vector2Int(playerCell.x + self.LastDirectionX, playerCell.y + self.LastDirectionY)

		local isPlaceable = false
		local terrainAction = ""
		local isTerrainTool = false
		local terrainCooldown = 0
		if isvalid(inv) and activeItem ~= "" then
			local baseName = inv:GetBaseItemName(activeItem)
			local ds = _DataService:GetTable("item_dataset")
			if ds ~= nil then
				local row = ds:FindRow("Name", baseName)
				if row ~= nil then
					local ok, v = pcall(function() return row:GetItem("TerrainEditAction") end)
					if ok and v ~= nil then terrainAction = v end
					if row:GetItem("Category") == "furniture" then
						isPlaceable = true
					end
					if terrainAction ~= nil and terrainAction ~= "" then
						isTerrainTool = row:GetItem("Category") == "tool"
						-- T61: 지형 편집 전용 쿨다운(TerrainEditCooldown 컬럼) — 공란이면 채집 쿨다운 폴백
						local okCd, rawCd = pcall(function() return row:GetItem("TerrainEditCooldown") end)
						if okCd and rawCd ~= nil and tostring(rawCd) ~= "" then
							terrainCooldown = tonumber(rawCd) or 0
						end
					end
				end
			end
		end

		local cooldown = self:GetEffectiveMineCooldown()
		if terrainAction ~= nil and terrainAction ~= "" and terrainCooldown > 0 then
			cooldown = terrainCooldown
		end
		if now - self.LastMineTime < cooldown then
			return
		end
		self.LastMineTime = now

		if terrainAction ~= nil and terrainAction ~= "" then
			if isTerrainTool then
				local state = self.Entity.StateComponent
				if isvalid(state) then
					state:ChangeState("MINE")
				end
			end
			inv:ServerRequestTerrainEdit(activeItem, targetCell.x, targetCell.y, self.LastDirectionX, self.LastDirectionY)
			return
		end

		if isPlaceable then
			log("[PLACE] Requesting placement of " .. activeItem .. " at cell (" .. targetCell.x .. ", " .. targetCell.y .. ")")
			inv:ServerRequestPlace(activeItem, targetCell.x, targetCell.y)
			return
		end
		
		local state = self.Entity.StateComponent
		if isvalid(state) then
			state:ChangeState("MINE")
		end
		
		local myPos = self.Entity.TransformComponent.WorldPosition
		self:RequestMine(myPos, targetCell.x, targetCell.y)
	end

	@ExecSpace("ClientOnly")
	method void OnKeyDown(KeyDownEvent event)
		-- description: Handle keyboard input events on client.
		if self.IsSleeping then
			self:ServerRequestWakeUp()
			return
		end
		
		local key = event.key
		
		if key == KeyboardKey.LeftControl or key == KeyboardKey.RightControl then
			self:TryMine()
		elseif key == KeyboardKey.LeftAlt or key == KeyboardKey.RightAlt then
			log("Visual Jump key (Alt) pressed.")
			local movement = self.Entity.MovementComponent
			if isvalid(movement) then
				movement:Jump()
			end
		elseif key == KeyboardKey.Space then
			local popup = _EntityService:GetEntityByPath("/ui/PopupGroup/CraftingPopup")
			if isvalid(popup) and popup.Enable then
				local controller = popup:GetComponent("script.UICraftingController")
				if isvalid(controller) then
					controller:TryCraft()
				end
			end
		elseif key == KeyboardKey.I then
			local popup = _EntityService:GetEntityByPath("/ui/PopupGroup/InventoryPopup")
			if isvalid(popup) then
				local controller = popup:GetComponent("script.UIInventoryController")
				if isvalid(controller) then
					controller:Toggle()
				end
			end
		elseif key == KeyboardKey.C then
			local popup = _EntityService:GetEntityByPath("/ui/PopupGroup/CraftingPopup")
			if isvalid(popup) then
				local controller = popup:GetComponent("script.UICraftingController")
				if isvalid(controller) then
					controller:Toggle()
				end
			end
		elseif key == KeyboardKey.H then
			-- Character info popup. Moved from E to H to free E for skill slot 3. (Phase 13 #2)
			local popup = _EntityService:GetEntityByPath("/ui/PopupGroup/CharacterPopup")
			if isvalid(popup) then
				local controller = popup:GetComponent("script.UICharacterController")
				if isvalid(controller) then
					controller:Toggle()
				end
			end
		elseif key == KeyboardKey.Q then
			self:TryCastSlot(1)
		elseif key == KeyboardKey.W then
			self:TryCastSlot(2)
		elseif key == KeyboardKey.E then
			self:TryCastSlot(3)
		elseif key == KeyboardKey.R then
			self:TryCastSlot(4)
		elseif key == KeyboardKey.K then
			-- 스킬트리 팝업 토글 (S3)
			local popup = _EntityService:GetEntityByPath("/ui/PopupGroup/SkillTreePopup")
			if isvalid(popup) then
				local controller = popup:GetComponent("script.UISkillTreeController")
				if isvalid(controller) then
					---@type UISkillTreeController
					local c = controller
					c:Toggle()
				end
			end
		elseif key == KeyboardKey.J then
			-- T22: 도감 팝업 토글 (아이템/몬스터/업적)
			local popup = _EntityService:GetEntityByPath("/ui/PopupGroup/CollectionPopup")
			if not isvalid(popup) then
				log_warning("[DEX] J key: CollectionPopup missing")
				return
			end
			---@type UICollectionController
			local controller = popup:GetComponent("script.UICollectionController")
			if isvalid(controller) then
				controller:Toggle()
			else
				log_warning("[DEX] J key: UICollectionController missing")
			end
		elseif key == KeyboardKey.F then
			-- T59: F 본문은 TryInteract로 추출(로직 변경 없음). 분산 핸들러는 기존 KeyDown 동시 리슨 유지.
			self:TryInteract()
		else
			-- Numeric Keys (1 to 0)
			local slotIndex = 0
			if key == KeyboardKey.Alpha1 then slotIndex = 1
			elseif key == KeyboardKey.Alpha2 then slotIndex = 2
			elseif key == KeyboardKey.Alpha3 then slotIndex = 3
			elseif key == KeyboardKey.Alpha4 then slotIndex = 4
			elseif key == KeyboardKey.Alpha5 then slotIndex = 5
			elseif key == KeyboardKey.Alpha6 then slotIndex = 6
			elseif key == KeyboardKey.Alpha7 then slotIndex = 7
			elseif key == KeyboardKey.Alpha8 then slotIndex = 8
			elseif key == KeyboardKey.Alpha9 then slotIndex = 9
			elseif key == KeyboardKey.Alpha0 then slotIndex = 10
			end
		
			if slotIndex > 0 then
				local pinv = self.Entity:GetComponent("script.PlayerInventory")
				if isvalid(pinv) then
					pinv:ServerSelectQuickSlot(slotIndex)
				end
			end
		end
	end

	@ExecSpace("ClientOnly")
	method Entity FindNearbyFurnace()
		-- description: Finds the closest furnace entity within interaction distance on the client.
		local currentMap = self.Entity.CurrentMap
		if not isvalid(currentMap) then return nil end
		
		local myPos = self.Entity.TransformComponent.WorldPosition:ToVector2()
		local closest = nil
		local minDist = 1.5 -- Interaction distance (1.5 grid cells)
		
		local furnaceComponents = currentMap:GetChildComponentsByTypeName("script.Furnace", true)
		if not furnaceComponents then return nil end
		
		for _, comp in ipairs(furnaceComponents) do
			if isvalid(comp) then
				local ent = comp.Entity
				if isvalid(ent) then
					local fPos = ent.TransformComponent.WorldPosition:ToVector2()
					local dist = (myPos - fPos):Magnitude()
					if dist < minDist then
						minDist = dist
						closest = ent
					end
				end
			end
		end
		
		return closest
	end

	@ExecSpace("ClientOnly")
	method Entity FindNearbyChest()
		-- description: Finds the closest chest entity within interaction distance on the client.
		local currentMap = self.Entity.CurrentMap
		if not isvalid(currentMap) then return nil end
		
		local myPos = self.Entity.TransformComponent.WorldPosition:ToVector2()
		local closest = nil
		local minDist = 1.5 -- Interaction distance (1.5 grid cells)
		
		local chestComponents = currentMap:GetChildComponentsByTypeName("script.Chest", true)
		if not chestComponents then return nil end
		
		for _, comp in ipairs(chestComponents) do
			if isvalid(comp) then
				local ent = comp.Entity
				if isvalid(ent) then
					local fPos = ent.TransformComponent.WorldPosition:ToVector2()
					local dist = (myPos - fPos):Magnitude()
					if dist < minDist then
						minDist = dist
						closest = ent
					end
				end
			end
		end
		
		return closest
	end

	@ExecSpace("Client")
	method void ClientPlayMineEffect(boolean hitSuccess, Entity targetEntity)
		-- description: Play attack or hit effect on clients (Disabled).
	end

	@ExecSpace("Client")
	method void ShowMineFeedback(string message)
		-- description: Show gathering feedback as a screen popup message.
		_ScreenMessageLogic:PrivateMsg(message)
		log("[Gather] " .. message)
	end

	@ExecSpace("Server")
	method void RequestMine(Vector3 playerWorldPos, integer targetCellX, integer targetCellY)
		-- description: Execute mining verification and execution on the server.
		local playerComp = self.Entity.PlayerComponent
		if playerComp == nil or senderUserId ~= playerComp.UserId then
			return
		end
		
		local now = _UtilLogic.ServerElapsedSeconds
		if now - self.LastMineTime < self:GetEffectiveMineCooldown() - 0.1 then
			return
		end
		self.LastMineTime = now
		
		local currentMap = self.Entity.CurrentMap
		if not isvalid(currentMap) then
			log_warning("Player is not on a valid map.")
			return
		end
		
		---@type RectTileMapComponent
		local tilemap = currentMap:GetFirstChildComponentByTypeName("RectTileMapComponent", true)
		if not isvalid(tilemap) then
			log_warning("Target map does not contain a RectTileMapComponent.")
			return
		end
		
		-- Validate range to prevent exploitation
		local cellPos = tilemap:ToCellPosition(playerWorldPos)
		if cellPos == nil then return end
		local dist = math.max(math.abs(cellPos.x - targetCellX), math.abs(cellPos.y - targetCellY))
		if dist > 2 then
			log_warning("Player " .. self.Entity.Name .. " attempted to mine too far: dist " .. dist)
			return
		end
		
		-- Locate cell targeted by client
		local targetCell = Vector2Int(targetCellX, targetCellY)
		
		-- Combat: if a monster occupies the aimed cell, attack it instead of mining.
		local targetWorldPos = tilemap:ToWorldPosition(targetCell)
		local monsterEntity = self:FindMonsterAt(currentMap, targetWorldPos)
		if isvalid(monsterEntity) then
			local combat = self.Entity:GetComponent("script.PlayerCombat")
			if isvalid(combat) then
				---@type PlayerCombat
				local pc = combat
				pc:DoAttackAt(Vector2(targetWorldPos.x, targetWorldPos.y))
			end
			self:ClientPlayMineEffect(true, monsterEntity)
			return
		end
		
		-- Query the spawned resource entity occupying the target cell (entity-only mining)
		local key = math.floor(targetCell.x) .. "_" .. math.floor(targetCell.y)
		local resourceSpawner = _ResourceSpawner
		local pivotKey = nil
		---@type Entity
		local targetEntity = nil
		
		local gridToEntity = resourceSpawner and resourceSpawner:GetGridToEntity(currentMap.Name)
		if gridToEntity then
			local gridData = gridToEntity[key]
			if gridData and (gridData.isTile or isvalid(gridData.entity)) then
				pivotKey = math.floor(gridData.pivotX) .. "_" .. math.floor(gridData.pivotY)
				targetEntity = gridData.entity
			end
		end
		
		if pivotKey ~= nil then
		
			-- Play hit effect on all clients (attached to target resource entity)
			self:ClientPlayMineEffect(true, targetEntity)
		
			-- Report the hit to the durability manager using the entity's pivot key
			_TileDurabilityManager:HitResource(currentMap, pivotKey, self.Entity)
		else
			-- Play air swing effect on all clients (attached to player)
			self:ClientPlayMineEffect(false, nil)
			log("No resource entity found at target cell " .. tostring(targetCell))
		end
	end

	@ExecSpace("ServerOnly")
	method Entity FindMonsterAt(Entity map, Vector3 worldPos)
		-- Returns a living monster entity whose center is within ~1 cell of worldPos, or nil.
		if not isvalid(map) then return nil end
		local monsters = map:GetChildComponentsByTypeName("script.Monster", false)
		if monsters == nil then return nil end
		for i, mc in ipairs(monsters) do
			if isvalid(mc) and isvalid(mc.Entity) then
				---@type Monster
				local mon = mc
				if not mon.IsDead then
					local p = mc.Entity.TransformComponent.WorldPosition
					local dx = p.x - worldPos.x
					local dy = p.y - worldPos.y
					if dx * dx + dy * dy <= 0.81 then return mc.Entity end
				end
			end
		end
		return nil
	end

	@ExecSpace("Server")
	method void AddXP(integer amount)
		self.XP = self.XP + amount
		local leveledUp = false
		while self.XP >= self.MaxXP do
			self.Level = self.Level + 1
			self.XP = self.XP - self.MaxXP
			self.MaxXP = math.floor(self.MaxXP * 1.5)
			self.MaxStamina = self.MaxStamina + 10
			self.Stamina = self.MaxStamina
			self.GatheringSpeed = self.GatheringSpeed + 0.2
			self.SP = self.SP + self.SPPerLevelUp
			leveledUp = true
			
			self:ShowMineFeedback("LEVEL UP! Level " .. self.Level .. " (SP +" .. self.SPPerLevelUp .. ")")
		end
		if leveledUp and _PersistenceManager then
			local playerComp = self.Entity.PlayerComponent
			if playerComp then
				_PersistenceManager:MarkPlayerDirty(playerComp.UserId)
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void UpdatePlacementPreview()
		-- description: Updates the local placement preview entity when holding placeable furniture or tiles.
		if self.Entity ~= _UserService.LocalPlayer then return end
		
		local inv = self.Entity:GetComponent("script.PlayerInventory")
		if not isvalid(inv) then return end
		
		local slots = _HttpService:JSONDecode(inv.QuickSlotsJson) or {}
		local activeItem = slots[inv.SelectedQuickSlotIndex] or ""
		-- log("[PREVIEW] Active Item: " .. activeItem .. " Slot: " .. inv.SelectedQuickSlotIndex)
		
		local isPlaceable = false
		local iconRuid = ""
		local placedTileName = ""
		local previewRuid = ""
		
		if activeItem ~= "" then
			local baseName = inv:GetBaseItemName(activeItem)
			local ds = _DataService:GetTable("item_dataset")
			if ds ~= nil then
				local row = ds:FindRow("Name", baseName)
				if row ~= nil and row:GetItem("Category") == "furniture" then
					isPlaceable = true
					iconRuid = row:GetItem("IconRUID") or ""
					placedTileName = row:GetItem("PlacedTileName") or ""
					previewRuid = row:GetItem("PreviewRUID") or ""
				end
			end
		end
		
		if isPlaceable then
			local tilemap = self.Entity.CurrentMap:GetFirstChildComponentByTypeName("RectTileMapComponent")
			if isvalid(tilemap) then
				local playerWorldPos = self.Entity.TransformComponent.WorldPosition
				local playerCell = tilemap:ToCellPosition(playerWorldPos)
				if playerCell == nil then return end
				local targetCell = Vector2Int(playerCell.x + self.LastDirectionX, playerCell.y + self.LastDirectionY)
				local cellWorldPos = Vector3(targetCell.x + 0.5, targetCell.y + 0.5, 0)
				
				local preview = self._T.PlacementPreviewEntity
				if not isvalid(preview) then
					preview = self.Entity.CurrentMap:GetChildByName("PlacementPreview")
					self._T.PlacementPreviewEntity = preview
				end
				
				if isvalid(preview) then
					preview.Enable = true
					preview.Visible = true
					preview.TransformComponent.Scale = Vector3(1.0, 1.0, 1.0)
					
					local sprite = preview.SpriteRendererComponent
					if isvalid(sprite) then
						local spriteRuid = iconRuid
						if placedTileName == "" then
							if previewRuid ~= "" then
								spriteRuid = previewRuid
							end
						end
						if sprite.SpriteRUID ~= spriteRuid then
							sprite.SpriteRUID = spriteRuid
							self._T.LastActiveItem = activeItem
						end
					end
				end
				
				preview = self._T.PlacementPreviewEntity
				if isvalid(preview) then
					preview.TransformComponent.WorldPosition = cellWorldPos
					
					local canPlace = true
					-- Client-side occupancy check using collision simulator
					local simulator = _CollisionService:GetSimulator(self.Entity)
					if simulator then
						-- Use a slightly larger shape to ensure we catch nearby obstacles
						local checkShape = BoxShape(Vector2(targetCell.x + 0.5, targetCell.y + 0.5), Vector2(0.9, 0.9), 0)
						-- Check all relevant collision groups
						local groups = { CollisionGroups.Default, CollisionGroups.TriggerBox, CollisionGroups.HitBox }
						local overlaps = simulator:OverlapAll(groups, checkShape)
						
						for _, comp in ipairs(overlaps) do
							if isvalid(comp) and isvalid(comp.Entity) then
								local ent = comp.Entity
								-- Block if there's any entity except self, the preview itself, or temporary item drops
								if ent ~= self.Entity and ent.Name ~= "PlacementPreview" and ent.Name ~= "ItemDrop" then
									canPlace = false
									break
								end
							end
						end
					end
					if canPlace then
						if not self.CanPlaceOnCurrentMap then
							canPlace = false
						end
					end
					
					if canPlace then
						local currentMap = self.Entity.CurrentMap
						local layer1 = currentMap:GetChildByName("RectTileMap")
						local layer2 = currentMap:GetChildByName("RectTileMap2")
						local hasBase = false
						if isvalid(layer1) and isvalid(layer1.RectTileMapComponent) then
							if layer1.RectTileMapComponent:GetTile(targetCell) ~= nil then hasBase = true end
						end
						if isvalid(layer2) and isvalid(layer2.RectTileMapComponent) then
							if layer2.RectTileMapComponent:GetTile(targetCell) ~= nil then hasBase = true end
						end
						if not hasBase then 
							canPlace = false 
						end
					end
					
					local sprite = preview.SpriteRendererComponent
					if isvalid(sprite) then
						if canPlace then
							sprite.Color = Color(0.2, 1.0, 0.2, 0.6)
						else
							sprite.Color = Color(1.0, 0.2, 0.2, 0.6)
						end
						local mapRadius = 75
						if _ResourceSpawner then mapRadius = _ResourceSpawner.MapRadius end
						sprite.OrderInLayer = math.floor((mapRadius - targetCell.y) * 100) + 1
					end
				end
			end
		else
				-- Mining mode (tool / bare-hand / empty slot): show the mining target-cell reticle.
				self:UpdateMineReticle()
		end
	end

	@ExecSpace("ClientOnly")
	method void UpdateMineReticle()
		-- Highlights the cell the next Ctrl mine will hit (aim = LastDirection*), reusing the
		-- PlacementPreview entity. Mutually exclusive with the furniture placement preview.
		local currentMap = self.Entity.CurrentMap
		if not isvalid(currentMap) then return end
		local tilemap = currentMap:GetFirstChildComponentByTypeName("RectTileMapComponent")
		if not isvalid(tilemap) then return end
		
		local playerCell = tilemap:ToCellPosition(self.Entity.TransformComponent.WorldPosition)
		if playerCell == nil then return end
		local targetCell = Vector2Int(playerCell.x + self.LastDirectionX, playerCell.y + self.LastDirectionY)
		local cellWorldPos = Vector3(targetCell.x + 0.5, targetCell.y + 0.5, 0)
		
		local preview = self._T.PlacementPreviewEntity
		if not isvalid(preview) then
			preview = currentMap:GetChildByName("PlacementPreview")
			self._T.PlacementPreviewEntity = preview
		end
		if not isvalid(preview) then return end
		
		preview.Enable = true
		preview.Visible = true
		preview.TransformComponent.WorldPosition = cellWorldPos
		preview.TransformComponent.Scale = Vector3(self.ReticleScale, self.ReticleScale, 1.0)
		
		local sprite = preview.SpriteRendererComponent
		if isvalid(sprite) then
			-- Swap to the reticle sprite once when entering mining mode.
			if sprite.SpriteRUID ~= self.ReticleSpriteRUID then
				sprite.SpriteRUID = self.ReticleSpriteRUID
				self._T.LastActiveItem = "__mine__"
			end
			sprite.Color = Color(1, 1, 1, 0.85)
			local mapRadius = 75
			if _ResourceSpawner then mapRadius = _ResourceSpawner.MapRadius end
			sprite.OrderInLayer = math.floor((mapRadius - targetCell.y) * 100) + 1
		end
	end

	@ExecSpace("ClientOnly")
	method boolean TryInteract()
		-- T59: F/BtnInteract 공통 상호작용 본문 (KeyDown F에서 이동 — 로직 변경 금지).
		if self.FishingState ~= "None" and isvalid(self.ActiveFishingSpot) then
			self:ServerRequestFishingInteract(self.ActiveFishingSpot.Id)
			return true
		end
		-- 보물 상자: 포탈보다 우선 (홈 포탈 옆 스폰 시 F가 워프로만 먹히던 문제)
		local nearbyTreasure = self:FindNearbyTreasureChest()
		if isvalid(nearbyTreasure) then
			local tc = nearbyTreasure:GetComponent("script.TreasureChest")
			if not isvalid(tc) then tc = nearbyTreasure:GetComponent("TreasureChest") end
			if isvalid(tc) then
				if tc.IsOpened then
					self:ShowMineFeedback("이미 열어본 상자입니다.")
				else
					tc:ServerRequestOpen()
				end
				return true
			end
		end
		if isvalid(self.ActivePortal) then
			-- Estate portals open the destination list (town / hunting grounds); fixed portals in
			-- other maps warp straight to their single target. See TryUsePortal.
			self:TryUsePortal()
			return true
		end
		local nearbyBed = self:FindNearbyBed()
		if isvalid(nearbyBed) then
			self:ServerRequestSleep(nearbyBed.Id)
			return true
		end
		local nearbyFurnace = self:FindNearbyFurnace()
		if isvalid(nearbyFurnace) then
			local popup = _EntityService:GetEntityByPath("/ui/PopupGroup/FurnacePopup")
			if isvalid(popup) then
				local controller = popup:GetComponent("script.UIFurnaceController")
				if isvalid(controller) then
					local c = controller
					if popup.Enable then
						c:Close()
					else
						c:Open(nearbyFurnace)
					end
				end
			end
			return true
		end

		local nearbyChest = self:FindNearbyChest()
		if isvalid(nearbyChest) then
			local popup = _EntityService:GetEntityByPath("/ui/PopupGroup/ChestPopup")
			if isvalid(popup) then
				local controller = popup:GetComponent("script.UIChestController")
				if isvalid(controller) then
					local c = controller
					if popup.Enable then
						c:Close()
					else
						c:Open(nearbyChest)
					end
				end
			end
			return true
		end

		local nearbyFishingSpot = self:FindNearbyFishingSpot()
		if isvalid(nearbyFishingSpot) then
			self:ServerRequestFishingInteract(nearbyFishingSpot.Id)
			return true
		end
		return false
	end

	@ExecSpace("ClientOnly")
	method void OnInteractButton()
		-- T59: BtnInteract = TryInteract + 미처리 시 InteractRequestEvent(분산 핸들러 브리지).
		if self:TryInteract() then
			return
		end
		local evt = InteractRequestEvent()
		self.Entity:SendEvent(evt)
		log("[T59] InteractRequestEvent sent (no PC-owned target)")
	end

	@ExecSpace("ClientOnly")
	method void OnScreenTouch(ScreenTouchEvent event)
		-- description: Handles screen touch and mouse clicks. Placement logic has been removed as it is now tool-driven.
		if event.TouchId ~= 1 then return end
		if _InputService:IsPointerOverUI() then return end
		
		-- Optionally, could add interaction logic here in the future
	end

	@ExecSpace("Server")
	method void ServerRequestWarp()
		local playerComp = self.Entity.PlayerComponent
		if playerComp == nil or senderUserId ~= playerComp.UserId then
			return
		end
		if not isvalid(self.ActivePortal) then return end
		
		-- Automatically unlock waypoint of current hunting ground map on returning to home/warp
		local currentMap = self.Entity.CurrentMap
		if isvalid(currentMap) then
			local ds = _DataService:GetTable("PortalDestinationDataSet")
			if ds then
				local rowCount = ds:GetRowCount()
				for i = 1, rowCount do
					local mapName = ds:GetCell(i, "MapName")
					local destId = ds:GetCell(i, "DestinationId")
					local displayName = ds:GetCell(i, "DisplayName")
					local unlockType = ds:GetCell(i, "UnlockType")
					if mapName == currentMap.Name and unlockType == "waypoint" then
						self:UnlockWaypoint(destId, displayName)
						break
					end
				end
			end
		end
		
		local portalGate = self.ActivePortal:GetComponent("script.PortalGate")
		local territoryPortal = self.ActivePortal:GetComponent("script.TerritoryPortal")
		
		if isvalid(portalGate) then
			local targetMap = portalGate.TargetMapName
			if targetMap == "Home" then
				targetMap = "Home_" .. playerComp.UserId
			end
			
			local targetPos = portalGate.TargetPosition
			playerComp:MoveToMapPosition(targetMap, targetPos)
			log("PlayerController: Warped player " .. playerComp.UserId .. " to " .. targetMap .. " at " .. tostring(targetPos))

			-- 업적/퀘스트 진행: 포탈 이동 액션 발행
			if _ActionSignals ~= nil then
				_ActionSignals:EmitToPlayer(self.Entity, _ActionEnum.Warp, targetMap, 1)
			end
		elseif isvalid(territoryPortal) then
			local subIndex = territoryPortal.SubTerritoryIndex
			local ownerId = playerComp.UserId
			local currentMap = self.Entity.CurrentMap
			if isvalid(currentMap) then
				if string.sub(currentMap.Name, 1, 5) == "Home_" then
					ownerId = string.sub(currentMap.Name, 6)
					local p1, _ = string.find(ownerId, "_Sub_")
					if p1 then
						ownerId = string.sub(ownerId, 1, p1 - 1)
					end
				end
			end
			
			if _PersistenceManager then
				_PersistenceManager:LoadSubTerritoryMap(ownerId, subIndex)
			end
			
			local targetMap = "Home_" .. ownerId .. "_Sub_" .. subIndex
			playerComp:MoveToMapPosition(targetMap, Vector2(-3, 0))
			log("PlayerController: Warped player " .. playerComp.UserId .. " to sub-territory " .. targetMap)
		end
	end

	@ExecSpace("ClientOnly")
	method void TryUsePortal()
		-- Portals placed on estate (Home_*) maps are universal: they always open the full,
		-- grouped destination list popup, regardless of any TargetMapName/DestinationGroup values
		-- the PortalGate may carry (C-1 design; also means old saves need no group migration).
		-- Fixed portals on non-estate maps (town/hunt) keep their immediate warp behavior.
		if not isvalid(self.ActivePortal) then return end
		local currentMap = self.Entity.CurrentMap

		local portalGate = self.ActivePortal:GetComponent("script.PortalGate")
		if isvalid(portalGate) and isvalid(currentMap) and string.sub(currentMap.Name, 1, 5) == "Home_" then
			local popup = _EntityService:GetEntityByPath("/ui/PopupGroup/WarpPopup")
			if isvalid(popup) then
				local ctrl = popup:GetComponent("script.UIWarpController")
				if isvalid(ctrl) then
					---@type UIWarpController
					local warpCtrl = ctrl
					warpCtrl:Open()
				end
			end
		else
			self:ServerRequestWarp()
		end
	end

	@ExecSpace("Server")
	method boolean UnlockWaypoint(string waypointId, string displayName)
		if not waypointId or waypointId == "" then return false end
		
		local currentList = {}
		local ok, decoded = pcall(function() return _HttpService:JSONDecode(self.UnlockedWaypointsJson) end)
		if ok and decoded then
			currentList = decoded
		end
		
		for _, id in ipairs(currentList) do
			if id == waypointId then
				return false
			end
		end
		
		table.insert(currentList, waypointId)
		self.UnlockedWaypointsJson = _HttpService:JSONEncode(currentList)
		
		local feedbackMsg = "[활성화] " .. (displayName or waypointId) .. " 웨이포인트를 활성화했습니다!"
		self:ClientShowMineFeedback(feedbackMsg)
		
		local playerComp = self.Entity.PlayerComponent
		if playerComp and _PersistenceManager then
			_PersistenceManager:MarkPlayerDirty(playerComp.UserId)
		end
		return true
	end

	method boolean IsWaypointUnlocked(string waypointId)
		if not waypointId or waypointId == "" then return true end
		
		local currentList = {}
		local ok, decoded = pcall(function() return _HttpService:JSONDecode(self.UnlockedWaypointsJson) end)
		if ok and decoded then
			currentList = decoded
		end
		
		for _, id in ipairs(currentList) do
			if id == waypointId then
				return true
			end
		end
		return false
	end

	@ExecSpace("Server")
	method void ServerRequestWarpTo(string mapName, number arriveX, number arriveY)
		-- Server-validated warp to a destination chosen in the estate list portal. Only maps present
		-- in PortalDestinationDataSet are allowed (no arbitrary map jumps from a spoofed client).
		local playerComp = self.Entity.PlayerComponent
		if playerComp == nil or senderUserId ~= playerComp.UserId then return end
		
		local ds = _DataService:GetTable("PortalDestinationDataSet")
		if ds == nil then return end
		local row = ds:FindRow("MapName", mapName)
		if row == nil then
			log_warning("PlayerController: Rejected warp to unknown destination '" .. mapName .. "'.")
			return
		end
		
		local unlockType = row:GetItem("UnlockType") or "always"
		if unlockType == "waypoint" then
			local destId = row:GetItem("DestinationId")
			if not self:IsWaypointUnlocked(destId) then
				log_warning("PlayerController: Rejected warp to locked waypoint destination '" .. destId .. "'.")
				return
			end
		end
		
		local target = mapName
		if target == "Home" then
			target = "Home_" .. playerComp.UserId
		end
		playerComp:MoveToMapPosition(target, Vector2(arriveX, arriveY))
		log("PlayerController: List-warped " .. playerComp.UserId .. " to " .. target)
		-- 업적/퀘스트 진행: 포탈 이동 액션 발행
		if _ActionSignals ~= nil then
			_ActionSignals:EmitToPlayer(self.Entity, _ActionEnum.Warp, target, 1)
		end
	end

	@ExecSpace("Client")
	method void ClientHideSpawnFade()
		-- Server tells this client its home is ready: fade out the black spawn cover.
		local hudGroup = _EntityService:GetEntityByPath("/ui/HUDGroup")
		if not isvalid(hudGroup) then return end
		local ctrl = hudGroup:GetComponent("script.UIHUDController")
		if not isvalid(ctrl) then
			ctrl = hudGroup:GetFirstChildComponentByTypeName("script.UIHUDController", true)
		end
		if isvalid(ctrl) then
			---@type UIHUDController
			local c = ctrl
			c:FadeOutSpawn()
		end
	end

	@ExecSpace("Server")
	method void ServerRequestOpenPermissionSettings()
		local userId = senderUserId
		if userId == nil or userId == "" then userId = self.Entity.PlayerComponent.UserId end
		local currentMap = self.Entity.CurrentMap
		if not isvalid(currentMap) or string.sub(currentMap.Name, 1, 5) ~= "Home_" then return end
		local ownerId = string.sub(currentMap.Name, 6)
		if userId ~= ownerId then return end
		
		local mapComp = currentMap.MapComponent
		if not isvalid(mapComp) then return end
		
		local users = _UserService:GetUsersByMapComponent(mapComp)
		local guestData = {}
		
		if users then
			for _, user in ipairs(users) do
				if isvalid(user) and user.PlayerComponent then
					local guestId = user.PlayerComponent.UserId
					if guestId ~= ownerId then
						local hasPerm = false
						if _PersistenceManager then
							hasPerm = _PersistenceManager:CheckGuestPermission(ownerId, guestId, "place")
						end
						table.insert(guestData, {
							UserId = guestId,
							Name = user.Name,
							HasPermission = hasPerm
						})
					end
				end
			end
		end
		
		local jsonStr = _HttpService:JSONEncode(guestData)
		self:ClientOpenPermissionSettings(jsonStr)
	end

	@ExecSpace("Server")
	method void ServerRequestTogglePermission(string guestUserId)
		local userId = senderUserId
		if userId == nil or userId == "" then userId = self.Entity.PlayerComponent.UserId end
		local currentMap = self.Entity.CurrentMap
		if not isvalid(currentMap) or string.sub(currentMap.Name, 1, 5) ~= "Home_" then return end
		local ownerId = string.sub(currentMap.Name, 6)
		if userId ~= ownerId then return end
		
		if _PersistenceManager then
			_PersistenceManager:ServerRequestTogglePermission(ownerId, guestUserId)
			-- Refresh settings panel for owner
			self:ServerRequestOpenPermissionSettings()
		end
	end

	@ExecSpace("Server")
	method void ServerRequestVisitHome(string targetPlayerName)
		local playerComp = self.Entity.PlayerComponent
		if playerComp == nil or senderUserId ~= playerComp.UserId then
			return
		end
		
		-- Look up target player (online only)
		local targetUserId = nil
		for _, user in pairs(_UserService.UserEntities) do
			if string.lower(user.Name) == string.lower(targetPlayerName) then
				targetUserId = user.PlayerComponent.UserId
				break
			end
		end
		
		if targetUserId == nil then
			self:ClientShowWarpFeedback("해당 유저가 오프라인이거나 존재하지 않습니다.")
			return
		end
		
		local mapName = "Home_" .. targetUserId
		local map = _EntityService:GetEntityByPath("/maps/" .. mapName)
		if isvalid(map) then
			playerComp:MoveToMapPosition(mapName, Vector2(-3, 0))
			self:ClientShowWarpFeedback(targetPlayerName .. "님의 영지에 입장했습니다.")
		else
			self:ClientShowWarpFeedback("해당 유저가 오프라인이거나 영지가 열려있지 않습니다.")
		end
	end

	@ExecSpace("Client")
	method void ClientOpenPermissionSettings(string jsonStr)
		local popup = _EntityService:GetEntityByPath("/ui/PopupGroup/PermissionPopup")
		if isvalid(popup) then
			local ctrl = popup:GetComponent("script.UIPermissionController")
			if isvalid(ctrl) then
				ctrl:UpdatePermissionUI(jsonStr)
			end
		end
	end

	@ExecSpace("Client")
	method void ClientShowWarpFeedback(string message)
		_ScreenMessageLogic:PrivateMsg(message)
	end

	@ExecSpace("Client")
	method void ClientShowMineFeedback(string message)
		_ScreenMessageLogic:PrivateMsg(message)
	end

	@ExecSpace("Client")
	method void ClientSetCurrentMapPermissions(boolean canMine, boolean canPlace, boolean canInteract)
		self.CanMineOnCurrentMap = canMine
		self.CanPlaceOnCurrentMap = canPlace
		self.CanInteractOnCurrentMap = canInteract
		log("Permissions synced: mine=" .. tostring(canMine) .. ", place=" .. tostring(canPlace) .. ", interact=" .. tostring(canInteract))
	end

	-- T36: 이전 프레임 ResolveOverlaps 후 위치 (터널링 시 진입 면 판정용)
	property number OverlapSafeX = 0
	property number OverlapSafeY = 0
	property boolean OverlapSafeInit = false
	-- T36 재작업: 후보 수집 질의 반경 (해소 AABB와 분리 — 트리거 크기 의존 제거)
	property number OverlapQueryRadius = 2.5

	-- @ExecSpace 미지정: 클라 ResolveOverlaps와 서버 ExecuteDashSkill→IsObstacle 양쪽에서 호출되므로
	-- 호출자 측에서 실행되도록 둔다(순수 컴포넌트 조회, side-effect 없음).
	method boolean IsBlockingOverlapEntity(Entity entity)
		-- 데이터 주도 필터: 이름 분기 금지.
		-- 차단 = ResourceOccupiedArea 또는 PlaceableFurniture (각 BlocksMovement).
		if not isvalid(entity) or entity == self.Entity then return false end
		if isvalid(entity:GetComponent("script.itemreact")) then return false end
		local occ = entity:GetComponent("script.ResourceOccupiedArea")
		if isvalid(occ) then
			return occ.BlocksMovement ~= false
		end
		local furn = entity:GetComponent("script.PlaceableFurniture")
		if isvalid(furn) then
			return furn.BlocksMovement ~= false
		end
		return false
	end

	-- @ExecSpace 미지정: IsObstacle(서버 대시 포함)/ResolveOverlaps 공용. 순수 조회+산식.
	method boolean GetColliderAABB(Entity entity, table outBox)
		-- 이동 충돌의 기준 = 각 모델에 손으로 튜닝해 둔 실제 충돌 박스(TriggerComponent, 없으면
		-- PhysicsColliderComponent)를 월드 AABB로 변환한 것. ResourceOccupiedArea(스폰/채집 점유용,
		-- 더 넓음)가 아니라 이 박스를 써야 "사용자가 세팅한 범위"만큼만 막힌다. 감지(IsObstacle)와
		-- 밀어내기(ResolveOverlaps)가 동일 소스를 공유해 두 레이어가 어긋나지 않는다.
		local transform = entity.TransformComponent
		if not isvalid(transform) then return false end
		local boxSize = nil
		local offX, offY = 0, 0
		local trigger = entity.TriggerComponent
		if isvalid(trigger) then
			boxSize = trigger.BoxSize
			offX = trigger.ColliderOffset.x
			offY = trigger.ColliderOffset.y
		else
			local collider = entity.PhysicsColliderComponent
			if isvalid(collider) then
				boxSize = collider.BoxSize
				offX = collider.ColliderOffset.x
				offY = collider.ColliderOffset.y
			end
		end
		if boxSize == nil then return false end
		local cx = transform.WorldPosition.x + offX
		local cy = transform.WorldPosition.y + offY
		local hx = boxSize.x * 0.5
		local hy = boxSize.y * 0.5
		outBox.minX = cx - hx
		outBox.maxX = cx + hx
		outBox.minY = cy - hy
		outBox.maxY = cy + hy
		return true
	end

	-- @ExecSpace 미지정: IsObstacle(서버 대시 포함)/기타 공용. 순수 산식.
	method number CirclePenetration(Vector2 p, number radius, table box)
		-- 원(중심 p, 반지름 radius)이 AABB(box)를 파고든 깊이. <=0 이면 겹치지 않음.
		-- 중심이 AABB 내부면 radius + 가장 가까운 면까지의 거리를 반환해, 깊이가 단조 증가하도록 한다
		-- (IsObstacle이 "더 깊어지는 이동만 차단" 비교에 쓴다).
		local minX, maxX, minY, maxY = box.minX, box.maxX, box.minY, box.maxY
		local closestX = p.x
		if closestX < minX then closestX = minX elseif closestX > maxX then closestX = maxX end
		local closestY = p.y
		if closestY < minY then closestY = minY elseif closestY > maxY then closestY = maxY end
		local dx = p.x - closestX
		local dy = p.y - closestY
		local distSq = dx * dx + dy * dy
		if distSq < 0.0000001 then
			-- 중심이 AABB 내부
			local nearest = math.min(p.x - minX, maxX - p.x, p.y - minY, maxY - p.y)
			return radius + nearest
		end
		return radius - math.sqrt(distSq)
	end

	@ExecSpace("ClientOnly")
	method Vector2 ResolveCircleAABB(number cx, number cy, number radius, table box, number startX, number startY)
		-- 원-대-AABB MTV. 내부 침투 시 start 쪽 면을 우선해 방향 뒤집힘 방지.
		local minX, maxX, minY, maxY = box.minX, box.maxX, box.minY, box.maxY
		local closestX = cx
		if closestX < minX then closestX = minX elseif closestX > maxX then closestX = maxX end
		local closestY = cy
		if closestY < minY then closestY = minY elseif closestY > maxY then closestY = maxY end

		local dx = cx - closestX
		local dy = cy - closestY
		local distSq = dx * dx + dy * dy
		local r2 = radius * radius

		-- 중심이 AABB 내부 (closest == center)
		if distSq < 0.0000001 then
			local midX = (minX + maxX) * 0.5
			local midY = (minY + maxY) * 0.5
			-- start 위치에 따라 선호 축/방향 결정
			local preferLeft = startX < midX
			local preferDown = startY < midY
			local pushLeft = (minX - radius) - cx
			local pushRight = (maxX + radius) - cx
			local pushDown = (minY - radius) - cy
			local pushUp = (maxY + radius) - cy
			local candX = preferLeft and pushLeft or pushRight
			local candY = preferDown and pushDown or pushUp
			if math.abs(candX) <= math.abs(candY) then
				return Vector2(candX, 0)
			end
			return Vector2(0, candY)
		end

		if distSq >= r2 then
			return Vector2.zero
		end

		local dist = math.sqrt(distSq)
		local pen = radius - dist
		local nx = dx / dist
		local ny = dy / dist
		return Vector2(nx * pen, ny * pen)
	end

	@ExecSpace("ClientOnly")
	method void ResolveOverlaps(number delta)
		-- T36: 원(r=0.3) 대 AABB 전량 해소. 이름 분기 없음.
		if self.IsDead then return end

		local body = self.Entity.KinematicbodyComponent
		local currentPos = nil
		if isvalid(body) then
			currentPos = body:GetWorldGroundPosition()
		else
			local transform = self.Entity.TransformComponent
			if isvalid(transform) then
				currentPos = transform.WorldPosition:ToVector2()
			end
		end
		if not currentPos then return end

		if not self.OverlapSafeInit then
			self.OverlapSafeX = currentPos.x
			self.OverlapSafeY = currentPos.y
			self.OverlapSafeInit = true
		end
		local startX = self.OverlapSafeX
		local startY = self.OverlapSafeY

		local simulator = _CollisionService:GetSimulator(self.Entity)
		local r = 0.3
		-- 후보 수집만 넓은 원 — 침투/밀어내기 판정은 GetColliderAABB(Trigger 박스) 전담 (재작업 ①)
		local queryR = self.OverlapQueryRadius
		if queryR == nil or queryR < r then queryR = 2.5 end
		local checkShape = CircleShape(currentPos, queryR)
		local overlaps = simulator:OverlapAll(CollisionGroups.TriggerBox, checkShape)

		local pushX, pushY = 0.0, 0.0
		local hit = false
		local box = { minX = 0, maxX = 0, minY = 0, maxY = 0 }

		for _, comp in ipairs(overlaps) do
			if isvalid(comp) and isvalid(comp.Entity) then
				local entity = comp.Entity
				if self:IsBlockingOverlapEntity(entity) and self:GetColliderAABB(entity, box) then
					local mtv = self:ResolveCircleAABB(currentPos.x, currentPos.y, r, box, startX, startY)
					if mtv.x ~= 0 or mtv.y ~= 0 then
						pushX = pushX + mtv.x
						pushY = pushY + mtv.y
						hit = true
					end
				end
			end
		end

		if hit then
			-- 당 프레임 전량 해소 + 클램프 0.5
			local mag = math.sqrt(pushX * pushX + pushY * pushY)
			local maxPush = 0.5
			if mag > maxPush and mag > 0.0001 then
				local s = maxPush / mag
				pushX = pushX * s
				pushY = pushY * s
			end
			local targetX = currentPos.x + pushX
			local targetY = currentPos.y + pushY
			-- currentPos를 body:GetWorldGroundPosition()에서 읽었으므로 쓰기도 body:SetWorldPosition으로
			-- 대칭화한다. transform.WorldPosition에 직접 쓰면 (1) Kinematicbody가 물리 스텝에서 되돌리며
			-- 싸우고 (2) 점프 중 transform.y에 실린 시각 오프셋을 지면 좌표로 덮어써 수직 스냅/순간이동이
			-- 발생한다. 지면 좌표계로 읽고-쓰면 점프 시각 오프셋을 건드리지 않는다.
			local body2 = self.Entity.KinematicbodyComponent
			if isvalid(body2) then
				body2:SetWorldPosition(Vector2(targetX, targetY))
			else
				local transform = self.Entity.TransformComponent
				if isvalid(transform) then
					transform.WorldPosition = Vector3(targetX, targetY, transform.WorldPosition.z)
				end
			end
			-- SafePos는 해소 후 위치만 갱신 (차단 AABB 내부 오염 방지 — 재작업 ②)
			self.OverlapSafeX = targetX
			self.OverlapSafeY = targetY
		else
			-- hit=false: 넓은 질의로 근처 차단 AABB 침투가 없음이 보장될 때만 갱신
			self.OverlapSafeX = currentPos.x
			self.OverlapSafeY = currentPos.y
		end
	end

	method table EnsureEquipSlots(any decoded)
		-- 항상 길이 4 슬롯 배열로 정규화 (빈 값 = 미장착).
		local slots = { "", "", "", "" }
		if type(decoded) == "table" then
			for i = 1, 4 do
				local v = decoded[i]
				if v ~= nil then slots[i] = tostring(v) end
			end
		end
		return slots
	end

	method table GetEquippedSlots()
		-- EquippedSkillsJson → 길이 4 슬롯 테이블.
		local ok, decoded = pcall(function() return _HttpService:JSONDecode(self.EquippedSkillsJson) end)
		if not ok then return self:EnsureEquipSlots(nil) end
		return self:EnsureEquipSlots(decoded)
	end

	@ExecSpace("ServerOnly")
	method void SanitizeEquippedSkills()
		-- T45⑥: 로드 시 미해금·패시브·중복 장착 정리. 세이브 경로 무변경.
		local slots = self:GetEquippedSlots()
		local seen = {}
		local changed = false
		for i = 1, 4 do
			local sid = slots[i]
			if sid ~= nil and sid ~= "" then
				local level = self:GetSkillLevel(sid)
				local drop = false
				if level < 1 then
					drop = true
				else
					local ds = _DataService:GetTable("SkillDataSet")
					if ds ~= nil then
						local row = ds:FindRow("SkillId", sid)
						if row ~= nil and (row:GetItem("Type") or "") == "Passive" then
							drop = true
						end
					end
					if seen[sid] then drop = true end
				end
				if drop then
					slots[i] = ""
					changed = true
				else
					seen[sid] = true
				end
			end
		end
		if changed then
			self.EquippedSkillsJson = _HttpService:JSONEncode(slots)
			log("[SKILL] SanitizeEquippedSkills filtered unequipped/passive/dupes")
		else
			-- 기본 "[]" 등을 4슬롯 형태로 정규화
			local ok, raw = pcall(function() return _HttpService:JSONDecode(self.EquippedSkillsJson) end)
			if not ok or type(raw) ~= "table" or #raw ~= 4 then
				self.EquippedSkillsJson = _HttpService:JSONEncode(slots)
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void TryAutoEquipOnUnlock(string skillId)
		-- T45④: 해금(0→1) 시 빈 슬롯이 있을 때만 자동 장착. 패시브 제외.
		if skillId == nil or skillId == "" then return end
		if self:GetSkillLevel(skillId) < 1 then return end
		local ds = _DataService:GetTable("SkillDataSet")
		if ds == nil then return end
		local row = ds:FindRow("SkillId", skillId)
		if row == nil then return end
		if (row:GetItem("Type") or "") == "Passive" then return end

		local slots = self:GetEquippedSlots()
		for i = 1, 4 do
			if slots[i] == skillId then return end
		end
		for i = 1, 4 do
			if slots[i] == nil or slots[i] == "" then
				slots[i] = skillId
				self.EquippedSkillsJson = _HttpService:JSONEncode(slots)
				log("[SKILL] AutoEquip unlock " .. skillId .. " -> slot " .. tostring(i))
				return
			end
		end
		log("[SKILL] AutoEquip skipped (no empty slot) " .. skillId)
	end

	@ExecSpace("Server")
	method void ServerRequestEquipSkill(integer slotIndex, string skillId)
		-- T45②: 슬롯 장착/해제 RPC. skillId 빈 문자열=해제. 미해금·패시브 거부, 중복 시 스왑.
		local playerComp = self.Entity.PlayerComponent
		if playerComp == nil or senderUserId ~= playerComp.UserId then return end
		if slotIndex < 1 or slotIndex > 4 then return end

		local slots = self:GetEquippedSlots()
		local sid = skillId or ""

		if sid == "" then
			slots[slotIndex] = ""
			self.EquippedSkillsJson = _HttpService:JSONEncode(slots)
			if _PersistenceManager then
				_PersistenceManager:MarkPlayerDirty(playerComp.UserId)
			end
			log("[SKILL] Unequip slot " .. tostring(slotIndex))
			return
		end

		if self:GetSkillLevel(sid) < 1 then
			self:ClientShowMineFeedback("아직 해금하지 않은 스킬입니다.", playerComp.UserId)
			return
		end

		local ds = _DataService:GetTable("SkillDataSet")
		if ds == nil then return end
		local row = ds:FindRow("SkillId", sid)
		if row == nil then return end
		if (row:GetItem("Type") or "") == "Passive" then
			self:ClientShowMineFeedback("패시브 스킬은 장착할 수 없습니다.", playerComp.UserId)
			return
		end

		-- 이미 다른 슬롯에 있으면 스왑 (그 슬롯 ↔ 대상 슬롯)
		local other = 0
		for i = 1, 4 do
			if i ~= slotIndex and slots[i] == sid then
				other = i
				break
			end
		end
		if other > 0 then
			local prev = slots[slotIndex]
			slots[slotIndex] = sid
			slots[other] = prev
		else
			slots[slotIndex] = sid
		end
		self.EquippedSkillsJson = _HttpService:JSONEncode(slots)
		if _PersistenceManager then
			_PersistenceManager:MarkPlayerDirty(playerComp.UserId)
		end
		local sname = row:GetItem("Name") or sid
		local keys = { "Q", "W", "E", "R" }
		self:ClientShowMineFeedback("[" .. (keys[slotIndex] or "?") .. "] " .. tostring(sname) .. " 장착", playerComp.UserId)
		log("[SKILL] Equip " .. sid .. " slot=" .. tostring(slotIndex))
	end

	@ExecSpace("ClientOnly")
	method void TryCastSlot(integer slotIndex)
		-- Resolve the skill bound to slotIndex, do a client-side cooldown/stamina precheck, then RPC.
		if self.IsDead then return end
		
		local skills = self:GetEquippedSlots()
		if slotIndex < 1 or slotIndex > 4 then return end
		
		local skillId = skills[slotIndex]
		if not skillId or skillId == "" then return end
		
		local ds = _DataService:GetTable("SkillDataSet")
		if not ds then return end
		local row = ds:FindRow("SkillId", skillId)
		if not row then return end
		
		local level = self:GetSkillLevel(skillId)
		if level < 1 then
			log("[SKILL] Not unlocked: " .. skillId)
			return
		end
		
		local cd = self:GetEffectiveCooldown(skillId, level)
		local cost = tonumber(row:GetItem("StaminaCost")) or 0
		if (row:GetItem("Type") or "") == "Passive" then return end
		
		if not self.CooldownMap then self.CooldownMap = {} end
		local now = _UtilLogic.ElapsedSeconds
		local lastCast = self.CooldownMap[skillId] or -999.0
		if now - lastCast < cd then
			log("[SKILL] Client cooldown active for " .. skillId)
			return
		end
		if self.Stamina < cost then
			log("[SKILL] Client stamina low for " .. skillId)
			return
		end
		
		log("[SKILL] Requesting cast " .. skillId .. " (slot " .. slotIndex .. ") dir " .. self.LastDirectionX .. "," .. self.LastDirectionY)
		self:ServerRequestCastSkill(skillId, self.LastDirectionX, self.LastDirectionY)
	end

	@ExecSpace("Server")
	method void ServerRequestCastSkill(string skillId, integer dirX, integer dirY)
		-- Authoritative validation: verify sender, cooldown, stamina; then branch by skill Type.
		local playerComp = self.Entity.PlayerComponent
		if playerComp == nil or senderUserId ~= playerComp.UserId then return end
		if self.IsDead then return end
		
		local ds = _DataService:GetTable("SkillDataSet")
		if not ds then return end
		local row = ds:FindRow("SkillId", skillId)
		if not row then return end
		
		local level = self:GetSkillLevel(skillId)
		if level < 1 then return end
		
		local cd = self:GetEffectiveCooldown(skillId, level)
		local cost = tonumber(row:GetItem("StaminaCost")) or 0
		local damageMul = self:GetEffectiveDamageMultiplier(skillId, level)
		local skillType = row:GetItem("Type")
		local effectRUID = row:GetItem("EffectRUID")
		if (skillType or "") == "Passive" then return end
		
		if not self.CooldownMap then self.CooldownMap = {} end
		local now = _UtilLogic.ElapsedSeconds
		local lastCast = self.CooldownMap[skillId] or -999.0
		if now - lastCast < cd then return end
		if self.Stamina < cost then return end
		
		self.Stamina = math.max(0, self.Stamina - cost)
		self.CooldownMap[skillId] = now
		self:ClientSyncCooldown(skillId, now)
		
		if skillType == "Melee" then
			self:ExecuteAreaDamageSkill(damageMul, Vector2(dirX, dirY), 1.8, 1.2)
		elseif skillType == "Ultimate" then
			self:ExecuteAreaDamageSkill(damageMul, Vector2(0, 0), 5.0, 0.0)
		elseif skillType == "Dash" then
			self:ExecuteDashSkill(dirX, dirY)
		elseif skillType == "Projectile" then
			self:ExecuteProjectileSkill(skillId, damageMul, dirX, dirY)
		end
		
		if effectRUID ~= nil and effectRUID ~= "" then
			self:MulticastPlayEffect(effectRUID, self.Entity.TransformComponent.WorldPosition)
		end
		-- T46: SoundRUID 시전 사운드 (데이터 주도)
		local soundRUID = row:GetItem("SoundRUID")
		if soundRUID ~= nil and soundRUID ~= "" then
			self:MulticastPlaySkillSound(soundRUID)
		end
	end

	@ExecSpace("Client")
	method void ClientSyncCooldown(string skillId, number serverTime)
		-- The server confirmed the cast; stamp the cooldown using the CLIENT clock so the local
		-- precheck and the HUD cooldown readout (UISkillBarController) both count down on one timebase
		-- (server/client ElapsedSeconds are not synchronized, so the raw serverTime is not used here).
		if not self.CooldownMap then self.CooldownMap = {} end
		self.CooldownMap[skillId] = _UtilLogic.ElapsedSeconds
	end

	-- =========================================================================
	-- SKILL TREE (S2) — 해금/레벨업 상태, SP, 서버 검증 (docs/design/skill-tree-plan.md)
	-- =========================================================================

	method integer GetSkillLevel(string skillId)
		-- SkillLevelsJson에서 보유 레벨 조회 (0 = 미해금). @Sync 프로퍼티라 서버/클라 공용.
		if skillId == nil or skillId == "" then return 0 end
		local ok, levels = pcall(function() return _HttpService:JSONDecode(self.SkillLevelsJson) end)
		if not ok or levels == nil then return 0 end
		return tonumber(levels[skillId]) or 0
	end

	method number GetEffectiveDamageMultiplier(string skillId, integer level)
		-- 실효 배율 = DamageMultiplier + DamagePerLevel × (level-1)
		local ds = _DataService:GetTable("SkillDataSet")
		if not ds then return 1.0 end
		local row = ds:FindRow("SkillId", skillId)
		if not row then return 1.0 end
		local base = tonumber(row:GetItem("DamageMultiplier")) or 1.0
		if level < 1 then return base end
		local perLevel = tonumber(row:GetItem("DamagePerLevel")) or 0.0
		return base + perLevel * (level - 1)
	end

	method number GetEffectiveCooldown(string skillId, integer level)
		-- 실효 쿨다운 = Cooldown + CooldownPerLevel × (level-1), 하한 0.1초
		local ds = _DataService:GetTable("SkillDataSet")
		if not ds then return 0.0 end
		local row = ds:FindRow("SkillId", skillId)
		if not row then return 0.0 end
		local base = tonumber(row:GetItem("Cooldown")) or 0.0
		if level < 1 then return base end
		local perLevel = tonumber(row:GetItem("CooldownPerLevel")) or 0.0
		return math.max(0.1, base + perLevel * (level - 1))
	end

	method number GetPassiveBonus(string statName)
		-- 보유 중인 패시브 스킬(PassiveStat == statName)의 효과 합산: PassiveValuePerLevel × level.
		-- 신규 패시브는 SkillDataSet CSV 행 추가만으로 자동 반영된다 (하드코딩 금지 룰).
		local total = 0.0
		local ds = _DataService:GetTable("SkillDataSet")
		if ds == nil then return total end
		
		local rowCount = ds:GetRowCount()
		for i = 1, rowCount do
			local stat = ds:GetCell(i, "PassiveStat")
			if stat ~= nil and stat == statName then
				local skillId = ds:GetCell(i, "SkillId")
				local level = self:GetSkillLevel(skillId)
				if level >= 1 then
					local perLevel = tonumber(ds:GetCell(i, "PassiveValuePerLevel")) or 0.0
					total = total + perLevel * level
				end
			end
		end
		return total
	end

	method number GetEffectiveMineCooldown()
		-- 실효 채집 쿨다운 = MineCooldown + Σ패시브(MineCooldown, 음수), 하한 0.2초
		-- T16 GatherSpeed mult: 쿨다운 / mult (채집 빨라짐)
		local cd = self.MineCooldown + self:GetPassiveBonus("MineCooldown")
		local buffs = self.Entity:GetComponent("script.PlayerBuffs")
		if isvalid(buffs) then
			local mult = buffs:GetStatMult("GatherSpeed")
			if mult > 0.01 then
				cd = cd / mult
			end
			cd = cd - buffs:GetStatAdd("GatherSpeed") * 0.05
		end
		return math.max(0.2, cd)
	end

	method number GetBuffedMoveSpeed()
		-- T16 MoveSpeed: base 3.6 * mult + add
		local base = 3.6
		local buffs = self.Entity:GetComponent("script.PlayerBuffs")
		if isvalid(buffs) then
			return base * buffs:GetStatMult("MoveSpeed") + buffs:GetStatAdd("MoveSpeed")
		end
		return base
	end

	method number GetBuffedAttackPower()
		-- T16 AttackPower 가산 (BaseDamage에 더함)
		local buffs = self.Entity:GetComponent("script.PlayerBuffs")
		if isvalid(buffs) then
			return buffs:GetStatAdd("AttackPower") + (buffs:GetStatMult("AttackPower") - 1.0) * 8.0
		end
		return 0.0
	end

	method number GetBuffedStaminaRegen()
		-- T16 StaminaRegen: 초당 기본 2 + add, * mult
		local base = 2.0
		local buffs = self.Entity:GetComponent("script.PlayerBuffs")
		if isvalid(buffs) then
			return (base + buffs:GetStatAdd("StaminaRegen")) * buffs:GetStatMult("StaminaRegen")
		end
		return base
	end

	@ExecSpace("ServerOnly")
	method boolean IsUnlockAchievementSatisfied(integer achievementId)
		-- 패키지 업적 게이트 판정: Completed 상태이거나, 최종 스텝을 달성 가능(진행도 충족)한 경우 통과.
		local pa = self.Entity.PlayerAchievement
		if pa == nil then return false end
		
		local data = _AchievementDataSetLogic:GetData(achievementId)
		if data == nil then return false end
		
		local userData = pa.UserDataTable[achievementId]
		if userData == nil then return false end
		
		if userData.State == _AchievementStateEnum.Completed then return true end
		if not userData:IsCompletable(data) then return false end
		
		-- 다단계 업적은 마지막 스텝에서만 게이트 통과
		return data:GetStepData(userData.Step + 1) == nil
	end

	@ExecSpace("Server")
	method void ServerRequestSkillLevelUp(string skillId)
		-- 스킬트리 해금/레벨업 서버 검증: ①선행 스킬 ②캐릭터 레벨 ③업적 게이트 ④SP ⑤MaxLevel
		local playerComp = self.Entity.PlayerComponent
		if playerComp == nil or senderUserId ~= playerComp.UserId then return end
		
		local ds = _DataService:GetTable("SkillDataSet")
		if not ds then return end
		local row = ds:FindRow("SkillId", skillId)
		if not row then return end
		
		local ok, levels = pcall(function() return _HttpService:JSONDecode(self.SkillLevelsJson) end)
		if not ok or levels == nil then levels = {} end
		local curLevel = tonumber(levels[skillId]) or 0
		
		-- ⑤ 최대 레벨
		local maxLevel = tonumber(row:GetItem("MaxLevel")) or 1
		if curLevel >= maxLevel then
			self:ClientShowMineFeedback("이미 최대 레벨입니다.", playerComp.UserId)
			return
		end
		
		-- 해금(0→1) 시에만 검사하는 게이트
		if curLevel == 0 then
			-- ① 선행 스킬: 부모 Lv ≥ ParentRequiredLevel (공란/누락=1, T58)
			local parentId = row:GetItem("ParentSkillId")
			if parentId ~= nil and parentId ~= "" then
				local parentNeed = 1
				local okPrl, rawPrl = pcall(function() return row:GetItem("ParentRequiredLevel") end)
				if okPrl and rawPrl ~= nil and tostring(rawPrl) ~= "" then
					parentNeed = math.floor(tonumber(rawPrl) or 1)
				end
				if parentNeed < 1 then parentNeed = 1 end
				local parentLv = tonumber(levels[parentId]) or 0
				if parentLv < parentNeed then
					local parentName = parentId
					local parentRow = ds:FindRow("SkillId", parentId)
					if parentRow ~= nil then
						local pn = parentRow:GetItem("Name")
						if pn ~= nil and pn ~= "" then parentName = tostring(pn) end
					end
					self:ClientShowMineFeedback(
						"선행 스킬 '" .. parentName .. "' Lv " .. tostring(parentNeed) .. " 필요",
						playerComp.UserId)
					return
				end
			end
			-- ② 캐릭터 레벨
			local reqLevel = tonumber(row:GetItem("RequiredLevel")) or 1
			if self.Level < reqLevel then
				self:ClientShowMineFeedback("레벨 " .. reqLevel .. " 이상 필요합니다.", playerComp.UserId)
				return
			end
			-- ③ 목표(업적) 게이트
			local achId = tonumber(row:GetItem("UnlockAchievementId"))
			if achId ~= nil and achId > 0 and not self:IsUnlockAchievementSatisfied(achId) then
				self:ClientShowMineFeedback("해금 목표를 먼저 달성해야 합니다.", playerComp.UserId)
				return
			end
		end
		
		-- ④ SP 비용
		local spCost = tonumber(row:GetItem("SPCost")) or 1
		if self.SP < spCost then
			self:ClientShowMineFeedback("SP가 부족합니다. (필요: " .. spCost .. ")", playerComp.UserId)
			return
		end
		
		levels[skillId] = curLevel + 1
		self.SP = self.SP - spCost
		self.SkillLevelsJson = _HttpService:JSONEncode(levels)

		-- T45④: 최초 해금 시 빈 슬롯 자동 장착 (액티브만)
		if curLevel == 0 then
			self:TryAutoEquipOnUnlock(skillId)
		end
		
		if _PersistenceManager then
			_PersistenceManager:MarkPlayerDirty(playerComp.UserId)
		end
		
		local skillName = row:GetItem("Name") or skillId
		if curLevel == 0 then
			self:ClientShowMineFeedback("[스킬 해금] " .. skillName .. " Lv.1", playerComp.UserId)
		else
			self:ClientShowMineFeedback("[스킬 강화] " .. skillName .. " Lv." .. (curLevel + 1), playerComp.UserId)
		end
		log("[SKILL-TREE] " .. playerComp.UserId .. " leveled " .. skillId .. " -> " .. (curLevel + 1) .. " (SP left: " .. self.SP .. ")")
	end

	@ExecSpace("ServerOnly")
	method integer ComputeSkillDamage(number damageMul)
		-- Base melee damage + tool-power scaling, then the skill multiplier (mirrors PlayerCombat.DoAttackAt).
		local base = 8
		local combat = self.Entity:GetComponent("script.PlayerCombat")
		if isvalid(combat) then
			---@type PlayerCombat
			local c = combat
			base = c.BaseDamage
		end
		local pi = self.Entity:GetComponent("script.PlayerInventory")
		if isvalid(pi) then
			---@type PlayerInventory
			local p = pi
			local toolInfo = p:GetEquippedToolInfo()
			if toolInfo and toolInfo.power > 0 then
				base = base + toolInfo.power * 4
			end
		end
		base = base + math.floor(self:GetBuffedAttackPower() + 0.5)
		return math.floor(base * damageMul)
	end

	@ExecSpace("ServerOnly")
	method void ExecuteAreaDamageSkill(number damageMul, Vector2 dir, number boxSize, number reach)
		-- Melee / Ultimate: emit a damage box (ahead of the player by `reach`, or centered when reach == 0)
		-- that only hits monster HitBoxes, reusing PlayerCombat's CalcDamage / IsAttackTarget path.
		local combat = self.Entity:GetComponent("script.PlayerCombat")
		if not isvalid(combat) then return end
		---@type PlayerCombat
		local c = combat
		
		local finalDmg = self:ComputeSkillDamage(damageMul)
		local myPos = self.Entity.TransformComponent.WorldPosition
		local center = Vector2(myPos.x + dir.x * reach, myPos.y + dir.y * reach)
		local shape = BoxShape(center, Vector2(boxSize, boxSize), 0)
		
		local prev = c.PendingDamage
		c.PendingDamage = finalDmg
		c:AttackFast(shape, nil, CollisionGroups.HitBox)
		c.PendingDamage = prev
		log("[SKILL] Area damage " .. finalDmg .. " box " .. boxSize .. " at (" .. string.format("%.1f, %.1f", center.x, center.y) .. ")")
	end

	@ExecSpace("ServerOnly")
	method void ExecuteDashSkill(integer dirX, integer dirY)
		-- Teleport-dash a short distance toward facing, stopping just before the first obstacle.
		local body = self.Entity.KinematicbodyComponent
		local transform = self.Entity.TransformComponent
		if not isvalid(transform) then return end
		
		local currentPos
		if isvalid(body) then
			currentPos = body:GetWorldGroundPosition()
		else
			currentPos = transform.WorldPosition:ToVector2()
		end
		
		local dirVec = Vector2(dirX, dirY)
		if dirVec:Magnitude() <= 0.0001 then
			dirVec = Vector2(self.LastDirectionX, self.LastDirectionY)
			if dirVec:Magnitude() <= 0.0001 then dirVec = Vector2(-1, 0) end
		end
		dirVec = dirVec:Normalize()
		
		local maxDist = 3.0
		local step = 0.5
		local finalPos = currentPos
		for d = step, maxDist, step do
			local checkPos = currentPos + dirVec * d
			if self:IsObstacle(checkPos, 0.3, currentPos) then break end
			finalPos = checkPos
		end
		
		if isvalid(body) then
			body:SetWorldPosition(Vector2(finalPos.x, finalPos.y))
		else
			transform.WorldPosition = Vector3(finalPos.x, finalPos.y, transform.WorldPosition.z)
		end
		log("[SKILL] Dash to (" .. string.format("%.1f, %.1f", finalPos.x, finalPos.y) .. ")")
	end

	@ExecSpace("ServerOnly")
	method void ExecuteProjectileSkill(string skillId, number damageMul, integer dirX, integer dirY)
		-- Spawn a flying projectile entity carrying script.Projectile that hits the first monster.
		local parentMap = self.Entity.CurrentMap
		if not isvalid(parentMap) then return end
		
		local modelId = _EntryService:GetModelIdByName("Projectile_Fireball")
		if modelId == nil or modelId == "" then
			log_warning("[SKILL] Projectile_Fireball model not found; fireball skipped.")
			return
		end
		
		local finalDmg = self:ComputeSkillDamage(damageMul)
		local myPos = self.Entity.TransformComponent.WorldPosition
		local spawnPos = Vector3(myPos.x + dirX * 0.8, myPos.y + dirY * 0.8, myPos.z)
		
		local proj = _SpawnService:SpawnByModelId(modelId, "Projectile_" .. skillId, spawnPos, parentMap)
		if not isvalid(proj) then return end
		
		local sprite = proj.SpriteRendererComponent
		if isvalid(sprite) then
			sprite.IgnoreMapLayerCheck = true
			sprite.SortingLayer = _RenderLayers.EntityLayer
			sprite.OrderInLayer = 500
		end
		
		local projComp = proj:GetComponent("script.Projectile")
		if not isvalid(projComp) then
			proj:AddComponent("script.Projectile")
			projComp = proj:GetComponent("script.Projectile")
		end
		if isvalid(projComp) then
			---@type Projectile
			local p = projComp
			p:Initialize(self.Entity, Vector2(dirX, dirY), finalDmg, 6.0)
			log("[SKILL] Fireball spawned dmg " .. finalDmg)
		end
	end

	@ExecSpace("Multicast")
	method void MulticastPlayEffect(string effectRUID, Vector3 pos)
		-- Play the cast VFX on every client at the cast position (no-op if no RUID configured).
		if effectRUID ~= nil and effectRUID ~= "" then
			-- PlayEffect(ruid, instigator, position, zRotation:float, scale:Vector3, isLoop:bool)
			_EffectService:PlayEffect(effectRUID, nil, pos, 0.0, Vector3(1, 1, 1), false)
		end
	end

	@ExecSpace("Multicast")
	method void MulticastPlaySkillSound(string soundRUID)
		-- T46: 시전 사운드 (SoundService — 클라 재생).
		if soundRUID == nil or soundRUID == "" then return end
		_SoundService:PlaySound(soundRUID, 1.0)
	end

	@ExecSpace("ServerOnly")
	@EventSender("Self")
	handler HandlePlayerHit(HitEvent event)
		if self.IsDead then return end
		if self.IFrameTimer > 0 then return end
		
		if self.FishingState ~= "None" then
			self:ServerRequestCancelFishing()
		end
		
		local playerComp = self.Entity.PlayerComponent
		if playerComp == nil then return end
		if not isvalid(event.AttackerEntity) then return end
		
		-- Check contact damage from attacker
		local damage = event.TotalDamage
		if damage <= 0 then
			local monsterAttack = event.AttackerEntity:GetComponent("script.MonsterMeleeAttack")
			if isvalid(monsterAttack) then
				damage = math.max(1, math.floor(monsterAttack.ContactDamage - self.Defense * 0.1))
			else
				damage = 5
			end
		end
		
		-- Apply damage to player HP and start server-side IFrame cooldown
		playerComp.Hp = math.max(0, playerComp.Hp - damage)
		self.IFrameTimer = 1.0  -- 1 second i-frame
		_TimerService:SetTimerOnce(function()
			if isvalid(self.Entity) then
				self.IFrameTimer = 0.0
				log("[IFRAME] Server reset player IFrameTimer to 0.0")
			end
		end, 1.0)
		
		-- Trigger hit animation state and schedule IDLE restore on server
		local sc = self.Entity.StateComponent
		if isvalid(sc) then
			sc:ChangeState("HIT")
			_TimerService:SetTimerOnce(function()
				if isvalid(self.Entity) and not self.IsDead then
					local currentSc = self.Entity.StateComponent
					if isvalid(currentSc) and currentSc.CurrentStateName == "HIT" then
						currentSc:ChangeState("IDLE")
						log("[KNOCKBACK] Server restored player state from HIT to IDLE")
					end
				end
			end, 0.25)
		end
		
		-- Apply Knockback (Server-side teleport push with obstacle checking)
		local pp = self.Entity.TransformComponent.WorldPosition
		local ap = event.AttackerEntity.TransformComponent.WorldPosition
		local kx = pp.x - ap.x
		local ky = pp.y - ap.y
		local len = math.sqrt(kx * kx + ky * ky)
		if len <= 0.0001 then kx = 1 ky = 0 len = 1 end
		
		local dirX = kx / len
		local dirY = ky / len
		
		local dist = 1.2
		local targetPos = Vector3(pp.x + dirX * dist, pp.y + dirY * dist, pp.z)
		local finalKnockPos = pp  -- Default to no movement
		
		if not self:IsObstacle(Vector2(targetPos.x, targetPos.y), 0.3, nil) then
			playerComp:SetWorldPosition(targetPos)
			finalKnockPos = targetPos
			log("[KNOCKBACK] Server pushed player to: (" .. string.format("%.2f, %.2f", targetPos.x, targetPos.y) .. ")")
		else
			local halfPos = Vector3(pp.x + dirX * (dist * 0.5), pp.y + dirY * (dist * 0.5), pp.z)
			if not self:IsObstacle(Vector2(halfPos.x, halfPos.y), 0.3, nil) then
				playerComp:SetWorldPosition(halfPos)
				finalKnockPos = halfPos
				log("[KNOCKBACK] Server pushed player (half-distance) to: (" .. string.format("%.2f, %.2f", halfPos.x, halfPos.y) .. ")")
			end
		end
		
		self:ClientApplyKnockback(pp.x, pp.y, finalKnockPos.x, finalKnockPos.y, 0.25)
		
		log("Player " .. self.Entity.Name .. " hit for " .. damage .. " damage. HP remaining: " .. playerComp.Hp)
		
		-- Check Death
		if playerComp.Hp <= 0 then
			self:ServerDie()
		end
	end

	@ExecSpace("Server")
	method void ServerRequestSleep(string bedEntityId)
		-- description: Process player request to sleep in bed on server.
		if self.IsDead or self.IsSleeping then return end
		local playerComp = self.Entity.PlayerComponent
		if playerComp == nil or senderUserId ~= playerComp.UserId then return end
		
		local bed = _EntityService:GetEntity(bedEntityId)
		if not isvalid(bed) then return end
		
		local myPos = self.Entity.TransformComponent.WorldPosition
		local bedPos = bed.TransformComponent.WorldPosition
		local dist = Vector2.Distance(Vector2(myPos.x, myPos.y), Vector2(bedPos.x, bedPos.y))
		if dist > 3.0 then return end
		
		local currentMap = self.Entity.CurrentMap
		if isvalid(currentMap) and string.sub(currentMap.Name, 1, 5) == "Home_" then
			local ownerId = string.sub(currentMap.Name, 6)
			if _PersistenceManager and not _PersistenceManager:CheckGuestPermission(ownerId, senderUserId, "interact") then
				self:ShowMineFeedback("이 영지의 침대를 이용할 수 있는 권한이 없습니다.")
				return
			end
		end
		
		self.IsSleeping = true
		self.SleepStartTimeTicks = tostring(DateTime.UtcNow.Ticks)
		self._T.SleepHpAccum = 0.0
		self._T.SleepStaminaAccum = 0.0
		
		local movement = self.Entity.MovementComponent
		if isvalid(movement) then movement:Stop() end
		
		if _PersistenceManager then
			_PersistenceManager:MarkPlayerDirty(senderUserId)
		end
		
		log("[SLEEP] Player " .. self.Entity.Name .. " started sleeping in bed: " .. bedEntityId)
		self:ClientOnSleepStart()
	end

	@ExecSpace("Server")
	method void ServerRequestWakeUp()
		-- description: Process player request to wake up on server.
		if not self.IsSleeping then return end
		local playerComp = self.Entity.PlayerComponent
		if playerComp == nil or senderUserId ~= playerComp.UserId then return end
		
		self.IsSleeping = false
		self.SleepStartTimeTicks = "0"
		
		if _PersistenceManager then
			_PersistenceManager:MarkPlayerDirty(senderUserId)
		end
		
		log("[SLEEP] Player " .. self.Entity.Name .. " woke up.")
		self:ClientOnSleepEnd()
	end

	@ExecSpace("Client")
	method void ClientOnSleepStart()
		-- description: Handle client-side feedback when sleeping starts (T8).
		_ScreenMessageLogic:PrivateMsg("수면 시작 — 약 10분에 HP/스태미나 풀충전. 이동키로 기상(비례 회복).")
	end

	@ExecSpace("Client")
	method void ClientOnSleepEnd()
		-- description: Handle client-side feedback when sleeping ends.
		_ScreenMessageLogic:PrivateMsg("잠에서 깨어났습니다.")
	end

	@ExecSpace("ClientOnly")
	method Entity FindNearbyBed()
		-- description: Finds the closest bed entity within interaction distance on the client.
		local currentMap = self.Entity.CurrentMap
		if not isvalid(currentMap) then return nil end
		
		local myPos = self.Entity.TransformComponent.WorldPosition:ToVector2()
		local closest = nil
		local minDist = 1.5
		
		local bedComponents = currentMap:GetChildComponentsByTypeName("script.Furniture_Bed", true)
		if not bedComponents then return nil end
		
		for _, comp in ipairs(bedComponents) do
			if isvalid(comp) then
				local ent = comp.Entity
				if isvalid(ent) then
					local fPos = ent.TransformComponent.WorldPosition:ToVector2()
					local dist = (myPos - fPos):Magnitude()
					if dist < minDist then
						minDist = dist
						closest = ent
					end
				end
			end
		end
		
		return closest
	end

	@ExecSpace("ClientOnly")
	method Entity FindNearbyTreasureChest()
		-- T9: 미개봉 보물 상자 (거리 ≤2.5). 포탈보다 우선 처리용.
		local currentMap = self.Entity.CurrentMap
		if not isvalid(currentMap) then return nil end
		local myPos = self.Entity.TransformComponent.WorldPosition:ToVector2()
		local closest = nil
		local minDist = 2.5
		local comps = currentMap:GetChildComponentsByTypeName("script.TreasureChest", true)
		if not comps then
			comps = currentMap:GetChildComponentsByTypeName("TreasureChest", true)
		end
		if not comps then return nil end
		for _, comp in ipairs(comps) do
			if isvalid(comp) then
				if not comp.IsOpened then
					local ent = comp.Entity
					if isvalid(ent) then
						local fPos = ent.TransformComponent.WorldPosition:ToVector2()
						local dist = (myPos - fPos):Magnitude()
						if dist < minDist then
							minDist = dist
							closest = ent
						end
					end
				end
			end
		end
		return closest
	end

	@ExecSpace("ClientOnly")
	method Entity FindNearbyFishingSpot()
		local currentMap = self.Entity.CurrentMap
		if not isvalid(currentMap) then return nil end
		local myPos = self.Entity.TransformComponent.WorldPosition:ToVector2()
		local closest = nil
		local minDist = 2.5
		local comps = currentMap:GetChildComponentsByTypeName("script.FishingSpot", true)
		if not comps then return nil end
		for _, comp in ipairs(comps) do
			if isvalid(comp) then
				local ent = comp.Entity
				if isvalid(ent) then
					local fPos = ent.TransformComponent.WorldPosition:ToVector2()
					local dist = (myPos - fPos):Magnitude()
					if dist < minDist then
						minDist = dist
						closest = ent
					end
				end
			end
		end
		return closest
	end

	method boolean IsEquippedFishingRod()
		local inv = self.Entity:GetComponent("script.PlayerInventory")
		if not isvalid(inv) then return false end
		local toolKey = inv.EquippedTool
		if toolKey == nil or toolKey == "" then return false end
		local baseName = inv:GetBaseItemName(toolKey)
		local ds = _DataService:GetTable("item_dataset")
		if ds == nil then return false end
		local row = ds:FindRow("Name", baseName)
		if row == nil then return false end
		return row:GetItem("ToolType") == "rod"
	end

	@ExecSpace("Server")
	method void ServerRequestFishingInteract(string spotEntityId)
		local playerComp = self.Entity.PlayerComponent
		if playerComp == nil or senderUserId ~= playerComp.UserId then return end
		if self.IsDead or self.IsSleeping then return end
		
		local spotEnt = _EntityService:GetEntity(spotEntityId)
		if not isvalid(spotEnt) then return end
		local spot = spotEnt:GetComponent("script.FishingSpot")
		if not isvalid(spot) then return end
		
		local myPos = self.Entity.TransformComponent.WorldPosition
		local spotPos = spotEnt.TransformComponent.WorldPosition
		local dist = Vector2.Distance(Vector2(myPos.x, myPos.y), Vector2(spotPos.x, spotPos.y))
		if dist > 2.5 then return end
		
		if not self:IsEquippedFishingRod() then
			self:ClientShowMineFeedback("낚싯대를 장착해야 합니다.")
			return
		end
		
		if self.FishingState == "None" then
			spot:StartFishing(self.Entity)
		elseif self.FishingState == "Casting" then
			spot:PullRod(self.Entity)
		elseif self.FishingState == "Bite" then
			spot:PullRod(self.Entity)
		end
	end

	@ExecSpace("Server")
	method void ServerRequestCancelFishing()
		local playerComp = self.Entity.PlayerComponent
		if playerComp == nil or senderUserId ~= playerComp.UserId then return end
		if self.FishingState == "None" then return end
		if isvalid(self.ActiveFishingSpot) then
			local spot = self.ActiveFishingSpot:GetComponent("script.FishingSpot")
			if isvalid(spot) then
				spot:CancelFishing(self.Entity)
			end
		end
		self.FishingState = "None"
		self.ActiveFishingSpot = nil
		self:ClientShowMineFeedback("낚시가 취소되었습니다.")
	end

end