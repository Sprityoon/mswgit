@Logic
script PersistenceManager extends Logic

	property table DirtyPlayers = {}
	property table GuestPermissions = {}
	property any PeriodicSaveTimerId = nil
	-- T37 재작업: 세션 중 마지막 영지 좌표 캐시 (세이브 경로 GetAndWait 금지)
	property table LastHomePos = {}

	-- 월드 밤낮 시간 영속화 관련 속성
	@HideFromInspector property number AccumulatedTime = 0
	@HideFromInspector property number ClientAccumulatedTime = 0
	property any TimeSaveTimerId = nil
	property any TimeSyncTimerId = nil

	@ExecSpace("ServerOnly")
	method void OnBeginPlay()
		self.DirtyPlayers = {}
		self.GuestPermissions = {}
		self.LastHomePos = {}

		_UserService:ConnectEvent(UserEnterEvent, self.OnUserEnter)
		_UserService:ConnectEvent(UserLeaveEvent, self.OnUserLeave)

		-- Setup 60s periodic save timer
		self.PeriodicSaveTimerId = _TimerService:SetTimerRepeat(function()
			self:SaveDirtyData()
		end, 60.0)

		-- 월드 절대 시각 시스템 기동
		log("PersistenceManager: Starting world time system on server...")
		self:LoadWorldTime()

		-- 30초 주기 시간 저장
		self.TimeSaveTimerId = _TimerService:SetTimerRepeat(function()
			self:SaveWorldTime()
		end, 30.0)

		-- 5초 주기 클라이언트 시간 동기화 브로드캐스트
		self.TimeSyncTimerId = _TimerService:SetTimerRepeat(function()
			self:SyncTimeBroadcast()
		end, 5.0)

		log("PersistenceManager initialized on server.")
	end

	@ExecSpace("ServerOnly")
	method void OnEndPlay()
		if self.PeriodicSaveTimerId then
			_TimerService:ClearTimer(self.PeriodicSaveTimerId)
			self.PeriodicSaveTimerId = nil
		end
		if self.TimeSaveTimerId then
			_TimerService:ClearTimer(self.TimeSaveTimerId)
			self.TimeSaveTimerId = nil
		end
		if self.TimeSyncTimerId then
			_TimerService:ClearTimer(self.TimeSyncTimerId)
			self.TimeSyncTimerId = nil
		end

		log("PersistenceManager: Saving world time on server shutdown...")
		self:SaveWorldTime()

		-- Final synchronous save for all active players
		log("PersistenceManager: Performing final sync save on OnEndPlay...")
		local players = _UserService.UserEntities
		if players then
			for userId, player in pairs(players) do
				if isvalid(player) then
					self:SavePlayerData(player, true)
				end
			end
		end
		log("PersistenceManager: Final sync save completed.")
	end

	@ExecSpace("ServerOnly")
	method void OnUserEnter(UserEnterEvent event)
		local userId = event.UserId
		log("PersistenceManager: Player entered: " .. userId .. ". Initializing home map...")
		
		-- 신규 접속 유저 시간 즉시 동기화
		local curTime = self:GetServerAccumulatedTime()
		self:SyncTimeClient(curTime)
		
		-- Create dynamic home map if not exists
		local mapName = "Home_" .. userId
		local map = _EntityService:GetEntityByPath("/maps/" .. mapName)
		if not isvalid(map) then
			log("PersistenceManager: Creating dynamic home map for " .. userId)
			local ec = _DynamicMapService:CreateDynamicMap("map01", mapName)
			if ec == DynamicMapResultCode.Success then
				map = _EntityService:GetEntityByPath("/maps/" .. mapName)
				if isvalid(map) then
					log("PersistenceManager: Dynamic home map created successfully. Spawning initial resources...")
					_ResourceSpawner:SpawnInitialResourcesForMap(map)
				else
					log_error("PersistenceManager: Failed to get map entity after creation for " .. mapName)
				end
			else
				log_error("PersistenceManager: CreateDynamicMap failed for " .. mapName .. " with error: " .. tostring(ec))
				return
			end
		end

		-- Load saved data and warp the player straight to their saved home position.
		-- (No pre-teleport to a fixed cell + delayed reposition — that caused a visible
		--  double-jump. LoadPlayerData applies data, reconstructs the home, then warps once.)
		local player = _UserService:GetUserEntityByUserId(userId)
		if isvalid(player) then
			self:LoadPlayerData(player)

			-- Connect map changed event on server
			player:ConnectEvent(EntityMapChangedEvent, self.OnPlayerMapChanged)

			-- Reveal the world: fade out the spawn cover now that the player is placed.
			local pc = player:GetComponent("script.PlayerController")
			if isvalid(pc) then
				---@type PlayerController
				local controller = pc
				controller:ClientHideSpawnFade(player.PlayerComponent.UserId)
			end
		else
			log_warning("PersistenceManager: Player entity not found for teleport: " .. userId)
		end
	end

	@ExecSpace("ServerOnly")
	method void OnUserLeave(UserLeaveEvent event)
		local userId = event.UserId
		log("PersistenceManager: Player left: " .. userId .. ". Saving data...")
		
		local player = _UserService:GetUserEntityByUserId(userId)
		local currentMap = nil
		if isvalid(player) then
			currentMap = player.CurrentMap
			self:SavePlayerData(player, true)
			self.DirtyPlayers[userId] = nil
		end
		
		-- Cleanup dynamic map if no players are left in the map player was in
		if isvalid(currentMap) and string.sub(currentMap.Name, 1, 5) == "Home_" then
			local mapComp = currentMap.MapComponent
			if isvalid(mapComp) then
				local users = _UserService:GetUsersByMapComponent(mapComp)
				local count = 0
				if users then
					for _, u in ipairs(users) do
						if isvalid(u) and u.PlayerComponent and u.PlayerComponent.UserId ~= userId then
							count = count + 1
						end
					end
				end
				if count == 0 then
					log("PersistenceManager: Destroying empty dynamic map " .. currentMap.Name .. " on player disconnect")
					_DynamicMapService:DestroyDynamicMap(currentMap.Name)
				end
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void MarkPlayerDirty(string userId)
		if not userId or userId == "" then return end
		self.DirtyPlayers[userId] = true
	end

	@ExecSpace("ServerOnly")
	method void LoadPlayerData(Entity player)
		if not isvalid(player) then return end
		local userId = player.PlayerComponent.UserId
		local mapName = "Home_" .. userId
		local map = _EntityService:GetEntityByPath("/maps/" .. mapName)
		if not isvalid(map) then return end

		-- Resolved spawn position; the player is warped here once at the end of this method.
		local spawnX, spawnY = -3.0, 0.0

		local storage = _DataStorageService:GetUserDataStorage(userId)
		if not storage then
			log_error("PersistenceManager: Failed to get UserDataStorage for " .. userId)
			return
		end

		local errorCode, raw = storage:GetAndWait("SaveData")
		if errorCode == 0 and raw and raw ~= "" and raw ~= "{}" then
			log("PersistenceManager: Load successful for " .. userId .. ". Parsing data...")
			local success, data = pcall(function() return _HttpService:JSONDecode(raw) end)
			if not success or not data then
				log_error("PersistenceManager: JSON decode failed for " .. userId)
				self:SetDefaultPlayerData(player)
				return
			end

			-- Restore Guest Permissions
			local permRaw = data.guestPermissions or "{}"
			local p_ok, p_dec = pcall(function() return _HttpService:JSONDecode(permRaw) end)
			self.GuestPermissions[userId] = p_ok and p_dec or {}

			-- Restore PlayerController stats
			local pc = player:GetComponent("script.PlayerController")
			if isvalid(pc) then
				pc.Level = data.level or 1
				pc.XP = data.xp or 0
				pc.MaxXP = data.maxRawXp or 100
				pc.Stamina = data.stamina or 100
				pc.MaxStamina = data.maxStamina or 100
				pc.GatheringSpeed = data.gatheringSpeed or 1.0
				pc.UnlockedWaypointsJson = data.unlockedWaypoints or "[]"
				pc.SkillLevelsJson = data.skillLevels or "{}"
				pc.SP = data.sp or 0
				-- T69: QWER 장착 영속 — SkillLevels 복원 후 · Sanitize 전에 복원 (sanitize가 해금 레벨을 읽음)
				pc.EquippedSkillsJson = data.equippedSkills or "[]"
				-- T64: 낚시 숙련
				pc.FishingLevel = data.fishingLevel or 1
				pc.FishingXp = data.fishingXp or 0
				-- T45⑥: 로드 직후 미해금·패시브·중복 장착 필터
				pc:SanitizeEquippedSkills()
				log("[T69][SAVE] load equippedSkills=" .. tostring(pc.EquippedSkillsJson))
				
				-- Offline sleeping recovery (T8): 10분(600s) 비례 회복. ≥600s면 풀충전.
				local savedIsSleeping = data.isSleeping or false
				local savedSleepStartTimeTicks = data.sleepStartTimeTicks or "0"
				if savedIsSleeping and savedSleepStartTimeTicks ~= "0" then
					local success, err = pcall(function()
						local startTime = DateTime(tonumber(savedSleepStartTimeTicks) or 0)
						local now = DateTime.UtcNow
						local elapsedTicks = now.Ticks - startTime.Ticks
						local elapsedSeconds = elapsedTicks / 10000000.0
						if elapsedSeconds > 0 then
							local maxHp = player.PlayerComponent.MaxHp
							local maxSt = pc.MaxStamina
							if elapsedSeconds >= 600.0 then
								player.PlayerComponent.Hp = maxHp
								pc.Stamina = maxSt
								log("PersistenceManager: Offline sleep full restore (≥600s). Elapsed=" .. tostring(elapsedSeconds))
							else
								local ratio = elapsedSeconds / 600.0
								local hpRecovery = ratio * maxHp
								local staminaRecovery = ratio * maxSt
								player.PlayerComponent.Hp = math.min(maxHp, player.PlayerComponent.Hp + math.floor(hpRecovery))
								pc.Stamina = math.min(maxSt, pc.Stamina + math.floor(staminaRecovery))
								log("PersistenceManager: Offline sleep proportional. Elapsed=" .. tostring(elapsedSeconds)
									.. "s HP+" .. tostring(math.floor(hpRecovery))
									.. " St+" .. tostring(math.floor(staminaRecovery)))
							end
						end
					end)
					if not success then
						log_warning("PersistenceManager: Failed to calculate offline sleep recovery: " .. tostring(err))
					end
					-- 로그인 시 기상 상태로 입장 (Acceptance: 풀충전 입장 / 활성 플레이)
					pc.IsSleeping = false
					pc.SleepStartTimeTicks = "0"
				else
					pc.IsSleeping = false
					pc.SleepStartTimeTicks = "0"
				end
				
				log("PersistenceManager: Stats restored (Lv " .. pc.Level .. ")")
			end

			-- Restore PlayerInventory
			local inv = player:GetComponent("script.PlayerInventory")
			if isvalid(inv) then
				local invData = data.inventoryData
				if invData == nil or invData == "" then
					invData = "{}"
				end
				inv.InventoryDataJson = invData
				local ok, decoded = pcall(function() return _HttpService:JSONDecode(inv.InventoryDataJson) end)
				if ok and decoded then
					inv.Items = decoded
				else
					log_warning("PersistenceManager: Failed to decode inventoryData, fallback to empty.")
					inv.Items = {}
				end
				inv.Coin = data.coin or 0
				inv.EquippedTool = data.equippedTool or ""
				inv.QuickSlotsJson = data.quickSlots or "[\"\", \"\", \"\", \"\", \"\", \"\", \"\", \"\", \"\", \"\"]"
				inv.SelectedQuickSlotIndex = data.selectedSlot or 1
				inv.UnlockedRecipesJson = data.unlockedRecipes or "[]"
				inv.ActiveResearchId = data.activeResearchId or ""
				inv.ResearchStartTime = data.researchStartTime or "0"
				inv.DailyRequestDay = data.dailyRequestDay or "0"
				inv.DailyCompletedRequestsJson = data.dailyCompletedRequests or "[]"
				inv.DexItemsJson = data.dexItems or "{}"
				inv.DexMonstersJson = data.dexMonsters or "{}"
				inv.ActivePetId = data.activePetId or ""
				inv:ApplyHeldToolCostume()
				inv:MigrateLegacyRecipeUnlocks()
				-- 통화 스택→Coin 프로퍼티 흡수 (IsCurrency 미기입 사고 복구)
				inv:ConsolidateCurrencyItems()
				-- T7: 오프라인 연구 경과 정산
				inv:TryCompleteActiveResearch()
				-- T20: 일 변경 시 완료 목록 리셋
				inv:EnsureDailyRequestState()
				log("PersistenceManager: Inventory restored. Coin=" .. tostring(inv.Coin))
			end

			-- Restore Placed Tiles, Furniture, Destroyed Resources, and Terrain Edits for player's home map
			local tilesRaw = data.homeTiles or "[]"
			local furnRaw = data.homeFurniture
			local destRaw = data.homeDestroyedResources or "[]"
			local editsRaw = data.homeTerrainEdits or "[]"
			
			if furnRaw == nil or furnRaw == "" then
				furnRaw = self:GetDefaultFurnitureJson(inv)
			end

			local furnList = {}
			if furnRaw ~= nil and furnRaw ~= "" then
				local ok, decoded = pcall(function() return _HttpService:JSONDecode(furnRaw) end)
				if ok and decoded then
					furnList = decoded
				end
				
				-- 포탈 설정 보정 (구버전 세이브 호환성)
				for _, furn in ipairs(furnList) do
					local isPortal = false
					local itemDs = _DataService:GetTable("item_dataset")
					if itemDs ~= nil then
						local row = itemDs:FindRow("Name", furn.itemName)
						if row ~= nil then
							isPortal = row:GetItem("FurnitureKind") == "portal"
						end
					end
					if isPortal then
						if furn.destinationGroup == nil or furn.destinationGroup == "" then
							local targetMap = "town"
							local group = "town"
							local arriveX = 3
							local arriveY = 0
							
							local destDs = _DataService:GetTable("PortalDestinationDataSet")
							if destDs ~= nil then
								local rowCount = destDs:GetRowCount()
								for i = 1, rowCount do
									if destDs:GetCell(i, "IsDefault") == "true" or destDs:GetCell(i, "IsDefault") == true then
										targetMap = destDs:GetCell(i, "MapName") or targetMap
										group = destDs:GetCell(i, "Group") or group
										arriveX = tonumber(destDs:GetCell(i, "ArriveX")) or arriveX
										arriveY = tonumber(destDs:GetCell(i, "ArriveY")) or arriveY
										break
									end
								end
							end
							
							furn.destinationGroup = group
							furn.portalColor = "white"
							furn.targetMapName = targetMap
							furn.targetPositionX = arriveX
							furn.targetPositionY = arriveY
						end
					end
				end
				furnRaw = _HttpService:JSONEncode(furnList)
			end

			_ResourceSpawner:SetPlacedTilesJson(mapName, tilesRaw)
			_ResourceSpawner:SetPlacedFurnitureJson(mapName, furnRaw)
			_ResourceSpawner:SetTerrainEditsJson(mapName, editsRaw)
			_ResourceSpawner:LoadDestroyedResourcesFromJson(mapName, destRaw)
			_ResourceSpawner:ReconstructWorldPlacementsForMap(map)

			-- T19: 가축 복원 (가구 재구성 이후)
			local animalsRaw = data.homeAnimals or "[]"
			self:ReconstructHomeAnimals(map, animalsRaw, userId)

			-- T23: 활성 펫 재소환 (홈 로드 시점 — 이후 맵 이동은 Pet.WarpToOwner)
			local invPet = player:GetComponent("script.PlayerInventory")
			if isvalid(invPet) and invPet.ActivePetId ~= nil and invPet.ActivePetId ~= "" then
				invPet:TrySummonPet(invPet.ActivePetId)
			end

			-- Reconstruct 후 상자 아이템 데이터 복원
			local furnList = {}
			if furnRaw ~= nil and furnRaw ~= "" then
				local ok, decoded = pcall(function() return _HttpService:JSONDecode(furnRaw) end)
				if ok and decoded then
					furnList = decoded
				end
			end
			local chestComps = map:GetChildComponentsByTypeName("script.Chest", true)
			local tilemap = map:GetFirstChildComponentByTypeName("RectTileMapComponent", true)
			if chestComps and isvalid(tilemap) then
				for _, comp in ipairs(chestComps) do
					local ent = comp.Entity
					if isvalid(ent) then
						local entCell = tilemap:ToCellPosition(ent.TransformComponent.WorldPosition)
						if entCell then
							for _, furn in ipairs(furnList) do
								if furn.x == entCell.x and furn.y == entCell.y then
									if furn.chestItems then
										comp:SetItems(furn.chestItems)
									end
									break
								end
							end
						end
					end
				end
			end

			-- Remember saved home position; warp target depends on lastMapKind (T37).
			spawnX = data.posX or -3.0
			spawnY = data.posY or 0.0
			-- 세션 캐시 초기화 (비홈 저장 시 GetAndWait 없이 사용)
			self.LastHomePos[userId] = { x = spawnX, y = spawnY }
			-- 구세이브 폴백 or "home" = 현행 동작
			local lastKind = data.lastMapKind or "home"
			if lastKind == "town" or lastKind == "hunt" then
				-- 마을·사냥터 종료 → 마을 기본 스폰 (IsDefault 행)
				local dest = { mapName = "town", x = 3.0, y = 0.0 }
				self:GetDefaultTownSpawn(dest)
				local townMap = dest.mapName or "town"
				local tx = tonumber(dest.x) or 3.0
				local ty = tonumber(dest.y) or 0.0
				local townSafe = Vector2(tx + 0.5, ty + 0.5)
				if _ResourceSpawner ~= nil then
					local sp = _ResourceSpawner:FindSafeSpawnPosition(townMap, tx + 0.5, ty + 0.5)
					if sp ~= nil then townSafe = sp end
				end
				player.PlayerComponent:MoveToMapPosition(townMap, townSafe)
				log("PersistenceManager: Player warped to " .. townMap
					.. " (lastMapKind=" .. tostring(lastKind) .. ") at ("
					.. tostring(townSafe.x) .. ", " .. tostring(townSafe.y) .. ")")
				self.DirtyPlayers[userId] = false
				return
			end
		else
			if errorCode == 1000002 or raw == nil or raw == "" or raw == "{}" then
				log("PersistenceManager: No save data found (New Player) for " .. userId)
			else
				log_warning("PersistenceManager: Load failed for " .. userId .. " with error code: " .. tostring(errorCode))
			end
			self.GuestPermissions[userId] = {}
			self:SetDefaultPlayerData(player)
			
			_ResourceSpawner:SetPlacedTilesJson(mapName, "[]")
			
			local inv = player:GetComponent("script.PlayerInventory")
			local defaultFurn = self:GetDefaultFurnitureJson(inv)
			_ResourceSpawner:SetPlacedFurnitureJson(mapName, defaultFurn)
			_ResourceSpawner:SetTerrainEditsJson(mapName, "[]")

			_ResourceSpawner:LoadDestroyedResourcesFromJson(mapName, "[]")
			_ResourceSpawner:ReconstructWorldPlacementsForMap(map)
		end

		-- home (또는 구세이브): 영지 저장 좌표로 단일 워프
		local safePos = _ResourceSpawner:FindSafeSpawnPosition(mapName, spawnX, spawnY)
		player.PlayerComponent:MoveToMapPosition(mapName, safePos)
		log("PersistenceManager: Player warped to home " .. mapName .. " at (" .. safePos.x .. ", " .. safePos.y .. ") (original: " .. spawnX .. ", " .. spawnY .. ")")

		self.DirtyPlayers[userId] = false
	end

	@ExecSpace("ServerOnly")
	method void SetDefaultPlayerData(Entity player)
		if not isvalid(player) then return end
		log("PersistenceManager: Setting default player progress stats...")
		local pc = player:GetComponent("script.PlayerController")
		if isvalid(pc) then
			pc.Level = 1
			pc.XP = 0
			pc.MaxXP = 100
			pc.Stamina = 100
			pc.MaxStamina = 100
			pc.GatheringSpeed = 1.0
			pc.SkillLevelsJson = "{}"
			pc.SP = 0
			pc.FishingLevel = 1
			pc.FishingXp = 0
			pc.EquippedSkillsJson = "[]"
			pc:SanitizeEquippedSkills()
			pc.IsSleeping = false
			pc.SleepStartTimeTicks = "0"
		end
	end

	method string ClassifyMapKind(string mapName)
		-- T37: Home_ 접두=home / town=town / 그 외=hunt
		if mapName == nil or mapName == "" then return "home" end
		if string.sub(mapName, 1, 5) == "Home_" then return "home" end
		if mapName == "town" then return "town" end
		return "hunt"
	end

	method void GetDefaultTownSpawn(table outDest)
		-- PortalDestinationDataSet IsDefault 행 (T33) — 좌표 하드코딩 금지
		outDest.mapName = "town"
		outDest.x = 3.0
		outDest.y = 0.0
		local destDs = _DataService:GetTable("PortalDestinationDataSet")
		if destDs == nil then return end
		local n = destDs:GetRowCount()
		for i = 1, n do
			local isDef = destDs:GetCell(i, "IsDefault")
			if isDef == "true" or isDef == true or isDef == "True" then
				outDest.mapName = destDs:GetCell(i, "MapName") or outDest.mapName
				outDest.x = tonumber(destDs:GetCell(i, "ArriveX")) or outDest.x
				outDest.y = tonumber(destDs:GetCell(i, "ArriveY")) or outDest.y
				return
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void SavePlayerData(Entity player, boolean isSynchronous)
		if not isvalid(player) then return end
		-- §1.2 규칙 9: 진입 직후 컴포넌트 값 선캡처 — 세이브 경로 GetAndWait 금지 (T37 재작업)
		local userId = player.PlayerComponent.UserId
		local mapName = "Home_" .. userId
		
		local pc = player:GetComponent("script.PlayerController")
		local inv = player:GetComponent("script.PlayerInventory")
		if not isvalid(pc) or not isvalid(inv) then return end

		local currentMapName = ""
		if isvalid(player.CurrentMap) then
			currentMapName = player.CurrentMap.Name or ""
		end
		local mapKind = self:ClassifyMapKind(currentMapName)
		local livePosX = player.TransformComponent.WorldPosition.x
		local livePosY = player.TransformComponent.WorldPosition.y

		local capLevel = tonumber(pc.Level) or 1
		local capXp = tonumber(pc.XP) or 0
		local capMaxXp = tonumber(pc.MaxXP) or 100
		local capStamina = tonumber(pc.Stamina) or 100
		local capMaxStamina = tonumber(pc.MaxStamina) or 100
		local capGather = tonumber(pc.GatheringSpeed) or 1.0
		local capWaypoints = pc.UnlockedWaypointsJson or "[]"
		local capSkills = pc.SkillLevelsJson or "{}"
		-- T69: QWER 장착 — 선캡처(규칙 9: 추가 Yield 금지, 기존 캡처 블록과 동일 위치)
		local capEquippedSkills = pc.EquippedSkillsJson or "[]"
		local capSp = tonumber(pc.SP) or 0
		local capFishingLevel = tonumber(pc.FishingLevel) or 1
		local capFishingXp = tonumber(pc.FishingXp) or 0
		local capSleeping = pc.IsSleeping == true
		local capSleepTicks = pc.SleepStartTimeTicks or "0"
		local capCoin = tonumber(inv.Coin) or 0
		local capInvJson = inv.InventoryDataJson or "{}"
		local capEquipped = inv.EquippedTool or ""
		local capQuick = inv.QuickSlotsJson or "[\"\", \"\", \"\", \"\", \"\", \"\", \"\", \"\", \"\", \"\"]"
		local capSlot = tonumber(inv.SelectedQuickSlotIndex) or 1
		local capRecipes = inv.UnlockedRecipesJson or "[]"
		local capResearchId = inv.ActiveResearchId or ""
		local capResearchStart = inv.ResearchStartTime or "0"
		local capDailyDay = inv.DailyRequestDay or "0"
		local capDailyDone = inv.DailyCompletedRequestsJson or "[]"
		local capDexItems = inv.DexItemsJson or "{}"
		local capDexMonsters = inv.DexMonstersJson or "{}"
		local capActivePet = inv.ActivePetId or ""

		local posX = livePosX
		local posY = livePosY
		if mapKind == "home" then
			self.LastHomePos[userId] = { x = posX, y = posY }
		else
			local cached = self.LastHomePos[userId]
			if cached ~= nil then
				posX = tonumber(cached.x) or -3.0
				posY = tonumber(cached.y) or 0.0
			else
				posX = -3.0
				posY = 0.0
			end
		end

		-- Retrieve home map placements and destroyed resources to save to player user data
		local tilesJson = _ResourceSpawner:GetPlacedTilesJson(mapName)
		local furnRaw = _ResourceSpawner:GetPlacedFurnitureJson(mapName)
		local furnList = {}
		if furnRaw ~= nil and furnRaw ~= "" then
			local ok, decoded = pcall(function() return _HttpService:JSONDecode(furnRaw) end)
			if ok and decoded then
				furnList = decoded
			end
		end
		
		local map = _EntityService:GetEntityByPath("/maps/" .. mapName)
		if isvalid(map) then
			local chestComps = map:GetChildComponentsByTypeName("script.Chest", true)
			local tilemap = map:GetFirstChildComponentByTypeName("RectTileMapComponent", true)
			if chestComps and isvalid(tilemap) then
				for _, comp in ipairs(chestComps) do
					local ent = comp.Entity
					if isvalid(ent) then
						local entCell = tilemap:ToCellPosition(ent.TransformComponent.WorldPosition)
						if entCell then
							for _, furn in ipairs(furnList) do
								if furn.x == entCell.x and furn.y == entCell.y then
									-- 원본 스냅샷(정제 전). 빈 {} 는 아래 정제에서 제거한다.
									furn.chestItems = comp:GetItems()
									break
								end
							end
						end
					end
				end
			end
		end

		-- 상자 내용 정제: 빈 중첩 chestItems={} → LEA-3001. 비어 있으면 생략, 있으면 평문 복사만.
		for _, furn in ipairs(furnList) do
			local rawItems = furn.chestItems
			furn.chestItems = nil
			if rawItems ~= nil and type(rawItems) == "table" and next(rawItems) ~= nil then
				local clean = {}
				for _, it in ipairs(rawItems) do
					if type(it) == "table" and it.name ~= nil then
						local row = {
							name = tostring(it.name),
							count = math.floor(tonumber(it.count) or 0)
						}
						if it.isTool == true then
							row.isTool = true
							row.durability = math.floor(tonumber(it.durability) or 100)
						end
						table.insert(clean, row)
					end
				end
				if #clean > 0 then
					furn.chestItems = clean
				end
			end
		end

		local furnJson = self:SafeEncodeJson(furnList, "[]")
		local destJson = _ResourceSpawner:GetDestroyedResourcesAsJson(mapName)
		local permList = self.GuestPermissions[userId] or {}
		local permJson = self:SafeEncodeJson(permList, "[]")
		-- T19: 가축 목록 선캡처 (Yield 전)
		local animalsJson = self:CollectHomeAnimalsJson(mapName)

		local data = {
			level = capLevel,
			xp = capXp,
			maxRawXp = capMaxXp,
			stamina = capStamina,
			maxStamina = capMaxStamina,
			gatheringSpeed = capGather,
			coin = capCoin,
			inventoryData = capInvJson,
			equippedTool = capEquipped,
			quickSlots = capQuick,
			selectedSlot = capSlot,
			unlockedRecipes = capRecipes,
			activeResearchId = capResearchId,
			researchStartTime = capResearchStart,
			dailyRequestDay = capDailyDay,
			dailyCompletedRequests = capDailyDone,
			dexItems = capDexItems,
			dexMonsters = capDexMonsters,
			activePetId = capActivePet,
			unlockedWaypoints = capWaypoints,
			skillLevels = capSkills,
			equippedSkills = capEquippedSkills,
			sp = capSp,
			fishingLevel = capFishingLevel,
			fishingXp = capFishingXp,
			isSleeping = capSleeping,
			sleepStartTimeTicks = capSleepTicks,
			posX = tonumber(posX) or 0.0,
			posY = tonumber(posY) or 0.0,
			lastMapKind = mapKind,
			homeTiles = tilesJson or "[]",
			homeFurniture = furnJson,
			homeTerrainEdits = _ResourceSpawner:GetTerrainEditsJson(mapName) or "[]",
			homeDestroyedResources = destJson or "[]",
			homeAnimals = animalsJson,
			guestPermissions = permJson
		}

		log("[T69][SAVE] capture equippedSkills=" .. tostring(capEquippedSkills))
		-- data 인코드 실패 시 필드 단위 격리 (전체 세이브 조용히 삼키기 금지 — 필드명 로그)
		local okData, jsonStr = pcall(function() return _HttpService:JSONEncode(data) end)
		if not okData or jsonStr == nil or jsonStr == "" then
			log_error("PersistenceManager: data JSONEncode failed — isolating bad fields for " .. userId
				.. " err=" .. tostring(jsonStr))
			local safeData = {}
			for k, v in pairs(data) do
				local one = {}
				one[k] = v
				local okOne, encOne = pcall(function() return _HttpService:JSONEncode(one) end)
				if okOne and encOne ~= nil and encOne ~= "" then
					safeData[k] = v
				else
					log_error("PersistenceManager: save field dropped (unencodable): " .. tostring(k)
						.. " type=" .. type(v) .. " err=" .. tostring(encOne))
					if type(v) == "string" then
						safeData[k] = ""
					elseif type(v) == "number" then
						safeData[k] = 0
					elseif type(v) == "boolean" then
						safeData[k] = false
					else
						safeData[k] = "[]"
					end
				end
			end
			jsonStr = self:SafeEncodeJson(safeData, "{}")
			if jsonStr == nil or jsonStr == "" then
				log_error("PersistenceManager: save aborted after field isolation for " .. userId)
				return
			end
		end
		local storage = _DataStorageService:GetUserDataStorage(userId)
		if not storage then
			log_error("PersistenceManager: Failed to get UserDataStorage for saving " .. userId)
			return
		end

		if isSynchronous then
			local errorCode = storage:SetAndWait("SaveData", jsonStr)
			if errorCode ~= 0 then
				log_warning("PersistenceManager: Sync save failed for " .. userId .. ", error: " .. tostring(errorCode))
			else
				log("PersistenceManager: Sync save completed for " .. userId)
			end
		else
			storage:SetAsync("SaveData", jsonStr, function(errorCode, key)
				if errorCode ~= 0 then
					log_warning("PersistenceManager: Async save failed for " .. userId .. ", error: " .. tostring(errorCode))
				else
					log("PersistenceManager: Async save completed for " .. userId)
				end
			end)
		end
	end

	method string SafeEncodeJson(table tbl, string defaultVal)
		-- 빈 테이블은 MSW JSONEncode 가 "" 를 반환하므로 기본값 사용.
		-- 중첩 빈 테이블 등은 LEA-3001 을 던질 수 있어 pcall 필수.
		if defaultVal == nil or defaultVal == "" then
			defaultVal = "[]"
		end
		if tbl == nil or next(tbl) == nil then
			return defaultVal
		end
		local ok, encoded = pcall(function() return _HttpService:JSONEncode(tbl) end)
		if ok and encoded ~= nil and encoded ~= "" then
			return encoded
		end
		log_error("PersistenceManager: SafeEncodeJson failed, using default. err=" .. tostring(encoded))
		return defaultVal
	end

	@ExecSpace("ServerOnly")
	method void SaveDirtyData()
		local players = _UserService.UserEntities
		if players then
			for userId, isDirty in pairs(self.DirtyPlayers) do
				if isDirty then
					local player = players[userId]
					if isvalid(player) then
						self:SavePlayerData(player, false)
						self.DirtyPlayers[userId] = false
					end
				end
			end
		end
	end

	-- ==========================================
	-- 월드 밤낮 시간 영속화 및 계산 시스템 메서드
	-- ==========================================

	@ExecSpace("ServerOnly")
	method number GetServerAccumulatedTime()
		return self.AccumulatedTime + _UtilLogic.ServerElapsedSeconds
	end

	@ExecSpace("ServerOnly")
	method void LoadWorldTime()
		local storage = _DataStorageService:GetGlobalDataStorage("WorldTimeStorage")
		if not storage then
			log_error("PersistenceManager: Failed to load GlobalDataStorage 'WorldTimeStorage'")
			return
		end

		local errorCode, raw = storage:GetAndWait("AccumulatedTime")
		if errorCode == 0 and raw and raw ~= "" then
			local val = tonumber(raw)
			if val then
				self.AccumulatedTime = val
				log("PersistenceManager: Loaded accumulated time: " .. tostring(self.AccumulatedTime) .. " seconds.")
			else
				log_warning("PersistenceManager: Loaded value is invalid number: " .. tostring(raw) .. ". Falling back to 0.")
				self.AccumulatedTime = 0
			end
		else
			if errorCode == 1000002 or raw == nil or raw == "" then
				log("PersistenceManager: No previous world time data found. Starting at 0s.")
			else
				log_warning("PersistenceManager: World time load failed with error code: " .. tostring(errorCode))
			end
			self.AccumulatedTime = 0
		end
	end

	@ExecSpace("ServerOnly")
	method void SaveWorldTime()
		local storage = _DataStorageService:GetGlobalDataStorage("WorldTimeStorage")
		if not storage then
			log_error("PersistenceManager: Cannot save. GlobalDataStorage 'WorldTimeStorage' not found.")
			return
		end

		local curTime = self:GetServerAccumulatedTime()
		local ok = storage:SetAndWait("AccumulatedTime", tostring(math.floor(curTime)))
		if ok then
			log("PersistenceManager: Successfully auto-saved accumulated time: " .. tostring(math.floor(curTime)) .. " seconds.")
		else
			log_warning("PersistenceManager: Failed to auto-save accumulated time.")
		end
	end

	@ExecSpace("ServerOnly")
	method void SyncTimeBroadcast()
		local curTime = self:GetServerAccumulatedTime()
		self:SyncTimeClient(curTime)
	end

	@ExecSpace("Client")
	method void SyncTimeClient(number curTime)
		self.ClientAccumulatedTime = curTime
	end

	-- 공용 밤낮 판정 인터페이스 (IsNight)
	method boolean IsNight()
		local curTime = 0
		if self:IsServer() then
			curTime = self:GetServerAccumulatedTime()
		else
			curTime = self.ClientAccumulatedTime
		end
		local timeInDay = curTime % 600
		return (timeInDay >= 300)
	end

	-- 공용 현재 시간 반환 인터페이스 (0 ~ 599)
	method number GetCurrentTime()
		local curTime = 0
		if self:IsServer() then
			curTime = self:GetServerAccumulatedTime()
		else
			curTime = self.ClientAccumulatedTime
		end
		return curTime % 600
	end

	@ExecSpace("ServerOnly")
	method void OnPlayerMapChanged(EntityMapChangedEvent event)
		local player = event.Entity
		if not isvalid(player) or player.PlayerComponent == nil then return end

		local oldMap = event.OldMap
		local newMap = event.NewMap
		local userId = player.PlayerComponent.UserId

		-- 1. GC empty map if visitor left it
		if isvalid(oldMap) and string.sub(oldMap.Name, 1, 5) == "Home_" then
			local mapComp = oldMap.MapComponent
			if isvalid(mapComp) then
				local users = _UserService:GetUsersByMapComponent(mapComp)
				local count = 0
				if users then
					for _, u in ipairs(users) do
						if isvalid(u) and u.PlayerComponent and u.PlayerComponent.UserId ~= userId then
							count = count + 1
						end
					end
				end
				if count == 0 then
					log("PersistenceManager: Destroying empty dynamic map " .. oldMap.Name .. " after visitor warped out")
					_DynamicMapService:DestroyDynamicMap(oldMap.Name)
				end
			end
		end

		-- 2. Sync B's permissions in newMap
		if isvalid(newMap) then
			local mapName = newMap.Name
			local mine, place, interact = false, false, false
			if mapName == "Home_" .. userId then
				-- Own map: full permission
				mine = true
				place = true
				interact = true
			elseif string.sub(mapName, 1, 5) == "Home_" then
				-- Other player's home map: check permissions
				local ownerId = string.sub(mapName, 6)
				local hasPerm = self:CheckGuestPermission(ownerId, userId, "place") -- Using "place" as proxy
				mine = hasPerm
				place = hasPerm
				interact = hasPerm
			else
				-- Town or other public maps: no placement/mining/interact permission
				mine = false
				place = false
				interact = false
			end
			local pc = player:GetComponent("script.PlayerController")
			if isvalid(pc) then
				pc:ClientSetCurrentMapPermissions(mine, place, interact)
			end
		end
	end

	@ExecSpace("ServerOnly")
	method boolean CheckGuestPermission(string ownerId, string guestId, string actionType)
		if ownerId == guestId then return true end
		local ownerPerms = self.GuestPermissions[ownerId]
		if ownerPerms == nil then return false end
		local guestPerms = ownerPerms[guestId]
		if guestPerms == nil then return false end
		return guestPerms[actionType] == true
	end

	@ExecSpace("ServerOnly")
	method void ServerRequestTogglePermission(string ownerId, string guestUserId)
		if self.GuestPermissions[ownerId] == nil then
			self.GuestPermissions[ownerId] = {}
		end
		
		local current = self.GuestPermissions[ownerId][guestUserId]
		local newPerm = true
		if current and current.place then
			newPerm = false
		end
		
		self.GuestPermissions[ownerId][guestUserId] = { mine = newPerm, place = newPerm, interact = newPerm }
		self:MarkPlayerDirty(ownerId)
		log("PersistenceManager: Toggled guest permission for owner " .. ownerId .. " -> guest " .. guestUserId .. " to " .. tostring(newPerm))
		
		-- Notify the guest if they are currently in the owner's map
		local guestPlayer = _UserService:GetUserEntityByUserId(guestUserId)
		if isvalid(guestPlayer) and isvalid(guestPlayer.CurrentMap) and guestPlayer.CurrentMap.Name == "Home_" .. ownerId then
			local pc = guestPlayer:GetComponent("script.PlayerController")
			if isvalid(pc) then
				pc:ClientSetCurrentMapPermissions(newPerm, newPerm, newPerm)
			end
		end
	end

	@ExecSpace("ServerOnly")
	method string CollectHomeAnimalsJson(string mapName)
		-- T19: 홈 맵의 Animal 컴포넌트 목록을 JSON 배열로 직렬화 (Save 선캡처용).
		local list = {}
		local map = _EntityService:GetEntityByPath("/maps/" .. mapName)
		if not isvalid(map) then return "[]" end
		local comps = map:GetChildComponentsByTypeName("script.Animal", true)
		if comps ~= nil then
			for _, comp in ipairs(comps) do
				if isvalid(comp) and isvalid(comp.Entity) then
					local entry = comp:ToSaveEntry()
					if entry ~= nil then
						table.insert(list, entry)
					end
				end
			end
		end
		return self:SafeEncodeJson(list, "[]")
	end

	@ExecSpace("ServerOnly")
	method void ReconstructHomeAnimals(Entity map, string animalsRaw, string ownerUserId)
		-- T19: 세이브 homeAnimals JSON → 가축 스폰 + InitializeFromSave.
		if not isvalid(map) then return end
		if animalsRaw == nil or animalsRaw == "" or animalsRaw == "[]" then return end
		local ok, list = pcall(function() return _HttpService:JSONDecode(animalsRaw) end)
		if not ok or list == nil then
			log_warning("PersistenceManager: homeAnimals decode failed")
			return
		end
		local ads = _DataService:GetTable("AnimalDataSet")
		for _, a in ipairs(list) do
			if type(a) == "table" and a.animalId ~= nil and a.animalId ~= "" then
				local animalId = tostring(a.animalId)
				local modelName = "Animal_" .. animalId
				if ads ~= nil then
					local row = ads:FindRow("AnimalId", animalId)
					if row ~= nil then
						local okM, vM = pcall(function() return row:GetItem("ModelName") end)
						if okM and vM ~= nil and tostring(vM) ~= "" then
							modelName = tostring(vM)
						end
					end
				end
				local modelId = _EntryService:GetModelIdByName(modelName)
				if modelId == nil or modelId == "" then
					log_warning("PersistenceManager: animal model missing " .. modelName)
					continue
				end
				local hx = tonumber(a.x) or tonumber(a.homeX) or 0.0
				local hy = tonumber(a.y) or tonumber(a.homeY) or 0.0
				local penX = math.floor(tonumber(a.penX) or 0)
				local penY = math.floor(tonumber(a.penY) or 0)
				local fedAt = math.floor(tonumber(a.fedAt) or 0)
				local lastProd = math.floor(tonumber(a.lastProduceAt) or 0)
				local produced = a.produced == true
				local spawnPos = Vector3(hx, hy, 0)
				local ent = _SpawnService:SpawnByModelId(modelId, "Animal_" .. animalId .. "_load", spawnPos, map)
				if isvalid(ent) then
					local ac = ent:GetComponent("script.Animal")
					if not isvalid(ac) then
						ent:AddComponent("script.Animal")
						ac = ent:GetComponent("script.Animal")
					end
					if isvalid(ac) then
						ac:InitializeFromSave(animalId, penX, penY, hx, hy, fedAt, lastProd, produced, ownerUserId)
					end
				end
			end
		end
		log("PersistenceManager: homeAnimals reconstructed for " .. tostring(ownerUserId))
	end

	@ExecSpace("ServerOnly")
	method string GetDefaultFurnitureJson(Component inv)
		local furnList = {}
		local map01 = _EntityService:GetEntityByPath("/maps/map01")
		if isvalid(map01) then
			local placeableComps = map01:GetChildComponentsByTypeName("script.PlaceableFurniture", true)
			if placeableComps then
				for _, comp in ipairs(placeableComps) do
					local ent = comp.Entity
					if isvalid(ent) then
						local pos = ent.TransformComponent.WorldPosition
						local fx, fy = math.floor(pos.x), math.floor(pos.y)
						local itemName = comp.ItemId
						if itemName == nil or itemName == "" then
							local name = ent.Name
							if string.sub(name, 1, 10) == "Furniture_" then
								itemName = string.sub(name, 11)
							else
								itemName = name
							end
						end
						local fData = { itemName = itemName, x = fx, y = fy }
						local pg = ent:GetComponent("script.PortalGate")
						if isvalid(pg) then
							fData.targetMapName = pg.TargetMapName
							fData.targetPositionX = pg.TargetPosition.x
							fData.targetPositionY = pg.TargetPosition.y
							fData.destinationGroup = pg.DestinationGroup
							fData.portalColor = pg.PortalColor
						end
						table.insert(furnList, fData)
					end
				end
			end
		end
		
		if #furnList == 0 then
			local ownsPortal = false
			if isvalid(inv) and inv.Items ~= nil and (inv.Items["Portal"] or 0) > 0 then
				ownsPortal = true
			end
			if not ownsPortal then
				table.insert(furnList, {
					itemName = "Portal", x = -3, y = 0, destinationGroup = "town", portalColor = "white",
					targetMapName = "town", targetPositionX = 3, targetPositionY = 0
				})
			end
		end
		return _HttpService:JSONEncode(furnList)
	end

end
