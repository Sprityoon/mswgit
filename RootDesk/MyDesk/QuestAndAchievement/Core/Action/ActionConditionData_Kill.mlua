@Struct
script ActionConditionData_Kill extends ActionConditionData

	-- CondArg = 대상 몬스터 키 (빈 값 = 아무 몬스터). ActionEvent.Args = { monsterKey, count }
	property string Target = ""

	method any Clone()
		return ActionConditionData_Kill()
	end

	method boolean LoadArg(string str)
		self.Target = str or ""
		return true
	end

	method table GetActionEnumList()
		return { _ActionEnum.Kill }
	end

	method boolean Check(Entity userEntity, ActionEvent evt, integer userValue, integer condValue)
		if _Util:IsNilorEmptyString(self.Target) then
			return true
		end
		return evt.Args[1] == self.Target
	end

	method integer GetNextUserValue(Entity userEntity, ActionEvent evt, integer userValue, integer condValue)
		return userValue + (evt.Args[2] or 1)
	end

end
