@Logic
script MonsterSpawner extends Logic

	property integer MonsterCap = 10
	property number SpawnInterval = 10.0
	property any SpawnTimerId = nil

	@HideFromInspector property boolean IsNight = false
	-- T34: SpawnTuningDataSet 1회 캐시 (야간 배율)
	@HideFromInspector property number NightCapMult = 2.0
	@HideFromInspector property number NightHpMult = 1.5
	@HideFromInspector property number NightAtkMult = 1.5
	@HideFromInspector property boolean TuningLoaded = false

	@ExecSpace("ServerOnly")
	method void OnBeginPlay()
		log("MonsterSpawner: Spawner logic system starting...")
		self:TryStartSpawner()
	end

	@ExecSpace("ServerOnly")
	method void LoadSpawnTuning()
		-- SpawnTuningDataSet(Key,Value) 1회 로드. 행 추가만으로 전역 스폰 상수 확장.
		if self.TuningLoaded then return end
		local ds = _DataService:GetTable("SpawnTuningDataSet")
		if ds == nil then return end
		local n = ds:GetRowCount()
		for i = 1, n do
			local key = ds:GetCell(i, "Key") or ""
			local val = tonumber(ds:GetCell(i, "Value"))
			if key == "NightMonsterCapMult" and val ~= nil then
				self.NightCapMult = val
			elseif key == "NightMonsterHpMult" and val ~= nil then
				self.NightHpMult = val
			elseif key == "NightMonsterAtkMult" and val ~= nil then
				self.NightAtkMult = val
			end
		end
		self.TuningLoaded = true
		log("MonsterSpawner: SpawnTuning loaded Cap=" .. tostring(self.NightCapMult)
			.. " Hp=" .. tostring(self.NightHpMult) .. " Atk=" .. tostring(self.NightAtkMult))
	end

	@ExecSpace("ServerOnly")
	method void TryStartSpawner()
		local spawnDs = _DataService:GetTable("MonsterSpawnDataSet")
		if spawnDs == nil then
			log_warning("MonsterSpawner: MonsterSpawnDataSet not found yet. Retrying in 0.5s...")
			_TimerService:SetTimerOnce(function() self:TryStartSpawner() end, 0.5)
			return
		end

		self:LoadSpawnTuning()

		self.SpawnTimerId = _TimerService:SetTimerRepeat(function()
			self:TickMonsterSpawn()
		end, self.SpawnInterval)
		log("MonsterSpawner: System initialized successfully.")
	end

	@ExecSpace("ServerOnly")
	method void OnEndPlay()
		if self.SpawnTimerId then
			_TimerService:ClearTimer(self.SpawnTimerId)
			self.SpawnTimerId = nil
		end
	end

	@ExecSpace("ServerOnly")
	method void TickMonsterSpawn()
		local mapNames = _DynamicMapService:GetDynamicMapNameList()
		if not mapNames then return end

		-- Day/Night Cycle calculated by PersistenceManager
		if _PersistenceManager then
			self.IsNight = _PersistenceManager:IsNight()
		else
			-- Fallback in case PersistenceManager is not initialized yet
			local time = _UtilLogic.ServerElapsedSeconds % 600
			self.IsNight = (time >= 300)
		end

		for _, mapName in ipairs(mapNames) do
			local map = _EntityService:GetEntityByPath("/maps/" .. mapName)
			if isvalid(map) then
				self:SpawnMonstersForMap(map)
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void SpawnMonstersForMap(Entity map)
		-- Spawns combat monster variants into a hunting-ground map up to the population cap.
		-- Personal estates are peaceful (single green_island biome) per the 2026-06 concept
		-- shift (game_design.md §2.2/§3.4): combat spawning is skipped entirely so estates only
		-- ever host passive creatures. The per-cell green_island guard below stays as
		-- defense-in-depth for future hunting maps that mix a green_island sub-region.
		local mapName = map.Name

		-- Estate guard: a map whose force-biome is "green_island" is a single-biome peaceful
		-- estate (per-map; hunting maps set it to "" for multi-biome and do spawn combat).
		local rs = _ResourceSpawner
		if rs ~= nil and rs:GetMapForceBiomeId(mapName) == "green_island" then
			return
		end

		local monsters = map:GetChildComponentsByTypeName("script.Monster", true)
		
		-- Count active (not dead) monsters
		local activeCount = 0
		if monsters then
			for _, m in ipairs(monsters) do
				if isvalid(m) and not m.IsDead then
					activeCount = activeCount + 1
				end
			end
		end

		if not self.TuningLoaded then
			self:LoadSpawnTuning()
		end

		local effectiveCap = self.IsNight and (self.MonsterCap * self.NightCapMult) or self.MonsterCap

		if activeCount >= effectiveCap then
			return
		end

		local toSpawn = math.floor(effectiveCap - activeCount)
		if toSpawn < 1 then return end
		log("MonsterSpawner: Map " .. mapName .. " needs " .. toSpawn .. " monster(s). Active: " .. activeCount .. " (IsNight: " .. tostring(self.IsNight) .. ")")

		local spawnDs = _DataService:GetTable("MonsterSpawnDataSet")
		if spawnDs == nil then return end

		local resourceSpawner = _ResourceSpawner
		if resourceSpawner == nil then return end

		-- 경계 Big Wall 밴드(외곽 WallThickness겹) 안쪽 플레이어블 영역에만 스폰한다.
		local radius = (resourceSpawner.MapRadius or 75) - (resourceSpawner.WallThickness or 3)
		local gridToEntity = resourceSpawner:GetGridToEntity(mapName)

		-- Selectable biomes list from DataSet
		local biomeConfigs = {}
		local totalRows = spawnDs:GetRowCount()
		for i = 1, totalRows do
			local bid = spawnDs:GetCell(i, "BiomeId")
			local mid = spawnDs:GetCell(i, "MonsterModelId")
			local weight = tonumber(spawnDs:GetCell(i, "SpawnWeight")) or 100
			local hpMul = tonumber(spawnDs:GetCell(i, "HpMultiplier")) or 1.0
			local atkMul = tonumber(spawnDs:GetCell(i, "AtkMultiplier")) or 1.0
			
			if bid ~= nil and bid ~= "" then
				if biomeConfigs[bid] == nil then biomeConfigs[bid] = {} end
				table.insert(biomeConfigs[bid], {
					modelId = mid,
					weight = weight,
					hpMul = hpMul,
					atkMul = atkMul
				})
			end
		end

		-- Spawn attempt loop
		for s = 1, toSpawn do
			local spawnedOk = false
			-- Maximum 30 location search attempts per spawn
			for attempt = 1, 30 do
				local rx = math.random(-radius, radius)
				local ry = math.random(-radius, radius)

				local biomeId = resourceSpawner:GetBiomeAt(mapName, rx, ry)
				
				-- Safe Zone filtering (no spawn in green_island)
				if biomeId ~= "green_island" and biomeConfigs[biomeId] ~= nil then
					local gridKey = rx .. "_" .. ry
					-- Occupancy check
					if gridToEntity[gridKey] == nil then
						-- Player proximity check: spawn kills prevention
						local playerOk = true
						local users = _UserService:GetUsersByMapComponent(map.MapComponent)
						if users then
							for _, user in ipairs(users) do
								if isvalid(user) then
									local up = user.TransformComponent.WorldPosition
									local distSq = (up.x - (rx + 0.5))^2 + (up.y - (ry + 0.5))^2
									if distSq < 16.0 then -- 4.0 blocks radius
										playerOk = false
										break
									end
								end
							end
						end

						if playerOk then
							-- Biome configuration match found
							local options = biomeConfigs[biomeId]
							if #options > 0 then
								-- Weighted selection
								local totalWeight = 0
								for _, opt in ipairs(options) do
									totalWeight = totalWeight + opt.weight
								end
								
								local roll = math.random(1, totalWeight)
								local runningSum = 0
								local chosenOpt = options[1]
								for _, opt in ipairs(options) do
									runningSum = runningSum + opt.weight
									if roll <= runningSum then
										chosenOpt = opt
										break
									end
								end

								local modelId = _EntryService:GetModelIdByName(chosenOpt.modelId)
								if not modelId or modelId == "" then
									modelId = chosenOpt.modelId -- Fallback to direct modelId string
								end

								local spawnPos = Vector3(rx + 0.5, ry + 0.5, 0)
								-- Entity.Name = display/debug only; data keys use MonsterId (model id slug).
								local entityName = chosenOpt.modelId .. "_" .. biomeId
								local spawnedMonster = _SpawnService:SpawnByModelId(
									modelId,
									entityName,
									spawnPos,
									map
								)

								if isvalid(spawnedMonster) then
									-- Attach & tune Monster script properties
									local mComp = spawnedMonster:GetComponent("script.Monster")
									if isvalid(mComp) then
										-- Stable data key for coin/ItemDrop/Kill (not Entity.Name)
										mComp.MonsterId = chosenOpt.modelId
										local nightHp = self.IsNight and self.NightHpMult or 1.0
										local finalHpMul = chosenOpt.hpMul * nightHp
										mComp.MaxHp = mComp.MaxHp * finalHpMul
										mComp.Hp = mComp.MaxHp
									end

									-- Tune attack damage
									local atkComp = spawnedMonster:GetComponent("script.MonsterMeleeAttack")
									if isvalid(atkComp) then
										local nightAtk = self.IsNight and self.NightAtkMult or 1.0
										local finalAtkMul = chosenOpt.atkMul * nightAtk
										atkComp.ContactDamage = atkComp.ContactDamage * finalAtkMul
									end

									-- Set initial AI anchor pos to avoid leashing bugs
									local aiComp = spawnedMonster:GetComponent("script.MonsterAI")
									if isvalid(aiComp) then
										aiComp.SpawnPos = Vector2(rx + 0.5, ry + 0.5)
									end

									-- Tint from BiomeDataSet.MonsterTint (#RRGGBB; blank = white)
									local sprite = spawnedMonster.SpriteRendererComponent
									if isvalid(sprite) then
										sprite.IgnoreMapLayerCheck = true
										sprite.SortingLayer = _RenderLayers.EntityLayer
										sprite.OrderInLayer = math.max(_RenderLayers.MinEntityOrder, math.floor((radius - ry) * 100))
										local tint = Color(1.0, 1.0, 1.0, 1.0)
										if isvalid(resourceSpawner) then
											local hex = resourceSpawner:GetBiomeMonsterTintHex(biomeId)
											if hex ~= nil and hex ~= "" then
												local parsed = resourceSpawner:ParseHexColor(hex)
												if parsed ~= nil then tint = parsed end
											end
										end
										sprite.Color = tint
									end

									log("[SPAWN] Spawned variant monster " .. chosenOpt.modelId .. " at cell (" .. rx .. ", " .. ry .. ") in map " .. mapName .. " (HpMul=" .. chosenOpt.hpMul .. ", AtkMul=" .. chosenOpt.atkMul .. ")")
									spawnedOk = true
									break
								end
							end
						end
					end
				end
			end
			-- If one spawn succeeds, yield or let loop continue
			if not spawnedOk then
				-- Optimization: if failed to find a spot after 30 checks, break the spawn loop for this tick
				break
			end
		end
	end

end
