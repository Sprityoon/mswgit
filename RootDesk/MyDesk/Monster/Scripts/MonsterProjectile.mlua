@Component
script MonsterProjectile extends AttackComponent
	-- T39: 몬스터 원거리 공격 투사체. Body 없이 Transform Translate로 비행하며,
	-- 플레이어 HitBox에 근접하면 AttackFast로 정식 HitEvent를 발행하고 소멸한다.
	-- 데미지/속도/사거리는 Fire 인자로 주입(모델 프로퍼티 아님 — 스폰 시점 결정).

	property Entity Owner = nil
	property Vector2 Direction = Vector2(1, 0)
	property number Speed = 5.0
	property number LifeTime = 3.0
	property number HitRadius = 0.5
	property integer ProjectileDamage = 5
	property number ElapsedTime = 0.0
	property boolean Fired = false

	@ExecSpace("ServerOnly")
	method void Fire(Entity owner, Vector2 dir, integer dmg, number speed, number hitRadius, number lifeTime)
		-- 발사: 방향 정규화 + 데미지/속도 세팅 후 비행 시작.
		self.Owner = owner
		if dir:Magnitude() <= 0.0001 then
			self.Direction = Vector2(1, 0)
		else
			self.Direction = dir:Normalize()
		end
		self.ProjectileDamage = dmg
		self.Speed = speed
		if hitRadius > 0 then self.HitRadius = hitRadius end
		if lifeTime > 0 then self.LifeTime = lifeTime end
		self.ElapsedTime = 0.0
		self.Fired = true
	end

	@ExecSpace("ServerOnly")
	method void OnUpdate(number delta)
		if not self.Fired then return end

		self.ElapsedTime = self.ElapsedTime + delta
		if self.ElapsedTime >= self.LifeTime then
			self.Entity:Destroy()
			return
		end

		local transform = self.Entity.TransformComponent
		if not isvalid(transform) then return end
		local pos = transform.WorldPosition
		transform.WorldPosition = pos + Vector3(self.Direction.x * self.Speed * delta, self.Direction.y * self.Speed * delta, 0)

		-- 플레이어 HitBox 근접 판정 (Body 없는 투사체 → 시뫤레이터 Overlap).
		local myPos2D = transform.WorldPosition:ToVector2()
		local sim = _CollisionService:GetSimulator(self.Entity)
		if not sim then return end
		local shape = CircleShape(myPos2D, self.HitRadius)
		local overlaps = sim:OverlapAll({ CollisionGroups.HitBox }, shape)
		if overlaps and #overlaps > 0 then
			for _, hb in ipairs(overlaps) do
				local target = hb.Entity
				if isvalid(target) and target ~= self.Owner and isvalid(target.PlayerComponent) then
					-- 정식 히트 파이프라인(데미지 스킨/i-frame/덄백 훅) 경유.
					self:AttackFast(shape, "projectile", CollisionGroups.HitBox)
					self.Entity:Destroy()
					return
				end
			end
		end
	end

	method integer CalcDamage(Entity attacker, Entity defender, string attackInfo)
		-- attackInfo="projectile" — 이름 분기 아님(태깅 규약). @ExecSpace 금지(LEA-3014).
		return math.floor(self.ProjectileDamage)
	end

	method boolean IsAttackTarget(Entity defender, string attackInfo)
		-- 플레이어에게만 명중.
		if isvalid(defender.PlayerComponent) == false then return false end
		return __base:IsAttackTarget(defender, attackInfo)
	end

end
