@Component
script itemreact extends Component

	@Sync
	property string ItemName = "Dirt"

	@Sync
	property boolean IsNaturalSpawn = false

	@Sync
	property string NaturalSpawnModelId = ""

	property number ElapsedTime = 0

	property Vector3 BasePosition = Vector3(0,0,0)

	property boolean IsCollected = false

	property Vector3 Velocity = Vector3(0,0,0)

	property number ScatterTime = 0.0

	property number PickupGrace = 0.0

	@ExecSpace("ServerOnly")
	method void SetPickupGrace(number seconds)
		-- Suppresses magnet pickup for the given seconds (used by discard-drop so the dropper
		-- can step away before the item is re-collected).
		self.PickupGrace = seconds
	end

	method void OnBeginPlay()
		-- description: Initializes the item drop entity.
		if self:IsClient() then
			self:ApplyRarityVisuals()
		else
			-- 서버에서는 물리 속성을 초기화합니다.
			self.BasePosition = self.Entity.TransformComponent.WorldPosition
			self.ElapsedTime = math.random() * 10 -- Randomize start phase for sine wave float
			self.IsCollected = false
		end
	end

	@ExecSpace("ClientOnly")
	method void OnSyncProperty(string name, any value)
		-- description: Handles property synchronization. Applies rarity visual tint when ItemName is synced.
		if name == "ItemName" then
			self:ApplyRarityVisuals()
		end
	end

	@ExecSpace("ClientOnly")
	method void ApplyRarityVisuals()
		-- description: Queries item_dataset to get the item rarity and applies a soft tint color to the SpriteRenderer.
		local ds = _DataService:GetTable("item_dataset")
		if ds == nil then return end
		local row = ds:FindRow("Name", self.ItemName)
		if row == nil then return end
		local rarity = row:GetItem("Rarity") or "Common"
		
		local color = Color.white
		if rarity == "Uncommon" then
			color = Color(0.6, 1.0, 0.6, 1.0)
		elseif rarity == "Rare" then
			color = Color(0.6, 0.8, 1.0, 1.0)
		elseif rarity == "Epic" then
			color = Color(0.8, 0.6, 1.0, 1.0)
		elseif rarity == "Legendary" then
			color = Color(1.0, 0.8, 0.5, 1.0)
		end
		
		if isvalid(self.Entity.SpriteRendererComponent) then
			self.Entity.SpriteRendererComponent.Color = color
		end
	end

	@ExecSpace("ServerOnly")
	method void Init(string name)
		self.ItemName = name
		
		-- Scatter effect initialization
		-- Generate a random angle in the upper semi-circle (30 to 150 degrees) for natural upward/sideways spread
		local minAngle = math.pi * 0.15 -- ~27 degrees
		local maxAngle = math.pi * 0.85 -- ~153 degrees
		local angle = minAngle + math.random() * (maxAngle - minAngle)
		local speed = 1.2 + math.random() * 1.6
		
		self.Velocity = Vector3(math.cos(angle) * speed, math.sin(angle) * speed * 2.2, 0)
		self.ScatterTime = 0.55 + math.random() * 0.15
		self.BasePosition = self.Entity.TransformComponent.WorldPosition
	end

	@ExecSpace("ServerOnly")
	method void OnUpdate(number delta)
		if self.IsCollected then return end

		self.ElapsedTime = self.ElapsedTime + delta

		if self.PickupGrace > 0 then
			self.PickupGrace = self.PickupGrace - delta
		end

		local transform = self.Entity.TransformComponent
		if not isvalid(transform) then return end

		-- 1. Apply scatter velocity if ScatterTime > 0
		if self.ScatterTime > 0 then
			self.ScatterTime = self.ScatterTime - delta
			-- Apply gravity to vertical velocity
			self.Velocity.y = self.Velocity.y - 9.8 * delta
			-- Update base position based on velocity
			self.BasePosition = self.BasePosition + self.Velocity * delta
			
			if self.ScatterTime <= 0 then
				self.Velocity = Vector3(0, 0, 0)
			end
		end

		-- 2. Apply floating visual offset (sine wave) after scatter is done
		local floatOffset = 0
		if self.ScatterTime <= 0 then
			floatOffset = math.sin(self.ElapsedTime * 3.0) * 0.15
		end
		transform.WorldPosition = Vector3(self.BasePosition.x, self.BasePosition.y + floatOffset, self.BasePosition.z)

		-- Don't start pull or pickup check until scattering is completed
		if self.ScatterTime > 0 then
			return
		end

		-- Discard-drop grace: stay on the ground (no magnet) until the grace window elapses.
		if self.PickupGrace > 0 then
			return
		end

		-- 3. Detect nearby players (or their pets — T23) for pickup. PickupGrace already enforced above.
		local mapComp = self.Entity.CurrentMap.MapComponent
		if not isvalid(mapComp) then return end

		local users = _UserService:GetUsersByMapComponent(mapComp)
		if not users then return end
		
		local closestPlayer = nil
		local magnetPos = nil
		local minDistance = 2.0 -- player magnet range (2.0 units)
		
		for _, user in ipairs(users) do
			if isvalid(user) then
				local playerPos = user.TransformComponent.WorldPosition
				local dist = Vector2.Distance(Vector2(self.BasePosition.x, self.BasePosition.y), Vector2(playerPos.x, playerPos.y))
				if dist < minDistance then
					closestPlayer = user
					magnetPos = playerPos
					minDistance = dist
				end
			end
		end

		-- T23: 펫 위치 기준 자석 — 소유 플레이어에게 Collect. PickupGrace·소유권 규칙 유지.
		local pets = self.Entity.CurrentMap:GetChildComponentsByTypeName("script.Pet", true)
		if pets ~= nil then
			for _, pet in ipairs(pets) do
				if isvalid(pet) and isvalid(pet.Entity) then
					local range = tonumber(pet.PickupRange) or 2.5
					local petPos = pet.Entity.TransformComponent.WorldPosition
					local dist = Vector2.Distance(Vector2(self.BasePosition.x, self.BasePosition.y), Vector2(petPos.x, petPos.y))
					if dist < range and dist < minDistance then
						local ownerId = pet.OwnerUserId or ""
						local owner = nil
						if ownerId ~= "" then
							owner = _UserService:GetUserEntityByUserId(ownerId)
						end
						if isvalid(owner) and owner.CurrentMap == self.Entity.CurrentMap then
							closestPlayer = owner
							magnetPos = petPos
							minDistance = dist
						end
					end
				end
			end
		end
		
		-- 4. Magnet Pull and Pickup
		if closestPlayer and magnetPos ~= nil then
			local dx = magnetPos.x - transform.WorldPosition.x
			local dy = magnetPos.y - transform.WorldPosition.y
			local dist = math.sqrt(dx * dx + dy * dy)
			if dist > 0.01 then
				local dirX = dx / dist
				local dirY = dy / dist
				self.BasePosition = self.BasePosition + Vector3(dirX, dirY, 0) * delta * 4.5
			end
		
			if minDistance < 0.4 then
				self.IsCollected = true
				self:Collect(closestPlayer)
			end
		end
	end

	@ExecSpace("ServerOnly")
	method void Collect(Entity player)
		log("Collecting item: " .. self.ItemName .. " for player " .. player.Name)
		
		---@type PlayerInventory
		local inventory = player:GetComponent("script.PlayerInventory")
		if isvalid(inventory) then
			inventory:AddItem(self.ItemName, 1)

			-- 업적/퀘스트 진행: 아이템 획득 액션 발행
			if _ActionSignals ~= nil then
				_ActionSignals:EmitToPlayer(player, _ActionEnum.Gather, self.ItemName, 1)
			end

			-- 자연 생성된 돌 주변 아이템인 경우, 획득 완료 상태를 ResourceSpawner에 등록해 무한 파밍 방지
			if self.IsNaturalSpawn and _ResourceSpawner then
				local mapName = self.Entity.CurrentMap.Name
				local pos = self.Entity.TransformComponent.WorldPosition
				local x = math.floor(pos.x)
				local y = math.floor(pos.y)
				_ResourceSpawner:RegisterDestroyedResource(mapName, "AroundItem_Stone", self.NaturalSpawnModelId, x, y)
			end
		else
			log_warning("Player " .. player.Name .. " does not have a PlayerInventory component.")
		end
		
		-- Destroy the item drop entity
		self.Entity:Destroy()
	end

end
