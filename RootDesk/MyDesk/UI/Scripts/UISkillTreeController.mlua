@Component
script UISkillTreeController extends Component

	-- SkillTreePopup: SkillDataSet의 TreeRow/TreeCol 좌표로 노드를 배치하고 노드 4상태
	-- (잠김 / 목표 진행 중 / 해금 가능 / 보유)를 렌더링한다. (docs/design/skill-tree-plan.md §2 UI)
	-- T45: 보유 스킬 선택 → QWER 장착 버튼 + 현재 장착 슬롯 표시.

	property Entity btnClose = "da9d3a55-39ec-42c3-8e38-14c714c3cf71"

	property Entity spText = "4e3d8f52-1eec-4615-8d8d-2b68360f4b6b"

	property Entity equipDetailText = "de497519-cec6-4f98-b1b8-1bc8f15b572e"
	property ButtonComponent btnEquipQ = "ad27c86b-d307-4ce1-99cb-92e8dd5685b3"
	property ButtonComponent btnEquipW = "cc23b1a5-be5c-4772-8ca1-01bc64033a6b"
	property ButtonComponent btnEquipE = "3deee177-323d-49b5-9c3d-ff5fbde0eea7"
	property ButtonComponent btnEquipR = "61e8acd4-707c-4da1-8a43-a9457da438c0"

	property integer MaxRows = 4

	property integer MaxCols = 3

	property any closeHandler = nil

	property table nodeHandlers = {}
	property table equipHandlers = {}

	-- "row_col" -> skillId (Refresh 시 CSV 기준으로 재구성)
	property table nodeSkillMap = {}

	property string selectedSkillId = ""

	property number RefreshAccum = 0.0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		self.Entity.Enable = false
		self:ResolveEquipRefs()

		if isvalid(self.btnClose) then
			self.closeHandler = self.btnClose:ConnectEvent(ButtonClickEvent, self.OnCloseClicked)
		end

		self:SetupNodeEvents()
		self:SetupEquipButtons()
	end

	@ExecSpace("ClientOnly")
	method void ResolveEquipRefs()
		-- 경로 해석으로 장착 바 자식 확보 (UUID 폴백).
		self._T.detailTextE = self.Entity:GetChildByName("DetailText", true)
		self._T.btnQE = self.Entity:GetChildByName("BtnQ", true)
		self._T.btnWE = self.Entity:GetChildByName("BtnW", true)
		self._T.btnEE = self.Entity:GetChildByName("BtnE", true)
		self._T.btnRE = self.Entity:GetChildByName("BtnR", true)
	end

	@ExecSpace("ClientOnly")
	method void OnEndPlay()
		if self.closeHandler and isvalid(self.btnClose) then
			self.btnClose:DisconnectEvent(ButtonClickEvent, self.closeHandler)
		end
		for ent, clickHandler in pairs(self.nodeHandlers) do
			if isvalid(ent) then
				ent:DisconnectEvent(ButtonClickEvent, clickHandler)
			end
		end
		self.nodeHandlers = {}
		for ent, h in pairs(self.equipHandlers) do
			if isvalid(ent) then
				ent:DisconnectEvent(ButtonClickEvent, h)
			end
		end
		self.equipHandlers = {}
	end

	@ExecSpace("ClientOnly")
	method void Toggle()
		if self.Entity.Enable then
			self:Close()
		else
			self:Open()
		end
	end

	@ExecSpace("ClientOnly")
	method void Open()
		self.Entity.Enable = true
		self:ResolveEquipRefs()
		self:Refresh()
	end

	@ExecSpace("ClientOnly")
	method void Close()
		self.Entity.Enable = false
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		-- 열려 있는 동안 0.25초 주기로 갱신 (SP/업적 진행도 실시간 반영)
		if not self.Entity.Enable then return end
		self.RefreshAccum = self.RefreshAccum + delta
		if self.RefreshAccum < 0.25 then return end
		self.RefreshAccum = 0.0
		self:Refresh()
	end

	method any GetLocalPlayerController()
		local lp = _UserService.LocalPlayer
		if not isvalid(lp) then return nil end
		local pc = lp:GetComponent("script.PlayerController")
		if not isvalid(pc) then return nil end
		return pc
	end

	@ExecSpace("ClientOnly")
	method void SetupNodeEvents()
		for r = 1, self.MaxRows do
			for c = 1, self.MaxCols do
				local node = self.Entity:GetChildByName("Node_" .. r .. "_" .. c, true)
				if isvalid(node) then
					local key = r .. "_" .. c
					local clickHandler = node:ConnectEvent(ButtonClickEvent, function()
						self:OnNodeClicked(key)
					end)
					self.nodeHandlers[node] = clickHandler
				end
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void SetupEquipButtons()
		-- T45: QWER 장착 버튼.
		local pairs_ = {
			{ ent = self._T.btnQE, slot = 1 },
			{ ent = self._T.btnWE, slot = 2 },
			{ ent = self._T.btnEE, slot = 3 },
			{ ent = self._T.btnRE, slot = 4 },
		}
		for _, p in ipairs(pairs_) do
			if isvalid(p.ent) then
				local slotIdx = p.slot
				local h = p.ent:ConnectEvent(ButtonClickEvent, function()
					self:OnEquipSlotClicked(slotIdx)
				end)
				self.equipHandlers[p.ent] = h
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void OnNodeClicked(string key)
		-- 노드 클릭: 선택 + 해금/레벨업 요청 (서버 검증).
		local skillId = self.nodeSkillMap[key]
		if skillId == nil or skillId == "" then return end

		self.selectedSkillId = skillId
		self:RefreshEquipDetail()

		local pc = self:GetLocalPlayerController()
		if pc == nil then return end
		---@type PlayerController
		local controller = pc
		controller:ServerRequestSkillLevelUp(skillId)
	end

	@ExecSpace("ClientOnly")
	method void OnEquipSlotClicked(integer slotIndex)
		-- 선택 스킬을 해당 슬롯에 장착. 이미 그 슬롯이면 해제.
		if self.selectedSkillId == nil or self.selectedSkillId == "" then return end
		local pc = self:GetLocalPlayerController()
		if pc == nil then return end
		---@type PlayerController
		local controller = pc
		if controller:GetSkillLevel(self.selectedSkillId) < 1 then return end

		local slots = controller:GetEquippedSlots()
		local equipId = self.selectedSkillId
		if slots[slotIndex] == equipId then
			equipId = ""
		end
		controller:ServerRequestEquipSkill(slotIndex, equipId)
		self:RefreshEquipDetail()
	end

	@ExecSpace("ClientOnly")
	method void RefreshEquipDetail()
		-- 선택 스킬 + 현재 장착 슬롯 표시, QWER 버튼 하이라이트.
		local detailE = self._T.detailTextE
		if not isvalid(detailE) then detailE = self.equipDetailText end
		local pc = self:GetLocalPlayerController()
		local sid = self.selectedSkillId or ""
		local name = sid
		local level = 0
		local isPassive = false
		local equipKeys = ""
		local slots = { "", "", "", "" }
		if pc ~= nil then
			---@type PlayerController
			local controller = pc
			slots = controller:GetEquippedSlots()
			if sid ~= "" then
				level = controller:GetSkillLevel(sid)
			end
		end
		local ds = _DataService:GetTable("SkillDataSet")
		if sid ~= "" and ds ~= nil then
			local row = ds:FindRow("SkillId", sid)
			if row ~= nil then
				name = row:GetItem("Name") or sid
				isPassive = (row:GetItem("Type") or "") == "Passive"
			end
		end
		local keyNames = { "Q", "W", "E", "R" }
		for i = 1, 4 do
			if slots[i] == sid and sid ~= "" then
				if equipKeys ~= "" then equipKeys = equipKeys .. "," end
				equipKeys = equipKeys .. keyNames[i]
			end
		end

		local line = "스킬을 선택하세요"
		if sid ~= "" then
			if level < 1 then
				line = name .. " (미해금)"
			elseif isPassive then
				line = name .. " Lv." .. tostring(level) .. " · 패시브(장착 불가)"
			elseif equipKeys ~= "" then
				line = name .. " · 장착: " .. equipKeys
			else
				line = name .. " · 미장착 (QWER 클릭)"
			end
		end
		if isvalid(detailE) and isvalid(detailE.TextComponent) then
			detailE.TextComponent.Text = line
		end

		-- 버튼 하이라이트: 선택 스킬이 장착된 슬롯 = 골드
		local selBg = Color(0.94, 0.66, 0.19, 1.0)
		local idleBg = Color(0.18, 0.20, 0.16, 1.0)
		local selText = Color(0.15, 0.12, 0.08, 1.0)
		local idleText = Color(0.79, 0.75, 0.70, 1.0)
		local btnEnts = { self._T.btnQE, self._T.btnWE, self._T.btnEE, self._T.btnRE }
		for i = 1, 4 do
			local be = btnEnts[i]
			if isvalid(be) then
				local on = (sid ~= "" and slots[i] == sid)
				local spr = be.SpriteGUIRendererComponent
				if isvalid(spr) then
					if on then spr.Color = selBg else spr.Color = idleBg end
				end
				local txt = be.TextComponent
				if isvalid(txt) then
					if on then txt.FontColor = selText else txt.FontColor = idleText end
				end
			end
		end
	end

	@ExecSpace("ClientOnly")
	method boolean IsAchievementDoneClient(integer achId)
		-- 서버 IsUnlockAchievementSatisfied의 표시용 클라 미러 (UserDataTable은 @Sync로 내려옴)
		local lp = _UserService.LocalPlayer
		if not isvalid(lp) then return false end
		local pa = lp.PlayerAchievement
		if pa == nil then return false end

		local data = _AchievementDataSetLogic:GetData(achId)
		if data == nil then return false end

		local userData = pa.UserDataTable[achId]
		if userData == nil then return false end

		if userData.State == _AchievementStateEnum.Completed then return true end
		if not userData:IsCompletable(data) then return false end
		return data:GetStepData(userData.Step + 1) == nil
	end

	@ExecSpace("ClientOnly")
	method number GetAchievementPctClient(integer achId)
		-- 현재 스텝 진행률 0.0~1.0 (표시용)
		local lp = _UserService.LocalPlayer
		if not isvalid(lp) then return 0.0 end
		local pa = lp.PlayerAchievement
		if pa == nil then return 0.0 end

		local data = _AchievementDataSetLogic:GetData(achId)
		if data == nil then return 0.0 end

		local userData = pa.UserDataTable[achId]
		if userData == nil then return 0.0 end

		local stepData = data.StepDatas[userData.Step]
		if stepData == nil or stepData.Value <= 0 then return 1.0 end

		return math.min(1.0, userData.Value / stepData.Value)
	end

	@ExecSpace("ClientOnly")
	method void SetNodeVisual(Entity node, Color bgColor, string nameStr, string lvStr, string subStr, string iconRuid, boolean dimIcon)
		if isvalid(node.SpriteGUIRendererComponent) then
			node.SpriteGUIRendererComponent.Color = bgColor
		end
		local nameEnt = node:GetChildByName("NameText")
		if isvalid(nameEnt) and isvalid(nameEnt.TextComponent) then
			nameEnt.TextComponent.Text = nameStr
		end
		local lvEnt = node:GetChildByName("LvText")
		if isvalid(lvEnt) and isvalid(lvEnt.TextComponent) then
			lvEnt.TextComponent.Text = lvStr
		end
		local subEnt = node:GetChildByName("SubText")
		if isvalid(subEnt) and isvalid(subEnt.TextComponent) then
			subEnt.TextComponent.Text = subStr
		end
		-- T46: IconRUID (공란이면 숨김)
		local iconEnt = node:GetChildByName("Icon")
		if isvalid(iconEnt) then
			local ispr = iconEnt.SpriteGUIRendererComponent
			if isvalid(ispr) and iconRuid ~= nil and iconRuid ~= "" then
				iconEnt.Enable = true
				ispr.ImageRUID = iconRuid
				if dimIcon then
					ispr.Color = Color(0.25, 0.25, 0.28, 1.0)
				else
					ispr.Color = Color(1, 1, 1, 1)
				end
			else
				iconEnt.Enable = false
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void Refresh()
		local pc = self:GetLocalPlayerController()
		if pc == nil then return end
		---@type PlayerController
		local controller = pc

		if isvalid(self.spText) and isvalid(self.spText.TextComponent) then
			self.spText.TextComponent.Text = "SP " .. controller.SP .. "  |  Lv " .. controller.Level
		end

		-- 모든 노드 슬롯을 일단 숨김 — CSV에 좌표가 있는 스킬만 다시 켠다
		self.nodeSkillMap = {}
		for r = 1, self.MaxRows do
			for c = 1, self.MaxCols do
				local node = self.Entity:GetChildByName("Node_" .. r .. "_" .. c, true)
				if isvalid(node) then
					node.Enable = false
				end
			end
		end

		local ds = _DataService:GetTable("SkillDataSet")
		if ds == nil then return end

		local rowCount = ds:GetRowCount()
		for i = 1, rowCount do
			local skillId = ds:GetCell(i, "SkillId")
			local treeRow = tonumber(ds:GetCell(i, "TreeRow")) or 0
			local treeCol = tonumber(ds:GetCell(i, "TreeCol")) or 0

			if skillId ~= nil and skillId ~= "" and treeRow >= 1 and treeRow <= self.MaxRows
				and treeCol >= 1 and treeCol <= self.MaxCols then
				local node = self.Entity:GetChildByName("Node_" .. treeRow .. "_" .. treeCol, true)
				if isvalid(node) then
					node.Enable = true
					self.nodeSkillMap[treeRow .. "_" .. treeCol] = skillId
					self:RefreshNode(node, ds, i, skillId, controller)
				end
			end
		end

		self:RefreshEquipDetail()
	end

	@ExecSpace("ClientOnly")
	method void RefreshNode(Entity node, any ds, integer rowIndex, string skillId, any pc)
		---@type PlayerController
		local controller = pc

		local skillName = ds:GetCell(rowIndex, "Name") or skillId
		local maxLevel = tonumber(ds:GetCell(rowIndex, "MaxLevel")) or 1
		local spCost = tonumber(ds:GetCell(rowIndex, "SPCost")) or 1
		local parentId = ds:GetCell(rowIndex, "ParentSkillId")
		local reqLevel = tonumber(ds:GetCell(rowIndex, "RequiredLevel")) or 1
		local achId = tonumber(ds:GetCell(rowIndex, "UnlockAchievementId"))
		local iconRuid = ds:GetCell(rowIndex, "IconRUID") or ""

		local level = controller:GetSkillLevel(skillId)
		local selected = (self.selectedSkillId == skillId)

		if level >= 1 then
			-- 보유: 파랑(선택 시 골드 테두리 톤). 강화 가능 여부를 서브텍스트로.
			local sub = "MAX"
			if level < maxLevel then
				sub = "강화: SP " .. spCost
			end
			local bg = Color(0.16, 0.32, 0.55, 1.0)
			if selected then bg = Color(0.28, 0.42, 0.62, 1.0) end
			self:SetNodeVisual(node, bg, skillName, "Lv." .. level .. "/" .. maxLevel, sub, iconRuid, false)
			return
		end

		local parentOk = (parentId == nil or parentId == "" or controller:GetSkillLevel(parentId) >= 1)
		local levelOk = (controller.Level >= reqLevel)
		local achOk = (achId == nil or achId <= 0 or self:IsAchievementDoneClient(achId))

		if parentOk and levelOk and achOk then
			-- 해금 가능: 초록
			self:SetNodeVisual(node, Color(0.15, 0.45, 0.22, 1.0), skillName, "해금 가능", "해금: SP " .. spCost, iconRuid, false)
		elseif parentOk and levelOk and not achOk then
			-- 목표(업적) 진행 중: 주황 + 진행도 %
			local pct = math.floor(self:GetAchievementPctClient(achId) * 100)
			self:SetNodeVisual(node, Color(0.55, 0.38, 0.12, 1.0), skillName, "목표 진행 중", "진행도 " .. pct .. "%", iconRuid, true)
		else
			-- 잠김: 회색 + 사유
			local reason = ""
			if not parentOk then
				reason = "선행 스킬 필요"
			elseif not levelOk then
				reason = "Lv." .. reqLevel .. " 필요"
			end
			self:SetNodeVisual(node, Color(0.22, 0.22, 0.26, 1.0), skillName, "잠김", reason, iconRuid, true)
		end
	end

	@ExecSpace("ClientOnly")
	method void OnCloseClicked(ButtonClickEvent event)
		self:Close()
	end

end
