@Component
script UICraftingController extends Component

	property Entity craftingPopup = "ec3aa4ff-fb85-423f-9b57-a47e502af4c8"

	property ButtonComponent btnClose = "7b022360-a0b1-4187-b688-894dfab91aa0"

	property Entity recipeList = "e4e191a3-504a-48bc-8f77-eaf1c1cf6b49"

	property Entity recipeTemplate = "88533105-c6c6-4a5a-bd9a-d14315027775"

	property TextComponent detailName = "787a348a-96df-482d-a5c4-05f7c7fdb711"

	property TextComponent detailDesc = "d70d0810-df90-4a69-8228-bf0af8160675"

	property SpriteGUIRendererComponent detailIcon = "36f298bf-f4dd-4c72-91d6-50c02e7306ba"

	property Entity ingSlot1 = "8bc9ca06-d678-4aaf-abb8-3736dbd03a0b"

	property SpriteGUIRendererComponent ingIcon1 = "9a1e28f5-8035-48f2-840a-0dff019eb05f"

	property TextComponent ingCount1 = "187340dd-39ca-4dcc-b4c4-d3bf716b5e21"

	property Entity ingSlot2 = "127bdf4f-8397-40db-8ac3-95cd22aa6abf"

	property SpriteGUIRendererComponent ingIcon2 = "e72c1e6d-b8b5-496c-aadd-25e5c37b11d0"

	property TextComponent ingCount2 = "8dbcf786-4ae1-4bea-88aa-da36be44e131"

	property ButtonComponent btnCraft = "7a2ffe94-43c4-4857-8915-64bdf3c18993"

	-- T26: 탭/칩 행 템플릿 + 바 컨테이너 (순환 화살표 제거)
	property Entity tierBar = "72a5144a-0f53-48bc-93b9-6dd0e97cb372"

	property Entity tierChipTemplate = "c30bf3f6-2d01-4f2d-a575-e2da2e9a70fa"

	property Entity categoryBar = "c963671b-689f-4adf-9d59-c293792363aa"

	property Entity categoryChipTemplate = "2d0a1a26-fa79-4089-8ecd-f2c1860a9f06"

	property TextComponent unlockHintText = "37405201-394a-4323-a4a8-7d8900e913a0"

	property string selectedRecipe = "Stone Pickaxe"

	property table recipes = {}

	property table recipeOrder = {}

	property table recipeButtons = {}

	property table recipeClickHandlers = {}

	property table tierOptions = {}

	property table categoryOptions = {}

	property integer selectedTierIndex = 1

	property integer selectedCategoryIndex = 1

	property table tierChipButtons = {}

	property table tierChipHandlers = {}

	property table categoryChipButtons = {}

	property table categoryChipHandlers = {}

	property number CurrentScale = 1.0

	property number TargetScale = 1.0

	property any ScaleTimer = nil

	property any closeHandler = nil

	property any craftHandler = nil

	property boolean isCrafting = false

	property number LastToggleTime = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		self.Entity.Enable = false
		self:UpdateDimmer()
		
		-- Load recipe data from RecipeDataSet (single source of truth shared with the server)
		self:LoadRecipes()
		self:RebuildFilterOptions()
		self:BuildFilterChips()
		self:BuildRecipeList()
		
		self.closeHandler = self.btnClose.Entity:ConnectEvent(ButtonClickEvent, function() self:Close() end)
		self.craftHandler = self.btnCraft.Entity:ConnectEvent(ButtonClickEvent, function() self:TryCraft() end)
	end

	@ExecSpace("ClientOnly")
	method void LoadRecipes()
		-- Builds self.recipes (and self.recipeOrder) from RecipeDataSet rows. Tier/Category/Unlock* CSV 주도.
		self.recipes = {}
		self.recipeOrder = {}
		local ds = _DataService:GetTable("RecipeDataSet")
		if ds == nil then
			log_error("UICraftingController: RecipeDataSet not found.")
			return
		end
		
		local rowCount = ds:GetRowCount()
		for i = 1, rowCount do
			local recipeName = ds:GetCell(i, "RecipeName")
			local tier = math.floor(tonumber(ds:GetCell(i, "Tier")) or 1)
			if tier < 1 then tier = 1 end
			local category = ds:GetCell(i, "Category") or "misc"
			if category == "" then category = "misc" end
			local unlockId = ds:GetCell(i, "UnlockId") or ""
			local unlockHint = ds:GetCell(i, "UnlockHint") or ""
			local entry = {
				name = recipeName,
				desc = ds:GetCell(i, "Desc"),
				icon = ds:GetCell(i, "Icon"),
				tier = tier,
				category = category,
				unlockId = unlockId,
				unlockHint = unlockHint,
				ingredients = {}
			}
		
			local ing1Name = ds:GetCell(i, "Ing1Name") or ""
			local ing1Count = tonumber(ds:GetCell(i, "Ing1Count")) or 0
			local ing2Name = ds:GetCell(i, "Ing2Name") or ""
			local ing2Count = tonumber(ds:GetCell(i, "Ing2Count")) or 0
		
			if ing1Name ~= "" and ing1Count > 0 then
				table.insert(entry.ingredients, { name = ing1Name, required = ing1Count })
			end
			if ing2Name ~= "" and ing2Count > 0 then
				table.insert(entry.ingredients, { name = ing2Name, required = ing2Count })
			end
		
			self.recipes[recipeName] = entry
			table.insert(self.recipeOrder, recipeName)
		end
		log("UICraftingController: Loaded " .. rowCount .. " recipes from RecipeDataSet.")
	end

	@ExecSpace("ClientOnly")
	method void RebuildFilterOptions()
		-- CSV에 존재하는 Tier/Category 값만으로 필터 목록 생성 (코드 하드코딩 금지).
		self.tierOptions = { 0 }
		self.categoryOptions = { "all" }
		local tierSeen = {}
		local catSeen = {}
		tierSeen[0] = true
		catSeen["all"] = true
		for _, name in ipairs(self.recipeOrder) do
			local r = self.recipes[name]
			if r ~= nil then
				if not tierSeen[r.tier] then
					tierSeen[r.tier] = true
					table.insert(self.tierOptions, r.tier)
				end
				if not catSeen[r.category] then
					catSeen[r.category] = true
					table.insert(self.categoryOptions, r.category)
				end
			end
		end
		table.sort(self.tierOptions)
		if self.selectedTierIndex < 1 or self.selectedTierIndex > #self.tierOptions then
			self.selectedTierIndex = 1
		end
		if self.selectedCategoryIndex < 1 or self.selectedCategoryIndex > #self.categoryOptions then
			self.selectedCategoryIndex = 1
		end
	end

	@ExecSpace("ClientOnly")
	method void ClearFilterChips()
		-- 동적 칩 정리.
		for key, chip in pairs(self.tierChipButtons) do
			if isvalid(chip) then
				if self.tierChipHandlers[key] ~= nil then
					chip:DisconnectEvent(ButtonClickEvent, self.tierChipHandlers[key])
				end
				chip:Destroy()
			end
		end
		self.tierChipButtons = {}
		self.tierChipHandlers = {}
		for key, chip in pairs(self.categoryChipButtons) do
			if isvalid(chip) then
				if self.categoryChipHandlers[key] ~= nil then
					chip:DisconnectEvent(ButtonClickEvent, self.categoryChipHandlers[key])
				end
				chip:Destroy()
			end
		end
		self.categoryChipButtons = {}
		self.categoryChipHandlers = {}
	end

	@ExecSpace("ClientOnly")
	method void BuildFilterChips()
		-- CSV 파생 티어/카테고리를 가로 칩 탭으로 전부 노출 (순환 화살표 제거).
		self:ClearFilterChips()
		if isvalid(self.tierChipTemplate) then self.tierChipTemplate.Enable = false end
		if isvalid(self.categoryChipTemplate) then self.categoryChipTemplate.Enable = false end

		local chipW = 100
		local chipH = 32
		local gap = 8
		local startX = 16

		-- 티어 칩
		if isvalid(self.tierChipTemplate) then
			for i, tierVal in ipairs(self.tierOptions) do
				local label = "All"
				if tierVal ~= 0 then label = "T" .. tostring(tierVal) end
				local chip = self.tierChipTemplate:Clone("TierChip_" .. tostring(tierVal))
				chip.Enable = true
				local x = startX + (i - 1) * (chipW + gap)
				local tr = chip.UITransformComponent
				if isvalid(tr) then
					tr.anchoredPosition = Vector2(x, 0)
					tr.RectSize = Vector2(chipW, chipH)
				end
				local textComp = chip.TextComponent
				if isvalid(textComp) then
					textComp.Text = label
					textComp.FontSize = 16
				end
				local idx = i
				local h = chip:ConnectEvent(ButtonClickEvent, function()
					self:SelectTierIndex(idx)
				end)
				self.tierChipButtons[tostring(tierVal)] = chip
				self.tierChipHandlers[tostring(tierVal)] = h
			end
		end

		-- 카테고리 칩
		if isvalid(self.categoryChipTemplate) then
			local catW = 110
			for i, catVal in ipairs(self.categoryOptions) do
				local chip = self.categoryChipTemplate:Clone("CatChip_" .. tostring(catVal))
				chip.Enable = true
				local x = startX + (i - 1) * (catW + gap)
				local tr = chip.UITransformComponent
				if isvalid(tr) then
					tr.anchoredPosition = Vector2(x, 0)
					tr.RectSize = Vector2(catW, chipH)
				end
				local textComp = chip.TextComponent
				if isvalid(textComp) then
					textComp.Text = tostring(catVal)
					textComp.FontSize = 15
				end
				local idx = i
				local h = chip:ConnectEvent(ButtonClickEvent, function()
					self:SelectCategoryIndex(idx)
				end)
				self.categoryChipButtons[tostring(catVal)] = chip
				self.categoryChipHandlers[tostring(catVal)] = h
			end
		end

		self:RefreshChipHighlight()
	end

	@ExecSpace("ClientOnly")
	method void SelectTierIndex(integer index)
		-- 티어 탭 클릭.
		if index < 1 or index > #self.tierOptions then return end
		self.selectedTierIndex = index
		self:RefreshChipHighlight()
		self:RebuildRecipeList()
	end

	@ExecSpace("ClientOnly")
	method void SelectCategoryIndex(integer index)
		-- 카테고리 탭 클릭.
		if index < 1 or index > #self.categoryOptions then return end
		self.selectedCategoryIndex = index
		self:RefreshChipHighlight()
		self:RebuildRecipeList()
	end

	@ExecSpace("ClientOnly")
	method void RefreshChipHighlight()
		-- 선택 칩 = 액센트 배경+밝은 글자, 비선택 = 서페이스+디밍 (색+형태 이중 하이라이트).
		local selectedBg = Color(0.94, 0.66, 0.19, 1.0)   -- accent gold
		local idleBg = Color(0.18, 0.20, 0.16, 1.0)
		local selectedText = Color(0.15, 0.12, 0.08, 1.0)
		local idleText = Color(0.79, 0.75, 0.70, 1.0)

		for i, tierVal in ipairs(self.tierOptions) do
			local chip = self.tierChipButtons[tostring(tierVal)]
			if isvalid(chip) then
				local selected = (i == self.selectedTierIndex)
				local spr = chip.SpriteGUIRendererComponent
				if isvalid(spr) then
					if selected then spr.Color = selectedBg else spr.Color = idleBg end
				end
				local textComp = chip.TextComponent
				if isvalid(textComp) then
					if selected then textComp.FontColor = selectedText else textComp.FontColor = idleText end
				end
				local tr = chip.UITransformComponent
				if isvalid(tr) then
					if selected then
						tr.RectSize = Vector2(104, 34)
					else
						tr.RectSize = Vector2(100, 32)
					end
				end
			end
		end

		for i, catVal in ipairs(self.categoryOptions) do
			local chip = self.categoryChipButtons[tostring(catVal)]
			if isvalid(chip) then
				local selected = (i == self.selectedCategoryIndex)
				local spr = chip.SpriteGUIRendererComponent
				if isvalid(spr) then
					if selected then spr.Color = selectedBg else spr.Color = idleBg end
				end
				local textComp = chip.TextComponent
				if isvalid(textComp) then
					if selected then textComp.FontColor = selectedText else textComp.FontColor = idleText end
				end
				local tr = chip.UITransformComponent
				if isvalid(tr) then
					if selected then
						tr.RectSize = Vector2(114, 34)
					else
						tr.RectSize = Vector2(110, 32)
					end
				end
			end
		end
	end

	@ExecSpace("ClientOnly")
	method boolean IsRecipeUnlocked(string recipeName)
		-- T25: PlayerInventory.UnlockedRecipesJson + UnlockId 정합.
		local r = self.recipes[recipeName]
		if r == nil then return false end
		if r.unlockId == nil or r.unlockId == "" then return true end
		local player = _UserService.LocalPlayer
		if not isvalid(player) then return false end
		local inv = player:GetComponent("script.PlayerInventory")
		if not isvalid(inv) then return false end
		return inv:HasRecipeUnlock(r.unlockId)
	end

	@ExecSpace("ClientOnly")
	method boolean RecipeMatchesFilter(string recipeName)
		-- 선택 티어/카테고리와 일치하는지.
		local r = self.recipes[recipeName]
		if r == nil then return false end
		local tier = self.tierOptions[self.selectedTierIndex] or 0
		local cat = self.categoryOptions[self.selectedCategoryIndex] or "all"
		if tier ~= 0 and r.tier ~= tier then return false end
		if cat ~= "all" and r.category ~= cat then return false end
		return true
	end

	@ExecSpace("ClientOnly")
	method void RebuildRecipeList()
		-- 필터 변경 시 목록 재구성.
		for recipeName, item in pairs(self.recipeButtons) do
			if isvalid(item) then
				item:DisconnectEvent(ButtonClickEvent, self.recipeClickHandlers[recipeName])
				item:Destroy()
			end
		end
		self.recipeButtons = {}
		self.recipeClickHandlers = {}
		self:BuildRecipeList()
		-- 선택 레시피가 필터 밖이면 첫 매칭으로.
		if not self:RecipeMatchesFilter(self.selectedRecipe) then
			for _, name in ipairs(self.recipeOrder) do
				if self:RecipeMatchesFilter(name) then
					self:SelectRecipe(name)
					return
				end
			end
		else
			self:SelectRecipe(self.selectedRecipe)
		end
	end

	@ExecSpace("ClientOnly")
	method string GetItemRarity(string itemName)
		-- Returns the rarity of the item from item_dataset.
		local ds = _DataService:GetTable("item_dataset")
		if ds ~= nil then
			local row = ds:FindRow("Name", itemName)
			if row ~= nil then
				return row:GetItem("Rarity") or "Common"
			end
		end
		return "Common"
	end

	@ExecSpace("ClientOnly")
	method Color GetRarityColor(string rarity)
		-- Returns the UI display color corresponding to the rarity grade.
		if rarity == "Uncommon" then
			return Color(0.2, 0.8, 0.2, 1.0)
		elseif rarity == "Rare" then
			return Color(0.2, 0.6, 1.0, 1.0)
		elseif rarity == "Epic" then
			return Color(0.6, 0.2, 0.8, 1.0)
		elseif rarity == "Legendary" then
			return Color(1.0, 0.5, 0.0, 1.0)
		end
		return Color(1.0, 1.0, 1.0, 1.0)
	end

	@ExecSpace("ClientOnly")
	method void BuildRecipeList()
		-- Clones recipeTemplate for filter-matching recipes. 미해금 실루엣/자물쇠 훅, 재료 부족 회색 틴트.
		if not isvalid(self.recipeTemplate) then return end
		self.recipeTemplate.Enable = false

		local player = _UserService.LocalPlayer
		local inv = nil
		if isvalid(player) then inv = player:GetComponent("script.PlayerInventory") end
		
		for _, recipeName in ipairs(self.recipeOrder) do
			if self:RecipeMatchesFilter(recipeName) then
				local recipe = self.recipes[recipeName]
				local unlocked = self:IsRecipeUnlocked(recipeName)
				local item = self.recipeTemplate:Clone("Recipe_" .. recipeName)
				item.Enable = true
		
				local nameText = item:GetChildByName("Name").TextComponent
				if isvalid(nameText) then
					if unlocked then
						nameText.Text = recipe.name
						local rarity = self:GetItemRarity(recipe.name)
						nameText.FontColor = self:GetRarityColor(rarity)
					else
						nameText.Text = "???"
						nameText.FontColor = Color(0.5, 0.5, 0.5, 1)
					end
				end
		
				local iconEnt = item:GetChildByName("Icon")
				local icon = isvalid(iconEnt) and iconEnt.SpriteGUIRendererComponent or nil
				if isvalid(icon) then
					icon.ImageRUID = recipe.icon
					if not unlocked then
						icon.Color = Color(0.15, 0.15, 0.15, 0.85)
					else
						-- 재료 부족 시 회색 틴트
						local canCraft = true
						if isvalid(inv) then
							for _, ing in ipairs(recipe.ingredients) do
								if inv:GetItemCount(ing.name) < ing.required then
									canCraft = false
									break
								end
							end
						end
						if canCraft then
							icon.Color = Color(1, 1, 1, 1)
						else
							icon.Color = Color(0.45, 0.45, 0.45, 1)
						end
					end
				end
		
				local clickHandler = item:ConnectEvent(ButtonClickEvent, function() self:SelectRecipe(recipeName) end)
				self.recipeButtons[recipeName] = item
				self.recipeClickHandlers[recipeName] = clickHandler
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void OnEndPlay()
		if isvalid(self.btnClose) then self.btnClose.Entity:DisconnectEvent(ButtonClickEvent, self.closeHandler) end
		if isvalid(self.btnCraft) then self.btnCraft.Entity:DisconnectEvent(ButtonClickEvent, self.craftHandler) end
		self:ClearFilterChips()
		
		for recipeName, item in pairs(self.recipeButtons) do
			if isvalid(item) then
				item:DisconnectEvent(ButtonClickEvent, self.recipeClickHandlers[recipeName])
				item:Destroy()
			end
		end
		self.recipeButtons = {}
		self.recipeClickHandlers = {}
	end

	@ExecSpace("ClientOnly")
	method void Toggle()
		-- description: Toggles the crafting popup with time-based debounce check.
		local now = _UtilLogic.ElapsedSeconds
		if now - self.LastToggleTime < 0.15 then return end
		self.LastToggleTime = now
		
		if self.TargetScale > 0.9 and self.Entity.Enable then
			self:Close()
		else
			self:Open()
		end
	end

	@ExecSpace("ClientOnly")
	method void Open()
		-- description: Opens the crafting popup and resets crafting state.
		self.isCrafting = false
		self.Entity.Enable = true
		local transform = self.Entity.UITransformComponent
		if isvalid(transform) then
			self.CurrentScale = 0.8
			transform.Scale = Vector3(0.8, 0.8, 1.0)
		end
		self:ApplyScaleTween(1.0)
		self:RebuildFilterOptions()
		self:BuildFilterChips()
		self:RebuildRecipeList()
		if self:RecipeMatchesFilter("Stone Pickaxe") then
			self:SelectRecipe("Stone Pickaxe")
		elseif #self.recipeOrder > 0 then
			for _, name in ipairs(self.recipeOrder) do
				if self:RecipeMatchesFilter(name) then
					self:SelectRecipe(name)
					break
				end
			end
		end
		self:UpdateDimmer()
	end

	@ExecSpace("ClientOnly")
	method void Close()
		self:ApplyScaleTween(0.8)
	end

	@ExecSpace("ClientOnly")
	method void ApplyScaleTween(number targetScale)
		self.TargetScale = targetScale
		
		if self.ScaleTimer then
			_TimerService:ClearTimer(self.ScaleTimer)
			self.ScaleTimer = nil
		end
		
		local transform = self.Entity.UITransformComponent
		if not isvalid(transform) then return end
		
		self.ScaleTimer = _TimerService:SetTimerRepeat(function()
			if not isvalid(transform) then
				if self.ScaleTimer then
					_TimerService:ClearTimer(self.ScaleTimer)
					self.ScaleTimer = nil
				end
				return
			end
			
			local diff = self.TargetScale - self.CurrentScale
			if math.abs(diff) < 0.01 then
				self.CurrentScale = self.TargetScale
				transform.Scale = Vector3(self.CurrentScale, self.CurrentScale, 1.0)
				
				_TimerService:ClearTimer(self.ScaleTimer)
				self.ScaleTimer = nil
				
				if self.TargetScale < 0.9 then
					self.Entity.Enable = false
					self:UpdateDimmer()
				end
			else
				self.CurrentScale = self.CurrentScale + diff * 0.3
				transform.Scale = Vector3(self.CurrentScale, self.CurrentScale, 1.0)
			end
		end, 1/60)
	end

	@ExecSpace("ClientOnly")
	method void SelectRecipe(string recipeName)
		self.selectedRecipe = recipeName
		
		-- Highlight active list item
		for name, item in pairs(self.recipeButtons) do
			if isvalid(item) then
				if name == recipeName then
					item.SpriteGUIRendererComponent.Color = Color(0.18, 0.34, 0.15, 1) -- Highlight Forest Green
				else
					item.SpriteGUIRendererComponent.Color = Color(0.15, 0.18, 0.15, 1) -- Dark surface
				end
			end
		end
		
		self:UpdateDetails()
	end

	@ExecSpace("ClientOnly")
	method void UpdateDetails()
		-- description: Updates the crafting detail panel (name, description, ingredients) with rarity colors.
		local recipe = self.recipes[self.selectedRecipe]
		if not recipe then return end
		
		if isvalid(self.detailName) then
			self.detailName.Text = recipe.name
			local rarity = self:GetItemRarity(recipe.name)
			self.detailName.FontColor = self:GetRarityColor(rarity)
		end
		local unlocked = self:IsRecipeUnlocked(self.selectedRecipe)
		if isvalid(self.detailDesc) then
			if unlocked then
				self.detailDesc.Text = recipe.desc
			else
				self.detailDesc.Text = "잠긴 제작법"
			end
		end
		if isvalid(self.unlockHintText) then
			if unlocked then
				self.unlockHintText.Text = ""
			else
				local hint = recipe.unlockHint
				if hint == nil or hint == "" then hint = "???" end
				self.unlockHintText.Text = hint
			end
		end
		
		if isvalid(self.detailIcon) then
			self.detailIcon.ImageRUID = recipe.icon
			if unlocked then
				self.detailIcon.Color = Color(1, 1, 1, 1)
			else
				self.detailIcon.Color = Color(0.2, 0.2, 0.2, 0.9)
			end
		end
		
		local player = _UserService.LocalPlayer
		if not isvalid(player) then return end
		local inv = player:GetComponent("script.PlayerInventory")
		if not isvalid(inv) then return end
		
		-- Hide slot 2 by default, show if needed
		if isvalid(self.ingSlot2) then self.ingSlot2.Enable = false end
		if isvalid(self.ingSlot1) then self.ingSlot1.Enable = false end
		
		local canCraft = unlocked
		
		-- Ingredient 1
		local ing1 = recipe.ingredients[1]
		if ing1 and isvalid(self.ingSlot1) then
			self.ingSlot1.Enable = true
			local owned = inv:GetItemCount(ing1.name)
			
			if isvalid(self.ingIcon1) then
				self.ingIcon1.ImageRUID = self:GetIngredientIcon(ing1.name)
			end
		
			if isvalid(self.ingCount1) then
				self.ingCount1.Text = owned .. " / " .. ing1.required
				if owned >= ing1.required then
					self.ingCount1.FontColor = Color.green
				else
					self.ingCount1.FontColor = Color.red
					canCraft = false
				end
			end
		end
		
		-- Ingredient 2
		local ing2 = recipe.ingredients[2]
		if ing2 and isvalid(self.ingSlot2) then
			self.ingSlot2.Enable = true
			local owned = inv:GetItemCount(ing2.name)
		
			if isvalid(self.ingIcon2) then
				self.ingIcon2.ImageRUID = self:GetIngredientIcon(ing2.name)
			end
		
			if isvalid(self.ingCount2) then
				self.ingCount2.Text = owned .. " / " .. ing2.required
				if owned >= ing2.required then
					self.ingCount2.FontColor = Color.green
				else
					self.ingCount2.FontColor = Color.red
					canCraft = false
				end
			end
		end
		
		-- Update craft button state
		if isvalid(self.btnCraft) then
			if self.isCrafting then
				self.btnCraft.Entity.SpriteGUIRendererComponent.Color = Color(0.3, 0.3, 0.3, 1) -- Gray
				self.btnCraft.Enable = false
				local textComp = self.btnCraft.Entity.TextComponent
				if isvalid(textComp) then textComp.Text = "Crafting..." end
			elseif not unlocked then
				self.btnCraft.Entity.SpriteGUIRendererComponent.Color = Color(0.25, 0.25, 0.25, 1)
				self.btnCraft.Enable = false
				local textComp = self.btnCraft.Entity.TextComponent
				if isvalid(textComp) then textComp.Text = "Locked" end
			elseif canCraft then
				self.btnCraft.Entity.SpriteGUIRendererComponent.Color = Color(0.18, 0.34, 0.15, 1) -- Forest Green
				self.btnCraft.Enable = true
				local textComp = self.btnCraft.Entity.TextComponent
				if isvalid(textComp) then textComp.Text = "CRAFT (Space)" end
			else
				self.btnCraft.Entity.SpriteGUIRendererComponent.Color = Color(0.3, 0.1, 0.1, 1) -- Dark Red
				self.btnCraft.Enable = false
				local textComp = self.btnCraft.Entity.TextComponent
				if isvalid(textComp) then textComp.Text = "Insufficient Materials" end
			end
		end
	end

	@ExecSpace("ClientOnly")
	method string GetIngredientIcon(string ingName)
		-- Looks up the ingredient's IconRUID (item model sprite) from item_dataset.
		local ds = _DataService:GetTable("item_dataset")
		if ds == nil then return "" end
		local rowCount = ds:GetRowCount()
		for i = 1, rowCount do
			if ds:GetCell(i, "Name") == ingName then
				return ds:GetCell(i, "IconRUID") or ""
			end
		end
		return ""
	end

	@ExecSpace("ClientOnly")
	method void TryCraft()
		-- description: Triggers a craft request if the player has enough ingredients and is not already crafting.
		if self.isCrafting then return end
		
		local recipe = self.recipes[self.selectedRecipe]
		if not recipe then return end
		
		local player = _UserService.LocalPlayer
		if not isvalid(player) then return end
		local inv = player:GetComponent("script.PlayerInventory")
		if not isvalid(inv) then return end
		
		local canCraft = true
		for _, ing in ipairs(recipe.ingredients) do
			if inv:GetItemCount(ing.name) < ing.required then
				canCraft = false
				break
			end
		end
		
		if canCraft then
			self.isCrafting = true
			self:UpdateDetails()
			log("Requesting craft for " .. recipe.name)
			inv:ServerRequestCraft(recipe.name)
		end
	end

	@ExecSpace("ClientOnly")
	method void UpdateDimmer()
		local dimmer = _EntityService:GetEntityByPath("/ui/PopupGroup/Dimmer")
		if not isvalid(dimmer) then return end
		
		local inv = _EntityService:GetEntityByPath("/ui/PopupGroup/InventoryPopup")
		local craft = _EntityService:GetEntityByPath("/ui/PopupGroup/CraftingPopup")
		local char = _EntityService:GetEntityByPath("/ui/PopupGroup/CharacterPopup")
		
		local anyOpen = (isvalid(inv) and inv.Enable) or (isvalid(craft) and craft.Enable) or (isvalid(char) and char.Enable)
		dimmer.Enable = anyOpen
	end

end