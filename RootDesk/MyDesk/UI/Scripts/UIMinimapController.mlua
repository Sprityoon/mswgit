@Component
script UIMinimapController extends Component

	property number MapRadius = 75.0

	property integer GridCells = 15

	property number TilesPerCell = 4.0

	property any updateTimer = nil

	property any layer1 = nil

	property any layer2 = nil

	property boolean mapReady = false

	property string cachedMapName = ""

	property any coordsText = nil

	property any mapNameText = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- Caches the tilemap layers, then repaints the player-centered window on a light timer.
		self:CacheTileMaps()
		
		-- Spawn or find the Map Name UI Text entity
		local mapNameEnt = self.Entity:GetChildByName("MapNameText")
		if not isvalid(mapNameEnt) then
			mapNameEnt = _SpawnService:SpawnByModelId("uitext", "MapNameText", Vector3.zero, self.Entity)
		end
		if isvalid(mapNameEnt) then
			local sprite = mapNameEnt.SpriteGUIRendererComponent
			if isvalid(sprite) then
				sprite.Color = Color(0, 0, 0, 0)
			end
			local transform = mapNameEnt.UITransformComponent
			if isvalid(transform) then
				transform.AlignmentOption = AlignmentType.CastFrom("Left")
				transform.anchoredPosition = Vector2(-110, 0)
				transform.RectSize = Vector2(150, 30)
			end
			self.mapNameText = mapNameEnt.TextComponent
			if isvalid(self.mapNameText) then
				self.mapNameText.FontSize = 22
				self.mapNameText.FontColor = Color(1.0, 1.0, 1.0, 1.0)
				self.mapNameText.UseOutLine = true
				self.mapNameText.OutlineColor = Color(0.0, 0.0, 0.0, 1.0)
				self.mapNameText.OutlineWidth = 1.0
				self.mapNameText.Alignment = 2 -- MiddleRight
			end
		end

		-- Spawn or find the Coords UI Text entity
		local coords = self.Entity:GetChildByName("Coords")
		if not isvalid(coords) then
			coords = _SpawnService:SpawnByModelId("uitext", "Coords", Vector3.zero, self.Entity)
		end
		if isvalid(coords) then
			local sprite = coords.SpriteGUIRendererComponent
			if isvalid(sprite) then
				sprite.Color = Color(0, 0, 0, 0)
			end
			local transform = coords.UITransformComponent
			if isvalid(transform) then
				transform.AlignmentOption = AlignmentType.CastFrom("BottomCenter")
				transform.anchoredPosition = Vector2(0, -15) -- 15 pixels below bottom edge
				transform.RectSize = Vector2(120, 25)
			end
			self.coordsText = coords.TextComponent
			if isvalid(self.coordsText) then
				self.coordsText.FontSize = 20
				self.coordsText.FontColor = Color(1.0, 1.0, 1.0, 1.0)
				self.coordsText.UseOutLine = true
				self.coordsText.OutlineColor = Color(0.0, 0.0, 0.0, 1.0)
				self.coordsText.OutlineWidth = 1.0
				self.coordsText.Alignment = 4 -- MiddleCenter
			end
		end

		self.updateTimer = _TimerService:SetTimerRepeat(function()
			self:RepaintWindow()
		end, 0.25)
	end

	@ExecSpace("ClientOnly")
	method void OnEndPlay()
		-- Releases the repaint timer.
		if self.updateTimer then
			_TimerService:ClearTimer(self.updateTimer)
			self.updateTimer = nil
		end
	end

	@ExecSpace("ClientOnly")
	method void CacheTileMaps()
		-- Resolves the base-earth (layer1) and grass/overlay (layer2) RectTileMapComponents
		-- from the map the local player is currently on (home / town / etc.), not a fixed map.
		local player = _UserService.LocalPlayer
		if not isvalid(player) then
			_TimerService:SetTimerOnce(function() self:CacheTileMaps() end, 0.5)
			return
		end
		local map = player.CurrentMap
		if not isvalid(map) then
			_TimerService:SetTimerOnce(function() self:CacheTileMaps() end, 0.5)
			return
		end
		local l1 = map:GetChildByName("RectTileMap")
		local l2 = map:GetChildByName("RectTileMap2")
		self.layer1 = isvalid(l1) and l1.RectTileMapComponent or nil
		self.layer2 = isvalid(l2) and l2.RectTileMapComponent or nil
		if not isvalid(self.layer1) then
			_TimerService:SetTimerOnce(function() self:CacheTileMaps() end, 0.5)
			return
		end
		self.cachedMapName = map.Name
		self.mapReady = true
		log("UIMinimapController: Tilemap layers cached for minimap on map " .. map.Name .. ".")
	end

	@ExecSpace("ClientOnly")
	method Color TileColor(string tileName)
		-- Maps a tile name to its minimap color. Prefix-based so new variants inherit a family color.
		-- wall.tileset 2026-07-07 스킴: Layer 1 = "Soil" 전면(잔디가 안 덮인 곳 = 길, 흙색),
		-- Layer 2 = 잔디 커버(FullGrass/Grass*Corner/Soil{dir} 프린지 — 전부 잔디색). 구 tile1 이름 호환 유지.
		if tileName == nil or tileName == "" then
			return Color(0.06, 0.07, 0.09, 1.0)
		end
		if tileName == "FullGrass" then
			return Color(0.39, 0.60, 0.13, 1.0)
		elseif string.sub(tileName, 1, 5) == "Grass" then
			return Color(0.39, 0.60, 0.13, 1.0)
		elseif tileName == "Soil" then
			return Color(0.76, 0.60, 0.42, 1.0)
		elseif string.sub(tileName, 1, 4) == "Soil" then
			-- Soil{LT..RD} = Layer 2 잔디 가장자리 프린지 (대부분 잔디) — 잔디색으로 취급
			return Color(0.39, 0.60, 0.13, 1.0)
		elseif string.sub(tileName, 1, 10) == "TerraceTop" then
			return Color(0.30, 0.48, 0.12, 1.0)
		elseif string.sub(tileName, 1, 9) == "CliffFace" then
			return Color(0.45, 0.32, 0.22, 1.0)
		elseif tileName == "Big Wall" then
			return Color(0.25, 0.20, 0.16, 1.0)
		elseif string.sub(tileName, 1, 9) == "BaseGrass" then
			return Color(0.39, 0.60, 0.13, 1.0)
		elseif string.sub(tileName, 1, 8) == "BaseSand" then
			return Color(0.91, 0.82, 0.55, 1.0)
		elseif string.sub(tileName, 1, 8) == "BaseSnow" then
			return Color(0.90, 0.93, 0.95, 1.0)
		elseif string.sub(tileName, 1, 9) == "BaseEarth" then
			return Color(0.70, 0.53, 0.42, 1.0)
		end
		return Color(0.55, 0.50, 0.45, 1.0)
	end

	@ExecSpace("ClientOnly")
	method string TileNameAt(integer wx, integer wy)
		-- Returns the topmost actual tile name at world cell (wx, wy): overlay (layer2) over base (layer1).
		local cell = Vector2Int(wx, wy)
		if isvalid(self.layer2) then
			local t2 = self.layer2:GetTile(cell)
			if t2 ~= nil and t2.Name ~= nil and t2.Name ~= "" then
				return t2.Name
			end
		end
		if isvalid(self.layer1) then
			local t1 = self.layer1:GetTile(cell)
			if t1 ~= nil and t1.Name ~= nil then
				return t1.Name
			end
		end
		return ""
	end

	@ExecSpace("ClientOnly")
	method void RepaintWindow()
		-- Repaints all cells with the actual tilemap state in the window centered on the player.
		if not self.mapReady then return end
		local player = _UserService.LocalPlayer
		if not isvalid(player) then return end

		-- Re-cache tilemap layers when the player has moved to a different map (home <-> town warp).
		local curMap = player.CurrentMap
		if isvalid(curMap) and curMap.Name ~= self.cachedMapName then
			self.mapReady = false
			self:CacheTileMaps()
			return
		end

		local worldPos = player.TransformComponent.WorldPosition
		local px = math.floor(worldPos.x)
		local py = math.floor(worldPos.y)
		
		if isvalid(self.coordsText) then
			self.coordsText.Text = string.format("(%d, %d)", px, py)
		end
		
		if isvalid(self.mapNameText) then
			self.mapNameText.Text = self:GetMapDisplayName(self.cachedMapName)
		end
		
		local gridCells = self.GridCells
		local half = math.floor(gridCells / 2)
		local tilesPerCell = math.floor(self.TilesPerCell)
		
		for r = 0, gridCells - 1 do
			for c = 0, gridCells - 1 do
				local cellEntity = self.Entity:GetChildByName("Cell_" .. r .. "_" .. c)
				if isvalid(cellEntity) and isvalid(cellEntity.SpriteGUIRendererComponent) then
					local wx = px + (c - half) * tilesPerCell
					local wy = py + (r - half) * tilesPerCell
					local tileName = self:TileNameAt(wx, wy)
					cellEntity.SpriteGUIRendererComponent.Color = self:TileColor(tileName)
				end
			end
		end
	end

	@ExecSpace("ClientOnly")
	method string GetMapDisplayName(string mapName)
		if mapName == nil or mapName == "" then return "" end
		if string.sub(mapName, 1, 5) == "Home_" then
			return "개인 영지"
		end
		
		local ds = _DataService:GetTable("PortalDestinationDataSet")
		if ds ~= nil then
			local rowCount = ds:GetRowCount()
			for i = 1, rowCount do
				if ds:GetCell(i, "MapName") == mapName then
					return ds:GetCell(i, "DisplayName")
				end
			end
		end
		return mapName
	end

end