@Component
script UIResearchController extends Component

	-- Research lab UI: list + detail + start (T14 craft hybrid skeleton, simplified).
	-- Visual identity: forest dark + gold accent #F0A830 (same as craft/HUD).

	property Entity btnClose = "b7d0772a-f2e4-44d9-be84-08ff99ecb9ed"

	property Entity researchList = "f5c29ed4-6a1b-4fea-bd1d-bdcbe230eb69"

	property Entity researchTemplate = "7986ced2-11b5-44bb-a710-4c31bd840158"

	property Entity detailName = "0967a122-0b51-4fa0-9043-f1fa88935026"

	property Entity detailDesc = "d60afb20-069f-4e00-8a5c-0cedad3c9623"

	property Entity detailIcon = "7d7f0493-11d1-4262-bf15-e5225d7c8b4f"

	property Entity ingIcon = "d38fba4f-c4c3-4c44-8f79-4f4dd0418c51"

	property Entity ingCount = "23429675-db48-40f1-9f4c-3445a4b713a5"

	property Entity progressText = "6587a641-e5cd-457c-9820-273ed2127d53"

	property Entity btnStart = "d1c69317-ab67-404f-84af-150d371c5e15"

	property string selectedResearchId = ""

	property table researchRows = {}

	property table researchOrder = {}

	property table listButtons = {}

	property table listHandlers = {}

	property any closeHandler = nil

	property any startHandler = nil

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		self.Entity.Enable = false
		self:ResolveRefs()
		self:LoadResearchData()
		self:BuildList()

		if isvalid(self.btnClose) then
			self.closeHandler = self.btnClose:ConnectEvent(ButtonClickEvent, function() self:Close() end)
		end
		if isvalid(self.btnStart) then
			self.startHandler = self.btnStart:ConnectEvent(ButtonClickEvent, function() self:TryStart() end)
		end

		if #self.researchOrder > 0 then
			self:SelectResearch(self.researchOrder[1])
		end
	end

	@ExecSpace("ClientOnly")
	method void OnEndPlay()
		if self.closeHandler and isvalid(self.btnClose) then
			self.btnClose:DisconnectEvent(ButtonClickEvent, self.closeHandler)
		end
		if self.startHandler and isvalid(self.btnStart) then
			self.btnStart:DisconnectEvent(ButtonClickEvent, self.startHandler)
		end
	end

	@ExecSpace("ClientOnly")
	method void ResolveRefs()
		-- Runtime path lookup when injectBindings leaves nil (first-run safety).
		local bg = self.Entity:GetChildByName("Bg")
		if not isvalid(bg) then return end
		if not isvalid(self.btnClose) then self.btnClose = bg:GetChildByName("BtnClose") end
		if not isvalid(self.researchList) then self.researchList = bg:GetChildByName("List") end
		if isvalid(self.researchList) and not isvalid(self.researchTemplate) then
			self.researchTemplate = self.researchList:GetChildByName("ResearchTemplate")
		end
		local details = bg:GetChildByName("Details")
		if isvalid(details) then
			if not isvalid(self.detailName) then self.detailName = details:GetChildByName("Name") end
			if not isvalid(self.detailDesc) then self.detailDesc = details:GetChildByName("Desc") end
			if not isvalid(self.detailIcon) then self.detailIcon = details:GetChildByName("Icon") end
			if not isvalid(self.progressText) then self.progressText = details:GetChildByName("ProgressText") end
			if not isvalid(self.btnStart) then self.btnStart = details:GetChildByName("BtnStart") end
			local slot1 = details:GetChildByName("Slot1")
			if isvalid(slot1) then
				if not isvalid(self.ingIcon) then self.ingIcon = slot1:GetChildByName("Icon") end
				if not isvalid(self.ingCount) then self.ingCount = slot1:GetChildByName("Count") end
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void LoadResearchData()
		self.researchRows = {}
		self.researchOrder = {}
		local ds = _DataService:GetTable("ResearchDataSet")
		if ds == nil then
			log_error("UIResearchController: ResearchDataSet not found.")
			return
		end
		local rowCount = ds:GetRowCount()
		local sortable = {}
		for i = 1, rowCount do
			local id = ds:GetCell(i, "ResearchId") or ""
			if id ~= "" then
				local sortOrder = math.floor(tonumber(ds:GetCell(i, "SortOrder")) or i)
				local entry = {
					id = id,
					displayName = ds:GetCell(i, "DisplayName") or id,
					inputItem = ds:GetCell(i, "InputItem") or "",
					inputCount = math.floor(tonumber(ds:GetCell(i, "InputCount")) or 0),
					duration = math.floor(tonumber(ds:GetCell(i, "Duration")) or 0),
					unlockRecipeId = ds:GetCell(i, "UnlockRecipeId") or "",
					iconRuid = ds:GetCell(i, "IconRUID") or "",
					desc = ds:GetCell(i, "Desc") or "",
					sortOrder = sortOrder,
				}
				self.researchRows[id] = entry
				table.insert(sortable, entry)
			end
		end
		-- SortOrder 오름차순 (구리=1 → 철=2). 동일 시 ResearchId 문자열.
		table.sort(sortable, function(a, b)
			if a.sortOrder ~= b.sortOrder then return a.sortOrder < b.sortOrder end
			return tostring(a.id) < tostring(b.id)
		end)
		for _, e in ipairs(sortable) do
			table.insert(self.researchOrder, e.id)
		end
	end

	@ExecSpace("ClientOnly")
	method void BuildList()
		if not isvalid(self.researchList) or not isvalid(self.researchTemplate) then return end
		self.researchTemplate.Enable = false

		for id, btn in pairs(self.listButtons) do
			if isvalid(btn) then
				if self.listHandlers[id] then
					btn:DisconnectEvent(ButtonClickEvent, self.listHandlers[id])
				end
				btn:Destroy()
			end
		end
		self.listButtons = {}
		self.listHandlers = {}

		-- 템플릿과 같은 위치에 겹치면 마지막 클론(철)만 보이던 버그 수정: 세로 오프셋 배치.
		local rowH = 72
		local startY = 160
		for i, id in ipairs(self.researchOrder) do
			local row = self.researchRows[id]
			local item = self.researchTemplate:Clone("Research_" .. id)
			item.Enable = true
			local tr = item.UITransformComponent
			if isvalid(tr) then
				tr.anchoredPosition = Vector2(0, startY - (i - 1) * rowH)
				tr.RectSize = Vector2(320, 64)
			end
			local nameChild = item:GetChildByName("Name")
			if isvalid(nameChild) and isvalid(nameChild.TextComponent) then
				nameChild.TextComponent.Text = row.displayName
			end
			local iconChild = item:GetChildByName("Icon")
			if isvalid(iconChild) and isvalid(iconChild.SpriteGUIRendererComponent) and row.iconRuid ~= "" then
				iconChild.SpriteGUIRendererComponent.ImageRUID = row.iconRuid
			end
			local rid = id
			self.listHandlers[id] = item:ConnectEvent(ButtonClickEvent, function()
				self:SelectResearch(rid)
			end)
			self.listButtons[id] = item
		end
	end

	@ExecSpace("ClientOnly")
	method void Open()
		self.Entity.Enable = true
		self:RefreshDetail()
		log("[RESEARCH-UI] Opened")
	end

	@ExecSpace("ClientOnly")
	method void Close()
		self.Entity.Enable = false
		log("[RESEARCH-UI] Closed")
	end

	@ExecSpace("ClientOnly")
	method void SelectResearch(string researchId)
		self.selectedResearchId = researchId
		self:RefreshDetail()
	end

	@ExecSpace("ClientOnly")
	method boolean IsUnlocked(string unlockId)
		if unlockId == nil or unlockId == "" then return true end
		local player = _UserService.LocalPlayer
		if not isvalid(player) then return false end
		local inv = player:GetComponent("script.PlayerInventory")
		if not isvalid(inv) then return false end
		return inv:HasRecipeUnlock(unlockId)
	end

	@ExecSpace("ClientOnly")
	method string GetItemIconRUID(string itemName)
		local ds = _DataService:GetTable("item_dataset")
		if ds ~= nil then
			local row = ds:FindRow("Name", itemName)
			if row ~= nil then
				return row:GetItem("IconRUID") or ""
			end
		end
		return ""
	end

	@ExecSpace("ClientOnly")
	method integer GetOwnedCount(string itemName)
		local player = _UserService.LocalPlayer
		if not isvalid(player) then return 0 end
		local inv = player:GetComponent("script.PlayerInventory")
		if not isvalid(inv) then return 0 end
		return inv:GetItemCount(itemName)
	end

	@ExecSpace("ClientOnly")
	method void RefreshDetail()
		local row = self.researchRows[self.selectedResearchId]
		if row == nil then return end

		if isvalid(self.detailName) and isvalid(self.detailName.TextComponent) then
			self.detailName.TextComponent.Text = row.displayName
		end
		if isvalid(self.detailDesc) and isvalid(self.detailDesc.TextComponent) then
			self.detailDesc.TextComponent.Text = row.desc
		end
		if isvalid(self.detailIcon) and isvalid(self.detailIcon.SpriteGUIRendererComponent) then
			local ruid = row.iconRuid
			if ruid == "" then ruid = self:GetItemIconRUID(row.inputItem) end
			self.detailIcon.SpriteGUIRendererComponent.ImageRUID = ruid
		end
		if isvalid(self.ingIcon) and isvalid(self.ingIcon.SpriteGUIRendererComponent) then
			self.ingIcon.SpriteGUIRendererComponent.ImageRUID = self:GetItemIconRUID(row.inputItem)
		end
		local owned = self:GetOwnedCount(row.inputItem)
		if isvalid(self.ingCount) and isvalid(self.ingCount.TextComponent) then
			self.ingCount.TextComponent.Text = tostring(owned) .. "/" .. tostring(row.inputCount)
			if owned >= row.inputCount then
				self.ingCount.TextComponent.FontColor = Color(0.365, 0.722, 0.361, 1.0)
			else
				self.ingCount.TextComponent.FontColor = Color(0.851, 0.325, 0.310, 1.0)
			end
		end

		local player = _UserService.LocalPlayer
		local inv = nil
		if isvalid(player) then inv = player:GetComponent("script.PlayerInventory") end

		local status = ""
		local btnLabel = "연구 시작"
		local unlocked = self:IsUnlocked(row.unlockRecipeId)

		if unlocked then
			status = "이미 해금됨"
			btnLabel = "완료"
		elseif isvalid(inv) and inv.ActiveResearchId ~= nil and inv.ActiveResearchId ~= "" then
			if inv.ActiveResearchId == row.id then
				local startT = tonumber(inv.ResearchStartTime) or 0
				local nowT = os.time()
				local elapsed = math.max(0, nowT - startT)
				local remain = math.max(0, row.duration - elapsed)
				if remain <= 0 then
					status = "완료 처리 중…"
				else
					status = string.format("연구 중… 남은 시간 %d초", remain)
				end
				btnLabel = "진행 중"
			else
				status = "다른 연구 진행 중"
				btnLabel = "대기"
			end
		else
			status = string.format("소요 %d초 · 재료 %s x%d", row.duration, row.inputItem, row.inputCount)
			btnLabel = "연구 시작"
		end

		if isvalid(self.progressText) and isvalid(self.progressText.TextComponent) then
			self.progressText.TextComponent.Text = status
		end
		if isvalid(self.btnStart) then
			local tc = self.btnStart.TextComponent
			if isvalid(tc) then tc.Text = btnLabel end
		end
	end

	@ExecSpace("ClientOnly")
	method void OnUpdate(number delta)
		if not self.Entity.Enable then return end
		self:RefreshDetail()
	end

	@ExecSpace("ClientOnly")
	method void TryStart()
		local row = self.researchRows[self.selectedResearchId]
		if row == nil then return end
		if self:IsUnlocked(row.unlockRecipeId) then
			local pc = _UserService.LocalPlayer and _UserService.LocalPlayer:GetComponent("script.PlayerController")
			if isvalid(pc) then pc:ShowMineFeedback("이미 해금된 연구입니다.") end
			return
		end
		local player = _UserService.LocalPlayer
		if not isvalid(player) then return end
		local inv = player:GetComponent("script.PlayerInventory")
		if not isvalid(inv) then return end
		inv:ServerRequestStartResearch(row.id)
	end

end
