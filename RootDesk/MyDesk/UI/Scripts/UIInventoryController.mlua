@Component
script UIInventoryController extends Component

	property Entity inventoryPopup = "4056e69c-09be-4e95-b7f6-7fe1c1681e93"

	property ButtonComponent btnClose = "d5d37751-4933-4a50-a5ec-8047f8c3de7a"

	property ButtonComponent tabAll = "8184738e-5a40-45e4-be39-ed99b264c864"

	property ButtonComponent tabRes = "3b379672-b765-444d-a1db-56b714d7bad8"

	property ButtonComponent tabEquip = "b62e05bd-1198-4515-b987-46329c89cfcc"

	property GridViewComponent gridView = "3957ee4d-7fff-4556-ad91-4faff1946cf6"

	property Entity itemSlotTemplate = "235c59fd-b346-4564-893a-46e22b300061"

	property TextComponent capacityText = "285b48e7-bead-43d9-8b21-ee4bd20f2484"

	property Entity tooltipPanel = "a13637cd-46a6-4e9c-9555-56da6e882b94"

	property TextComponent tooltipName = "d555f5d8-2a82-467c-8ee5-6d089d6a9dee"

	property TextComponent tooltipDesc = "465408f1-1092-4c35-8ada-5203a5b86687"

	property TextComponent tooltipCount = "83cdedab-55a1-4fc0-8949-fb65ba390c6a"

	property string activeTab = "All"

	property table filteredItems = {}

	property table slotHandlers = {}

	property table lastClickTimes = {}

	-- Inventory → QuickSlot drag state (mirrors UIHUDController quickslot D&D)
	property table invTouchDownHandlers = {}

	property table invTouchDragHandlers = {}

	property table invTouchUpHandlers = {}

	property boolean invIsDragging = false

	property number invDragAccumulatedDelta = 0

	property string invDragItemKey = ""

	property any invDraggedIcon = nil

	property Vector2 invDraggedIconOriginalPos = Vector2(0, 0)

	property Vector2 invDragOffset = Vector2(0, 0)

	property Entity invDragStartSlot = nil

	-- Floating ghost parented outside inventory clip (GridView mask) so it stays visible over HUD
	property Entity invDragGhost = nil

	property Entity invDragSourceIcon = nil

	property Color invDragSourceIconOriginalColor = Color.white

	property boolean invSuppressClick = false

	property any closeHandler = nil

	property number CurrentScale = 1.0

	property number TargetScale = 1.0

	property any ScaleTimer = nil

	property string inspectedItem = ""

	property integer inspectedCount = 0

	-- Discard (버리기) UI bindings — injected by UIBuilder
	property ButtonComponent btnDiscardOpen = "4dbc45ea-00a5-4412-badd-be4ada185aed"

	property Entity discardPopup = "a160b3f7-d7a2-4019-8e7c-8b34bd5b6584"

	property TextComponent discardItemText = "531426cf-99f2-4996-beb8-00811f50967d"

	property TextComponent discardCountText = "77a1d770-31ee-40b1-9c96-6e11b160cbb5"

	property ButtonComponent btnDiscardMinus = "861924c2-d4ec-4a7d-ae7b-85f34b2b48ad"

	property ButtonComponent btnDiscardPlus = "6661dd37-c226-46cf-ab53-7f20ef9373a3"

	property ButtonComponent btnDiscardDrop = "e8703251-7b5a-42f1-8b27-0809a25caca1"

	property ButtonComponent btnDiscardDelete = "ae901ceb-e64f-493d-a87b-57227973df55"

	property ButtonComponent btnDiscardCancel = "e34d901c-f08f-49cc-a561-10d2ddf7fe3c"

	property integer discardCount = 1

	property integer discardMax = 1

	property any discardOpenHandler = nil

	property any discardMinusHandler = nil

	property any discardPlusHandler = nil

	property any discardDropHandler = nil

	property any discardDeleteHandler = nil

	property any discardCancelHandler = nil

	property string SelectedForFurnace = ""

	property any tabAllHandler = nil

	property any tabResHandler = nil

	property any tabEquipHandler = nil



	property number LastToggleTime = 0

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		self.inventoryPopup.Enable = false
		self.tooltipPanel.Enable = false
		if isvalid(self.discardPopup) then
			self.discardPopup.Enable = false
		end
		self:UpdateDimmer()
		
		-- Button clicks
		self.closeHandler = self.btnClose.Entity:ConnectEvent(ButtonClickEvent, function()
			self:Close()
		end)
		self.tabAllHandler = self.tabAll.Entity:ConnectEvent(ButtonClickEvent, function()
			self:SetTab("All")
		end)
		self.tabResHandler = self.tabRes.Entity:ConnectEvent(ButtonClickEvent, function()
			self:SetTab("Resources")
		end)
		self.tabEquipHandler = self.tabEquip.Entity:ConnectEvent(ButtonClickEvent, function()
			self:SetTab("Equipment")
		end)
		
		-- GridView setup — ItemEntity (clone source) MUST be injected at runtime,
		-- otherwise the grid renders zero slots even though TotalCount is set.
		if isvalid(self.itemSlotTemplate) then
			self.gridView.ItemEntity = self.itemSlotTemplate
		end
		self.gridView.OnRefresh = function(index, entity)
			self:RefreshGridItem(index, entity)
		end



		-- Discard (버리기) button wiring
		if isvalid(self.btnDiscardOpen) then
			self.discardOpenHandler = self.btnDiscardOpen.Entity:ConnectEvent(ButtonClickEvent, function()
				self:OpenDiscard()
			end)
		end
		if isvalid(self.btnDiscardMinus) then
			self.discardMinusHandler = self.btnDiscardMinus.Entity:ConnectEvent(ButtonClickEvent, function()
				self:ChangeDiscardCount(-1)
			end)
		end
		if isvalid(self.btnDiscardPlus) then
			self.discardPlusHandler = self.btnDiscardPlus.Entity:ConnectEvent(ButtonClickEvent, function()
				self:ChangeDiscardCount(1)
			end)
		end
		if isvalid(self.btnDiscardDrop) then
			self.discardDropHandler = self.btnDiscardDrop.Entity:ConnectEvent(ButtonClickEvent, function()
				self:DoDiscard("drop")
			end)
		end
		if isvalid(self.btnDiscardDelete) then
			self.discardDeleteHandler = self.btnDiscardDelete.Entity:ConnectEvent(ButtonClickEvent, function()
				self:DoDiscard("delete")
			end)
		end
		if isvalid(self.btnDiscardCancel) then
			self.discardCancelHandler = self.btnDiscardCancel.Entity:ConnectEvent(ButtonClickEvent, function()
				self:CloseDiscard()
			end)
		end
	end

	@ExecSpace("ClientOnly")
	method void OnEndPlay()
		if isvalid(self.btnClose) then
			self.btnClose.Entity:DisconnectEvent(ButtonClickEvent, self.closeHandler)
		end
		if isvalid(self.tabAll) then
			self.tabAll.Entity:DisconnectEvent(ButtonClickEvent, self.tabAllHandler)
		end
		if isvalid(self.tabRes) then
			self.tabRes.Entity:DisconnectEvent(ButtonClickEvent, self.tabResHandler)
		end
		if isvalid(self.tabEquip) then
			self.tabEquip.Entity:DisconnectEvent(ButtonClickEvent, self.tabEquipHandler)
		end
		for slotEntity, slotHandler in pairs(self.slotHandlers) do
			if isvalid(slotEntity) then
				slotEntity:DisconnectEvent(ButtonClickEvent, slotHandler)
			end
		end
		self.slotHandlers = {}

		if self.invTouchDownHandlers then
			for slotEntity, eventHandler in pairs(self.invTouchDownHandlers) do
				if isvalid(slotEntity) then
					slotEntity:DisconnectEvent(UITouchDownEvent, eventHandler)
				end
			end
			self.invTouchDownHandlers = {}
		end
		if self.invTouchDragHandlers then
			for slotEntity, eventHandler in pairs(self.invTouchDragHandlers) do
				if isvalid(slotEntity) then
					slotEntity:DisconnectEvent(UITouchDragEvent, eventHandler)
				end
			end
			self.invTouchDragHandlers = {}
		end
		if self.invTouchUpHandlers then
			for slotEntity, eventHandler in pairs(self.invTouchUpHandlers) do
				if isvalid(slotEntity) then
					slotEntity:DisconnectEvent(UITouchUpEvent, eventHandler)
				end
			end
			self.invTouchUpHandlers = {}
		end
		self:ResetInvDragState()

		if self.keyDownHandler then
			_InputService:DisconnectEvent(KeyDownEvent, self.keyDownHandler)
			self.keyDownHandler = nil
		end

		if isvalid(self.btnDiscardOpen) and self.discardOpenHandler then
			self.btnDiscardOpen.Entity:DisconnectEvent(ButtonClickEvent, self.discardOpenHandler)
		end
		if isvalid(self.btnDiscardMinus) and self.discardMinusHandler then
			self.btnDiscardMinus.Entity:DisconnectEvent(ButtonClickEvent, self.discardMinusHandler)
		end
		if isvalid(self.btnDiscardPlus) and self.discardPlusHandler then
			self.btnDiscardPlus.Entity:DisconnectEvent(ButtonClickEvent, self.discardPlusHandler)
		end
		if isvalid(self.btnDiscardDrop) and self.discardDropHandler then
			self.btnDiscardDrop.Entity:DisconnectEvent(ButtonClickEvent, self.discardDropHandler)
		end
		if isvalid(self.btnDiscardDelete) and self.discardDeleteHandler then
			self.btnDiscardDelete.Entity:DisconnectEvent(ButtonClickEvent, self.discardDeleteHandler)
		end
		if isvalid(self.btnDiscardCancel) and self.discardCancelHandler then
			self.btnDiscardCancel.Entity:DisconnectEvent(ButtonClickEvent, self.discardCancelHandler)
		end
	end

	@ExecSpace("ClientOnly")
	method void Toggle()
		-- description: Toggles the inventory popup with time-based debounce check.
		local now = _UtilLogic.ElapsedSeconds
		if now - self.LastToggleTime < 0.15 then return end
		self.LastToggleTime = now
		
		if self.TargetScale > 0.9 and self.inventoryPopup.Enable then
			self:Close()
		else
			self:Open()
		end
	end

	@ExecSpace("ClientOnly")
	method void Open()
		self.inventoryPopup.Enable = true
		self.inspectedItem = ""
		local transform = self.inventoryPopup.UITransformComponent
		if isvalid(transform) then
			self.CurrentScale = 0.8
			transform.Scale = Vector3(0.8, 0.8, 1.0)
		end
		self:ApplyScaleTween(1.0)
		
		self:SetTab("All")
		self:UpdateDimmer()
	end

	@ExecSpace("ClientOnly")
	method void Close()
		self.tooltipPanel.Enable = false
		self.inspectedItem = ""
		self:ApplyScaleTween(0.8)
		
		-- Restore position to centered
		local transform = self.inventoryPopup.UITransformComponent
		if isvalid(transform) then
			transform.anchoredPosition = Vector2(0, 0)
		end
	end

	@ExecSpace("ClientOnly")
	method void ApplyScaleTween(number targetScale)
		self.TargetScale = targetScale
		
		if self.ScaleTimer then
			_TimerService:ClearTimer(self.ScaleTimer)
			self.ScaleTimer = nil
		end
		
		local transform = self.inventoryPopup.UITransformComponent
		if not isvalid(transform) then return end
		
		self.ScaleTimer = _TimerService:SetTimerRepeat(function()
			if not isvalid(transform) then
				if self.ScaleTimer then
					_TimerService:ClearTimer(self.ScaleTimer)
					self.ScaleTimer = nil
				end
				return
			end
			
			local diff = self.TargetScale - self.CurrentScale
			if math.abs(diff) < 0.01 then
				self.CurrentScale = self.TargetScale
				transform.Scale = Vector3(self.CurrentScale, self.CurrentScale, 1.0)
				
				_TimerService:ClearTimer(self.ScaleTimer)
				self.ScaleTimer = nil
				
				if self.TargetScale < 0.9 then
					self.inventoryPopup.Enable = false
					self:UpdateDimmer()
				end
			else
				self.CurrentScale = self.CurrentScale + diff * 0.3
				transform.Scale = Vector3(self.CurrentScale, self.CurrentScale, 1.0)
			end
		end, 1/60)
	end

	@ExecSpace("ClientOnly")
	method void SetTab(string tabName)
		self.activeTab = tabName
		
		-- Highlight active tab
		local allColor = Color(0.3, 0.3, 0.3, 1)
		local resColor = Color(0.3, 0.3, 0.3, 1)
		local equipColor = Color(0.3, 0.3, 0.3, 1)
		
		if tabName == "All" then
			allColor = Color(0.18, 0.34, 0.15, 1) -- Forest Green
		elseif tabName == "Resources" then
			resColor = Color(0.18, 0.34, 0.15, 1)
		elseif tabName == "Equipment" then
			equipColor = Color(0.18, 0.34, 0.15, 1)
		end
		
		if isvalid(self.tabAll) then self.tabAll.Entity.SpriteGUIRendererComponent.Color = allColor end
		if isvalid(self.tabRes) then self.tabRes.Entity.SpriteGUIRendererComponent.Color = resColor end
		if isvalid(self.tabEquip) then self.tabEquip.Entity.SpriteGUIRendererComponent.Color = equipColor end
		
		self:RefreshInventoryData()
	end

	@ExecSpace("ClientOnly")
	method void RefreshInventoryData()
		local player = _UserService.LocalPlayer
		if not isvalid(player) then return end
		
		local inv = player:GetComponent("script.PlayerInventory")
		if not isvalid(inv) then return end
		
		local items = inv:SafeDecodeJson(inv.InventoryDataJson, {})
		
		-- Filter items based on activeTab
		self.filteredItems = {}
		local totalCount = 0
		
		for itemKey, val in pairs(items) do
			local isTable = (type(val) == "table")
			local count = isTable and (val.count or 1) or val
			if count > 0 then
				totalCount = totalCount + 1
				local itemName = isTable and val.name or itemKey
				local category = self:GetItemCategory(itemName)
		
				if self.activeTab == "All" or self.activeTab == category then
					table.insert(self.filteredItems, { key = itemKey, name = itemName, count = count })
				end
			end
		end
		
		-- Sort items alphabetically for clean display
		table.sort(self.filteredItems, function(a, b)
			return a.name < b.name
		end)
		
		-- Update Capacity
		if isvalid(self.capacityText) then
			self.capacityText.Text = totalCount .. " / 24 items"
		end
		
		-- Refresh GridView
		if isvalid(self.gridView) then
			self.gridView.TotalCount = #self.filteredItems
			self.gridView:Refresh(true, true)
		end
	end

	@ExecSpace("ClientOnly")
	method string GetItemCategory(string itemName)
		-- Returns the inventory category tab name for the item.
		local ds = _DataService:GetTable("item_dataset")
		if ds ~= nil then
			local row = ds:FindRow("Name", itemName)
			if row ~= nil then
				local category = row:GetItem("Category") or ""
				if category == "tool" or category == "furniture" then
					return "Equipment"
				end
			end
		end
		return "Resources"
	end

	@ExecSpace("ClientOnly")
	method string GetItemIcon(string itemName)
		-- Looks up the item's IconRUID (item model sprite) from item_dataset.
		local ds = _DataService:GetTable("item_dataset")
		if ds == nil then return "" end
		local row = ds:FindRow("Name", itemName)
		if row ~= nil then
			return row:GetItem("IconRUID") or ""
		end
		return ""
	end

	@ExecSpace("ClientOnly")
	method string GetItemDescription(string itemName)
		-- Looks up the item's description from item_dataset.
		local ds = _DataService:GetTable("item_dataset")
		if ds ~= nil then
			local row = ds:FindRow("Name", itemName)
			if row ~= nil then
				return row:GetItem("Description") or "A mysterious item of unknown utility."
			end
		end
		return "A mysterious item of unknown utility."
	end

	@ExecSpace("ClientOnly")
	method string GetItemRarity(string itemName)
		-- Returns the rarity of the item from item_dataset.
		local ds = _DataService:GetTable("item_dataset")
		if ds ~= nil then
			local row = ds:FindRow("Name", itemName)
			if row ~= nil then
				return row:GetItem("Rarity") or "Common"
			end
		end
		return "Common"
	end

	@ExecSpace("ClientOnly")
	method Color GetRarityColor(string rarity)
		-- Returns the UI display color corresponding to the rarity grade.
		if rarity == "Uncommon" then
			return Color(0.2, 0.8, 0.2, 1.0)
		elseif rarity == "Rare" then
			return Color(0.2, 0.6, 1.0, 1.0)
		elseif rarity == "Epic" then
			return Color(0.6, 0.2, 0.8, 1.0)
		elseif rarity == "Legendary" then
			return Color(1.0, 0.5, 0.0, 1.0)
		end
		return Color(1.0, 1.0, 1.0, 1.0)
	end

	@ExecSpace("ClientOnly")
	method void DestroyInvDragGhost()
		-- Removes floating drag ghost and restores the source slot icon visibility.
		if isvalid(self.invDragGhost) then
			self.invDragGhost:Destroy()
			self.invDragGhost = nil
		end
		if isvalid(self.invDragSourceIcon) and isvalid(self.invDragSourceIcon.SpriteGUIRendererComponent) then
			self.invDragSourceIcon.SpriteGUIRendererComponent.Color = self.invDragSourceIconOriginalColor
		end
		self.invDragSourceIcon = nil
	end

	@ExecSpace("ClientOnly")
	method void EnsureInvDragGhost(Entity sourceIcon, Vector2 screenPoint)
		-- Floating ghost must live under PopupGroup (displayOrder > HUD) so it draws
		-- above InventoryPopup, yet outside GridView clip so it stays visible off-panel.
		-- Parenting under HUDGroup put the ghost BEHIND the inventory (invisible).
		if isvalid(self.invDragGhost) then return end
		if not isvalid(sourceIcon) then return end

		local host = _EntityService:GetEntityByPath("/ui/PopupGroup")
		if not isvalid(host) then
			host = _EntityService:GetEntityByPath("/ui/HUDGroup")
		end
		if not isvalid(host) then return end

		-- Prefer runtime uisprite (same path as UIHUD NightOverlay) over Clone+Attach,
		-- which can keep clip/parent quirks from GridView slot icons.
		local ghost = _SpawnService:SpawnByModelId("uisprite", "InvDragGhost", Vector3.zero, host)
		if not isvalid(ghost) then
			-- Fallback: clone source icon and reparent
			ghost = sourceIcon:Clone("InvDragGhost")
			if isvalid(ghost) then
				ghost:AttachTo(host)
			end
		end
		if not isvalid(ghost) then return end
		ghost.Enable = true

		local srcSprite = sourceIcon.SpriteGUIRendererComponent
		local ghostSprite = ghost.SpriteGUIRendererComponent
		if isvalid(ghostSprite) then
			ghostSprite.RaycastTarget = false
			if isvalid(srcSprite) then
				ghostSprite.ImageRUID = srcSprite.ImageRUID
				ghostSprite.Color = srcSprite.Color
			end
			-- Do NOT set OrderInLayer here: Screen-mode UI requires OverrideSorting=true
			-- (and UIMode/World rules) or Maker emits LWA-3047. Draw order is handled by
			-- SetSiblingIndex below within PopupGroup hierarchy.
		end

		local srcT = sourceIcon.UITransformComponent
		local gT = ghost.UITransformComponent
		if isvalid(gT) then
			gT.Pivot = Vector2(0.5, 0.5)
			gT.AlignmentOption = AlignmentType.Center
			if isvalid(srcT) then
				local rs = srcT.RectSize
				-- Guard zero-size clones; keep a readable drag cursor
				if rs.x < 1 or rs.y < 1 then
					gT.RectSize = Vector2(64, 64)
				else
					gT.RectSize = rs
				end
			else
				gT.RectSize = Vector2(64, 64)
			end
		end
		if isvalid(gT) then
			_UILogic:SetSiblingIndex(gT, 1000000)
		end

		self.invDragGhost = ghost

		-- Hide original in-slot icon only after ghost exists (avoids double-image)
		self.invDragSourceIcon = sourceIcon
		if isvalid(srcSprite) then
			self.invDragSourceIconOriginalColor = srcSprite.Color
			local c = self.invDragSourceIconOriginalColor
			srcSprite.Color = Color(c.r, c.g, c.b, 0)
		end

		self:PositionInvDragGhost(screenPoint)
	end

	@ExecSpace("ClientOnly")
	method void PositionInvDragGhost(Vector2 screenPoint)
		if not isvalid(self.invDragGhost) then return end
		local gT = self.invDragGhost.UITransformComponent
		if not isvalid(gT) then return end
		local host = self.invDragGhost.Parent
		if not isvalid(host) or not isvalid(host.UITransformComponent) then return end
		local localPos = _UILogic:ScreenToLocalUIPosition(screenPoint, host.UITransformComponent)
		gT.anchoredPosition = localPos
	end

	@ExecSpace("ClientOnly")
	method void ResetInvDragState()
		-- Clears inventory→quickslot drag state and floating ghost.
		self:DestroyInvDragGhost()
		-- Legacy path safety: if source icon was moved in-place, snap it back
		if isvalid(self.invDraggedIcon) and self.invDraggedIconOriginalPos ~= nil then
			if isvalid(self.invDraggedIcon.UITransformComponent) then
				self.invDraggedIcon.UITransformComponent.anchoredPosition = self.invDraggedIconOriginalPos
			end
		end
		self.invIsDragging = false
		self.invDragAccumulatedDelta = 0
		self.invDragItemKey = ""
		self.invDraggedIcon = nil
		self.invDragStartSlot = nil
	end

	@ExecSpace("ClientOnly")
	method integer HitTestQuickSlot(Vector2 screenPoint)
		-- Returns 1..10 if screenPoint is inside a HUD quickslot, else -1.
		-- Same bounds math as UIHUDController quickslot D&D drop (raycast-independent).
		for targetIdx = 1, 10 do
			local targetPath = "/ui/HUDGroup/QuickSlots/Slot" .. targetIdx
			local targetSlot = _EntityService:GetEntityByPath(targetPath)
			if isvalid(targetSlot) then
				local localPos = _UILogic:ScreenToLocalUIPosition(screenPoint, targetSlot.UITransformComponent)
				local rectSize = targetSlot.UITransformComponent.RectSize
				local pivot = targetSlot.UITransformComponent.Pivot

				local minX = -rectSize.x * pivot.x
				local maxX = rectSize.x * (1 - pivot.x)
				local minY = -rectSize.y * pivot.y
				local maxY = rectSize.y * (1 - pivot.y)

				if localPos.x >= minX and localPos.x <= maxX and localPos.y >= minY and localPos.y <= maxY then
					return targetIdx
				end
			end
		end
		return -1
	end

	@ExecSpace("ClientOnly")
	method boolean IsFurnaceOrChestOpen()
		local furnacePopup = _EntityService:GetEntityByPath("/ui/PopupGroup/FurnacePopup")
		local furnaceOpen = isvalid(furnacePopup) and furnacePopup.Enable
		local chestPopup = _EntityService:GetEntityByPath("/ui/PopupGroup/ChestPopup")
		local chestOpen = isvalid(chestPopup) and chestPopup.Enable
		return furnaceOpen or chestOpen
	end

	@ExecSpace("ClientOnly")
	method void RefreshGridItem(integer index, Entity slotEntity)
		-- index is 0-based
		local data = self.filteredItems[index + 1]
		if not data then return end
		
		-- Set rarity background color
		if isvalid(slotEntity) and isvalid(slotEntity.SpriteGUIRendererComponent) then
			local rarity = self:GetItemRarity(data.name)
			slotEntity.SpriteGUIRendererComponent.Color = self:GetRarityColor(rarity)
		end
		
		-- Icon
		local iconEntity = slotEntity:GetChildByName("Icon")
		if isvalid(iconEntity) and isvalid(iconEntity.SpriteGUIRendererComponent) then
			iconEntity.SpriteGUIRendererComponent.ImageRUID = self:GetItemIcon(data.name)
		end
		
		-- Count (+ equipped marker)
		local equippedTool = self:GetEquippedToolName()
		local countTextEntity = slotEntity:GetChildByName("Count")
		if isvalid(countTextEntity) and isvalid(countTextEntity.TextComponent) then
			if data.key == equippedTool then
				countTextEntity.TextComponent.Text = "[E] x" .. data.count
				countTextEntity.TextComponent.FontColor = Color(0.4, 1.0, 0.4, 1)
			else
				countTextEntity.TextComponent.Text = "x" .. data.count
				countTextEntity.TextComponent.FontColor = Color.white
			end
		end
		
		local btn = slotEntity.ButtonComponent
		if isvalid(btn) then
			if self.slotHandlers[slotEntity] then
				slotEntity:DisconnectEvent(ButtonClickEvent, self.slotHandlers[slotEntity])
			end
			self.slotHandlers[slotEntity] = slotEntity:ConnectEvent(ButtonClickEvent, function()
				-- Drag-drop already consumed this gesture
				if self.invSuppressClick then
					self.invSuppressClick = false
					return
				end

				local clickTime = _UtilLogic.ElapsedSeconds
				local lastTime = self.lastClickTimes[data.key] or 0
				-- lastClickTimes는 비교 후에 갱신 (단일 클릭이 더블로 오인되지 않게)
				local isDouble = (lastTime > 0) and ((clickTime - lastTime) < 0.35)
				self.lastClickTimes[data.key] = clickTime

				local furnacePopup = _EntityService:GetEntityByPath("/ui/PopupGroup/FurnacePopup")
				local furnaceOpen = isvalid(furnacePopup) and furnacePopup.Enable
				local chestPopup = _EntityService:GetEntityByPath("/ui/PopupGroup/ChestPopup")
				local chestOpen = isvalid(chestPopup) and chestPopup.Enable
				local shiftHeld = false
				if _InputService ~= nil then
					if _InputService:IsKeyPressed(KeyboardKey.LeftShift) then shiftHeld = true end
					if _InputService:IsKeyPressed(KeyboardKey.RightShift) then shiftHeld = true end
				end

				if furnaceOpen then
					-- 툴팁 숨김. 단일=무동작(하이라이트만). 더블=1개. 시프트(+클릭)=전부.
					self:HideItemTooltip()
					if shiftHeld then
						self:TransferToFurnace(data.key, data.count, slotEntity)
						return
					end
					if isDouble then
						self:TransferToFurnace(data.key, 1, slotEntity)
						-- 더블 소비 후 타이머 리셋해 삼중 클릭 방지
						self.lastClickTimes[data.key] = 0
						return
					end
					-- 단일 클릭: 절대 투입하지 않음
					self.SelectedForFurnace = data.key
					self:FlashSlotEntity(slotEntity, Color(0.3, 0.7, 1.0, 1.0))
					return
				end

				if isDouble then
					if chestOpen then
						self:TransferToChest(data.key, data.count, slotEntity)
					else
						local player = _UserService.LocalPlayer
						if isvalid(player) then
							local inv = player:GetComponent("script.PlayerInventory")
							if isvalid(inv) then
								local activeSlot = inv.SelectedQuickSlotIndex or 1
								inv:ServerRegisterQuickSlot(activeSlot, data.key)
							end
						end
					end
					self.lastClickTimes[data.key] = 0
				else
					self:ShowTooltip(data.key, data.count)
				end
			end)
		end

		-- Inventory → QuickSlot drag (reuses ServerRegisterQuickSlot + HUD hit-test)
		if isvalid(slotEntity.SpriteGUIRendererComponent) then
			slotEntity.SpriteGUIRendererComponent.RaycastTarget = true
		end
		if not isvalid(slotEntity:GetComponent("UITouchReceiveComponent")) then
			slotEntity:AddComponent("UITouchReceiveComponent")
		end

		if self.invTouchDownHandlers[slotEntity] then
			slotEntity:DisconnectEvent(UITouchDownEvent, self.invTouchDownHandlers[slotEntity])
		end
		if self.invTouchDragHandlers[slotEntity] then
			slotEntity:DisconnectEvent(UITouchDragEvent, self.invTouchDragHandlers[slotEntity])
		end
		if self.invTouchUpHandlers[slotEntity] then
			slotEntity:DisconnectEvent(UITouchUpEvent, self.invTouchUpHandlers[slotEntity])
		end

		self.invTouchDownHandlers[slotEntity] = slotEntity:ConnectEvent(UITouchDownEvent, function(event)
			self.invDragStartSlot = slotEntity
			self.invDragItemKey = data.key
			self.invIsDragging = false
			self.invDragAccumulatedDelta = 0
			self.invSuppressClick = false

			local icon = slotEntity:GetChildByName("Icon")
			if isvalid(icon) then
				self.invDraggedIcon = icon
				self.invDraggedIconOriginalPos = icon.UITransformComponent.anchoredPosition
				local startLocalPos = _UILogic:ScreenToLocalUIPosition(event.TouchPoint, slotEntity.UITransformComponent)
				self.invDragOffset = startLocalPos - self.invDraggedIconOriginalPos
			else
				self.invDraggedIcon = nil
			end
		end)

		self.invTouchDragHandlers[slotEntity] = slotEntity:ConnectEvent(UITouchDragEvent, function(event)
			if self.invDragStartSlot ~= slotEntity then return end
			-- 상자는 클릭 전용; 화로/냄비는 드래그 허용
			local chestPopup = _EntityService:GetEntityByPath("/ui/PopupGroup/ChestPopup")
			if isvalid(chestPopup) and chestPopup.Enable then return end

			self.invDragAccumulatedDelta = self.invDragAccumulatedDelta + math.abs(event.TouchDelta.x) + math.abs(event.TouchDelta.y)
			if self.invDragAccumulatedDelta > 5 then
				self.invIsDragging = true
			end

			if self.invIsDragging then
				if isvalid(self.invDraggedIcon) then
					self:EnsureInvDragGhost(self.invDraggedIcon, event.TouchPoint)
				end
				self:PositionInvDragGhost(event.TouchPoint)
			end
		end)

		self.invTouchUpHandlers[slotEntity] = slotEntity:ConnectEvent(UITouchUpEvent, function(event)
			if self.invDragStartSlot ~= slotEntity then return end

			local wasDragging = self.invIsDragging
			local itemKey = self.invDragItemKey

			if wasDragging and itemKey ~= "" then
				local furnacePopup = _EntityService:GetEntityByPath("/ui/PopupGroup/FurnacePopup")
				local furnaceOpen = isvalid(furnacePopup) and furnacePopup.Enable
				if furnaceOpen then
					local slotType = self:HitTestFurnaceSlot(event.TouchPoint)
					if slotType ~= "" then
						-- 드래그앤드롭 = 보유 전부 투입
						self:TransferToFurnaceSlot(itemKey, data.count, slotType, slotEntity)
						self.invSuppressClick = true
					else
						self.invSuppressClick = true
					end
				else
					local dropTargetIndex = self:HitTestQuickSlot(event.TouchPoint)
					if dropTargetIndex ~= -1 then
						local player = _UserService.LocalPlayer
						if isvalid(player) then
							local inv = player:GetComponent("script.PlayerInventory")
							if isvalid(inv) then
								inv:ServerRegisterQuickSlot(dropTargetIndex, itemKey)
								self:FlashSlotEntity(slotEntity, Color(0.2, 0.8, 0.2, 1.0))
								self.invSuppressClick = true
							end
						end
					else
						self.invSuppressClick = true
					end
				end
			end

			self:ResetInvDragState()
		end)
	end

	@ExecSpace("ClientOnly")
	method string GetEquippedToolName()
		-- Returns the locally synced equipped tool name.
		local player = _UserService.LocalPlayer
		if not isvalid(player) then return "" end
		local inv = player:GetComponent("script.PlayerInventory")
		if not isvalid(inv) then return "" end
		return inv.EquippedTool or ""
	end

	@ExecSpace("ClientOnly")
	method void HideItemTooltip()
		if isvalid(self.tooltipPanel) then
			self.tooltipPanel.Enable = false
		end
		self.inspectedItem = ""
		self.inspectedCount = 0
	end

	@ExecSpace("ClientOnly")
	method void ShowTooltip(string itemKey, integer count)
		-- Shows the item details tooltip with rarity colors.
		-- 화로/냄비 열림 중에는 툴팁이 스테이션 UI를 가리므로 표시하지 않음.
		if self:IsFurnaceOpenOnly() then
			self:HideItemTooltip()
			return
		end
		if not isvalid(self.tooltipPanel) then return end
		self.tooltipPanel.Enable = true
		self.inspectedItem = itemKey
		self.inspectedCount = count
		
		local player = _UserService.LocalPlayer
		local inv = isvalid(player) and player:GetComponent("script.PlayerInventory")
		local baseName = isvalid(inv) and inv:GetBaseItemName(itemKey) or itemKey
		
		if isvalid(self.tooltipName) then
			self.tooltipName.Text = baseName
			local rarity = self:GetItemRarity(baseName)
			self.tooltipName.FontColor = self:GetRarityColor(rarity)
		end
		if isvalid(self.tooltipDesc) then
			self.tooltipDesc.Text = self:GetItemDescription(baseName)
		end
		if isvalid(self.tooltipCount) then
			local suffix = ""
			if itemKey == self:GetEquippedToolName() then
				suffix = "  (Equipped)"
			elseif self:GetItemCategory(baseName) == "Equipment" then
				suffix = "  (Double-click to register)"
			end
			self.tooltipCount.Text = "Owned: " .. count .. suffix
		end
	end

	@ExecSpace("ClientOnly")
	method boolean IsFurnaceOpenOnly()
		local furnacePopup = _EntityService:GetEntityByPath("/ui/PopupGroup/FurnacePopup")
		return isvalid(furnacePopup) and furnacePopup.Enable
	end

	@ExecSpace("ClientOnly")
	method string GetOpenFurnaceRecipeTable()
		local furnacePopup = _EntityService:GetEntityByPath("/ui/PopupGroup/FurnacePopup")
		if not isvalid(furnacePopup) then return "SmeltingRecipeDataSet" end
		local furnaceController = furnacePopup:GetComponent("script.UIFurnaceController")
		if isvalid(furnaceController) and furnaceController.GetRecipeTableName ~= nil then
			return furnaceController:GetRecipeTableName()
		end
		return "SmeltingRecipeDataSet"
	end

	@ExecSpace("ClientOnly")
	method string HitTestFurnaceSlot(Vector2 screenPoint)
		-- 인벤 드래그 드롭 대상: input / fuel (output 제외).
		local paths = {
			input = "/ui/PopupGroup/FurnacePopup/Bg/InputSlot",
			fuel = "/ui/PopupGroup/FurnacePopup/Bg/FuelSlot",
		}
		for slotType, path in pairs(paths) do
			local ent = _EntityService:GetEntityByPath(path)
			if isvalid(ent) and isvalid(ent.UITransformComponent) then
				local tr = ent.UITransformComponent
				local size = tr.RectSize
				-- world corners approx via ScreenToLocal
				local localPos = _UILogic:ScreenToLocalUIPosition(screenPoint, tr)
				if localPos ~= nil then
					local hx = size.x * 0.5
					local hy = size.y * 0.5
					if localPos.x >= -hx and localPos.x <= hx and localPos.y >= -hy and localPos.y <= hy then
						return slotType
					end
				end
			end
		end
		return ""
	end

	@ExecSpace("ClientOnly")
	method void TransferToFurnaceSlot(string itemKey, integer count, string slotType, Entity slotEntity)
		-- slotType: "input" | "fuel" | ""(자동 판정)
		local furnacePopup = _EntityService:GetEntityByPath("/ui/PopupGroup/FurnacePopup")
		if not isvalid(furnacePopup) then return end
		local furnaceController = furnacePopup:GetComponent("script.UIFurnaceController")
		if not isvalid(furnaceController) or not isvalid(furnaceController.CurrentFurnace) then return end
		local furnaceComp = furnaceController.CurrentFurnace:GetComponent("script.Furnace")
		if not isvalid(furnaceComp) then return end

		local player = _UserService.LocalPlayer
		local inv = isvalid(player) and player:GetComponent("script.PlayerInventory")
		local baseName = isvalid(inv) and inv:GetBaseItemName(itemKey) or itemKey
		if count == nil or count < 1 then count = 1 end

		local recipeTable = self:GetOpenFurnaceRecipeTable()
		local recipeDs = _DataService:GetTable(recipeTable)
		local fuelDs = _DataService:GetTable("FurnaceFuelDataSet")
		local isFuel = fuelDs ~= nil and fuelDs:FindRow("FuelItem", baseName) ~= nil
		local isInput = recipeDs ~= nil and recipeDs:FindRow("InputItem", baseName) ~= nil

		local target = slotType
		if target == nil or target == "" then
			if isFuel and not isInput then
				target = "fuel"
			elseif isInput then
				target = "input"
			elseif isFuel then
				target = "fuel"
			else
				target = ""
			end
		end

		local transferred = false
		if target == "fuel" and isFuel then
			local curCount = furnaceComp.FuelItemCount
			local toPut = math.min(99 - curCount, count)
			if toPut > 0 then
				furnaceComp:RequestPutItem("fuel", baseName, toPut)
				transferred = true
			end
		elseif target == "input" and isInput then
			if furnaceComp.InputItemName ~= "" and furnaceComp.InputItemName ~= baseName then
				transferred = false
			else
				local curCount = furnaceComp.InputItemCount
				local toPut = math.min(99 - curCount, count)
				if toPut > 0 then
					furnaceComp:RequestPutItem("input", baseName, toPut)
					transferred = true
				end
			end
		end

		self:HideItemTooltip()
		if transferred then
			self:FlashSlotEntity(slotEntity, Color(0.2, 0.8, 0.2, 1.0))
			self.SelectedForFurnace = ""
			_TimerService:SetTimerOnce(function()
				if isvalid(self) then
					self:RefreshInventoryData()
				end
			end, 0.15)
		else
			self:FlashSlotEntity(slotEntity, Color(0.8, 0.2, 0.2, 1.0))
		end
	end

	@ExecSpace("ClientOnly")
	method void TransferToFurnace(string itemKey, integer count, Entity slotEntity)
		-- 자동 슬롯 판정 (레시피 테이블 = 열린 스테이션 기준).
		self:TransferToFurnaceSlot(itemKey, count, "", slotEntity)
	end

	@ExecSpace("ClientOnly")
	method void TransferToChest(string itemKey, integer count, Entity slotEntity)
		local chestPopup = _EntityService:GetEntityByPath("/ui/PopupGroup/ChestPopup")
		if not isvalid(chestPopup) then return end
		local chestController = chestPopup:GetComponent("script.UIChestController")
		if not isvalid(chestController) or not isvalid(chestController.CurrentChest) then return end
		local chestComp = chestController.CurrentChest:GetComponent("script.Chest")
		if not isvalid(chestComp) then return end
		
		chestComp:ServerRequestPutItem(itemKey, count)
		
		self:FlashSlotEntity(slotEntity, Color(0.2, 0.8, 0.2, 1.0))
		_TimerService:SetTimerOnce(function()
			if isvalid(self) then
				self:RefreshInventoryData()
			end
		end, 0.15)
	end

	@ExecSpace("ClientOnly")
	method void FlashSlotEntity(Entity slotEntity, Color flashColor)
		if not isvalid(slotEntity) or not isvalid(slotEntity.SpriteGUIRendererComponent) then return end
		local original = slotEntity.SpriteGUIRendererComponent.Color
		slotEntity.SpriteGUIRendererComponent.Color = flashColor
		_TimerService:SetTimerOnce(function()
			if isvalid(slotEntity) and isvalid(slotEntity.SpriteGUIRendererComponent) then
				slotEntity.SpriteGUIRendererComponent.Color = original
			end
		end, 0.3)
	end

	@ExecSpace("ClientOnly")
	method void UpdateDimmer()
		local dimmer = _EntityService:GetEntityByPath("/ui/PopupGroup/Dimmer")
		if not isvalid(dimmer) then return end
		
		local inv = _EntityService:GetEntityByPath("/ui/PopupGroup/InventoryPopup")
		local craft = _EntityService:GetEntityByPath("/ui/PopupGroup/CraftingPopup")
		local char = _EntityService:GetEntityByPath("/ui/PopupGroup/CharacterPopup")
		
		local anyOpen = (isvalid(inv) and inv.Enable) or (isvalid(craft) and craft.Enable) or (isvalid(char) and char.Enable)
		dimmer.Enable = anyOpen
	end

	@ExecSpace("ClientOnly")
	method void OpenDiscard()
		-- Opens the quantity-stepper modal for the currently inspected item.
		if self.inspectedItem == "" then return end
		if self.inspectedCount <= 0 then return end
		if not isvalid(self.discardPopup) then return end

		self.discardMax = self.inspectedCount
		self.discardCount = 1
		if isvalid(self.discardItemText) then
			self.discardItemText.Text = self.inspectedItem .. "  (보유 " .. self.inspectedCount .. ")"
		end
		self:UpdateDiscardCountText()
		self.discardPopup.Enable = true
	end

	@ExecSpace("ClientOnly")
	method void ChangeDiscardCount(integer delta)
		-- Steps the discard quantity within [1, owned amount].
		self.discardCount = self.discardCount + delta
		if self.discardCount < 1 then self.discardCount = 1 end
		if self.discardCount > self.discardMax then self.discardCount = self.discardMax end
		self:UpdateDiscardCountText()
	end

	@ExecSpace("ClientOnly")
	method void UpdateDiscardCountText()
		-- Reflects the current discard quantity in the stepper label.
		if isvalid(self.discardCountText) then
			self.discardCountText.Text = tostring(self.discardCount)
		end
	end

	@ExecSpace("ClientOnly")
	method void CloseDiscard()
		-- Hides the discard modal without acting.
		if isvalid(self.discardPopup) then
			self.discardPopup.Enable = false
		end
	end

	@ExecSpace("ClientOnly")
	method void DoDiscard(string mode)
		-- Sends the discard request to the server (mode = "drop" or "delete"), then closes.
		local itemName = self.inspectedItem
		local count = self.discardCount
		if itemName == "" or count <= 0 then
			self:CloseDiscard()
			return
		end

		local player = _UserService.LocalPlayer
		if isvalid(player) then
			local inv = player:GetComponent("script.PlayerInventory")
			if isvalid(inv) then
				---@type PlayerInventory
				local pi = inv
				pi:ServerRequestDiscard(itemName, count, mode)
			end
		end

		self:CloseDiscard()
		self.tooltipPanel.Enable = false
		self.inspectedItem = ""
		self.inspectedCount = 0
	end

end