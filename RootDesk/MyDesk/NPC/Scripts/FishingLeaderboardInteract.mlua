@Component
script FishingLeaderboardInteract extends Component
	-- T57: 낚시왕 리더보드 픽스처 F/BtnInteract → ranking-basic UI 오픈.
	-- T59: TouchEvent 제거. KeyDown F + InteractRequestEvent 브리지.

	property number InteractRange = 3.0
	property any keyHandler = nil
	property any interactRequestHandler = nil
	-- T67: 조준선 footprint
	property integer AimFootprintW = 1
	property integer AimFootprintH = 1

	method void OnBeginPlay()
		-- 클라: F KeyDown + InteractRequestEvent 구독.
		if self:IsClient() then
			self.keyHandler = _InputService:ConnectEvent(KeyDownEvent, self.OnKeyDown)
			local lp = _UserService.LocalPlayer
			if isvalid(lp) then
				-- LEA-4002: ClientOnly 메서드에 커스텀 Event 타입 파라미터 불가 → 클로저 구독.
				self.interactRequestHandler = lp:ConnectEvent(InteractRequestEvent, function()
					self:TryInteract()
				end)
			else
				log_warning("[T57][FISHRANK] LocalPlayer nil — InteractRequestEvent not connected")
			end
			log("[T57][FISHRANK] leaderboard fixture ready")
		end
	end

	method void OnEndPlay()
		-- 핸들러 해제.
		if self:IsClient() then
			if self.keyHandler ~= nil then
				_InputService:DisconnectEvent(KeyDownEvent, self.keyHandler)
				self.keyHandler = nil
			end
			if self.interactRequestHandler ~= nil then
				local lp = _UserService.LocalPlayer
				if isvalid(lp) then
					lp:DisconnectEvent(InteractRequestEvent, self.interactRequestHandler)
				end
				self.interactRequestHandler = nil
			end
		end
	end

	@ExecSpace("ClientOnly")
	method void OnKeyDown(KeyDownEvent event)
		-- F 키 → TryInteract.
		if event.key ~= KeyboardKey.F then return end
		self:TryInteract()
	end

	@ExecSpace("ClientOnly")
	method void TryInteract()
		-- T67: 조준선 게이트 (근접 거리 판정 폐지).
		local localPlayer = _UserService.LocalPlayer
		if not isvalid(localPlayer) then return end
		local pc = localPlayer:GetComponent("script.PlayerController")
		if not isvalid(pc) then return end
		if not pc:IsAimTarget(self.Entity) then return end
		log("[T67][AIM] FishingLeaderboard aim-ok")
		self:OpenLeaderboard()
	end

	@ExecSpace("ClientOnly")
	method number GetDistanceToPlayer(Entity player)
		-- 월드 거리.
		local myPos = self.Entity.TransformComponent.WorldPosition
		local playerPos = player.TransformComponent.WorldPosition
		return Vector2.Distance(Vector2(myPos.x, myPos.y), Vector2(playerPos.x, playerPos.y))
	end

	@ExecSpace("ClientOnly")
	method void OpenLeaderboard()
		-- ranking-basic-package UI 오픈 (Sample UILogic).
		if _RankingSampleUILogic == nil then
			log_error("[T57][FISHRANK] _RankingSampleUILogic missing")
			return
		end
		_RankingSampleUILogic:OpenUI()
		local week = 0
		if _FishingContestLogic ~= nil then
			week = _FishingContestLogic:GetCurrentWeekIndex()
		end
		log("[T57][FISHRANK] open leaderboard week=" .. tostring(week))
	end

end
